@* Modal dialog for creating/editing a parameter set. Returns ParamSetDialogResult on confirm. *@

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? "Edit Parameter Set" : "New Parameter Set")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            @if (!IsEdit)
            {
                <MudSelect T="Guid?" @bind-Value="_cbotId" Label="cBot" Required="true" RequiredError="cBot is required" Class="mb-2">
                    @foreach (var c in CBots) { <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">@c.Name</MudSelectItem> }
                </MudSelect>
            }
            <MudTextField @bind-Value="_name" Label="Name" Required="true" RequiredError="Name is required" Class="mb-2" Immediate="true" />
            <MudTextField @bind-Value="_json" Label="JSON" Lines="8" Variant="Variant.Outlined" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance Dialog { get; set; } = default!;

    [Parameter] public string? Name { get; set; }
    [Parameter] public string? Json { get; set; }
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public IReadOnlyList<CBotOption> CBots { get; set; } = [];
    [Parameter] public Guid? CBotId { get; set; }

    private MudForm? _form;
    private string _name = "";
    private string _json = "{}";
    private Guid? _cbotId;

    protected override void OnInitialized()
    {
        _name = Name ?? "";
        _json = string.IsNullOrWhiteSpace(Json) ? "{}" : Json!;
        _cbotId = CBotId;
    }

    private async Task Submit()
    {
        if (_form is not null) await _form.Validate();
        if (string.IsNullOrWhiteSpace(_name)) return;
        if (!IsEdit && _cbotId is null) return;
        Dialog.Close(DialogResult.Ok(new ParamSetDialogResult(_cbotId, _name.Trim(), _json)));
    }

    private void Cancel() => Dialog.Cancel();

    public sealed record ParamSetDialogResult(Guid? CBotId, string Name, string Json);
    public sealed record CBotOption(Guid Id, string Name);
}
