@* Modal dialog showing a freshly generated temporary password once, with a copy button. *@
@inject IJSRuntime JS
@inject ISnackbar Snack
@inject IStringLocalizer<Ui> L

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@L["users.tempPassword.title"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Warning" Class="mb-2">
            @L["users.tempPassword.warning"]
        </MudText>
        <MudTextField Value="Password" ReadOnly="true" Label="@L["users.tempPassword.label"]"
                      Variant="Variant.Outlined" Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.ContentCopy" OnAdornmentClick="Copy"
                      T="string" data-testid="temp-password" />
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Copy">@L["common.copy"]</MudButton>
        <MudButton OnClick="Close">@L["common.close"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance Dialog { get; set; } = default!;

    [Parameter] public string Password { get; set; } = "";

    private async Task Copy()
    {
        await JS.InvokeVoidAsync("copyToClipboard", Password);
        Snack.Add(L["common.copiedToClipboard"], Severity.Success);
    }

    private void Close() => Dialog.Close();
}
