@page "/ai/review"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inherits AiFeaturePageBase

<PageTitle>AI · Review cBot</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Review cBot</MudText>
    <HelpTip Text="Paste a cBot's source and the AI reviews it for bugs, risky trading logic, and missing safeguards before you run it." />
</MudStack>

<AiFeatureNotice EnabledChanged="OnAiStatus" PromptOnLoad="true" />

<MudPaper Class="pa-4" Elevation="1">
    <MudTextField @bind-Value="_source" Label="cBot source" Lines="10"
                  Placeholder="Paste cBot source to review for bugs and trading risks" />
    <AiModelSelect Feature="AiFeature.ReviewCBot" @bind-Selected="SelectedModelId" Class="mt-3" />
    <MudButton Class="mt-3" Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.RateReview" OnClick="Run" Disabled="Busy">
        Review cBot
    </MudButton>
</MudPaper>

<AiOutputPanel Loading="@Loading" Output="@Output" />

@code {
    private string _source = "";
    private const string Language = "CSharp";

    private Task Run() => PostTextAsync("/api/ai/review", new { Language, Source = _source });
}
