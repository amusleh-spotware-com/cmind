@page "/ai/build"
@using System.Text.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inherits AiFeaturePageBase
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IDialogService Dialogs

<PageTitle>AI · Build cBot</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Build cBot</MudText>
    <HelpTip Text="Describe a strategy in plain English. The AI writes the cBot, builds it, fixes its own compile errors (up to 3 tries), and on success creates a runnable cBot." />
</MudStack>

<AiFeatureNotice EnabledChanged="OnAiStatus" PromptOnLoad="true" />

<MudPaper Class="pa-4" Elevation="1">
    <MudText Typo="Typo.body2" Class="mb-2">
        Describe a strategy in plain English. The AI writes the cBot, builds it, fixes its own compile
        errors (up to 3 tries), and on success creates a runnable cBot.
    </MudText>
    <MudGrid>
        <MudItem xs="12" sm="4">
            <MudSelect T="string" @bind-Value="_language" Label="Language" Dense="true">
                <MudSelectItem Value="@("CSharp")">C#</MudSelectItem>
                <MudSelectItem Value="@("Python")">Python</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="8">
            <MudTextField @bind-Value="_projectName" Label="Bot name" Placeholder="MyBot" />
        </MudItem>
    </MudGrid>
    <MudTextField @bind-Value="_description" Label="Describe your strategy" Lines="5" Class="mt-3"
                  Placeholder="e.g. RSI mean-reversion on EURUSD h1, 1.5% risk, ATR stop-loss" />
    <AiModelSelect Feature="AiFeature.GenerateCBot" @bind-Selected="SelectedModelId" Class="mt-3" />
    <MudStack Row="true" Spacing="2" Class="mt-3" Wrap="Wrap.Wrap">
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Bolt" OnClick="BuildBot" Disabled="Busy">
            Build my bot
        </MudButton>
    </MudStack>

    @if (Loading)
    {
        <MudProgressLinear Indeterminate="true" Class="mt-3" />
    }

    @if (_buildResult is not null)
    {
        <MudPaper Class="pa-3 mt-3" Elevation="0" Outlined="true" data-testid="ai-build-result">
            @if (_buildResult.Success)
            {
                <MudAlert Severity="Severity.Success" Class="mb-2">
                    Built in @_buildResult.Attempts attempt(s). Saved as <b>@_buildResult.Name</b> in your cBots — your runnable cBot is ready.
                </MudAlert>
                <MudStack Row="true" Spacing="2">
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="@(() => Nav.NavigateTo($"/run?cbot={_buildResult.CBotId}"))"
                               Disabled="@(_buildResult.CBotId is null)">Run it</MudButton>
                    <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="@(() => Nav.NavigateTo($"/builder/{_buildResult.ProjectId}"))"
                               Disabled="@(_buildResult.ProjectId is null)">Open in editor</MudButton>
                </MudStack>
            }
            else
            {
                <MudAlert Severity="Severity.Error" Class="mb-2">
                    @(_buildResult.Error ?? $"Build failed after {_buildResult.Attempts} attempt(s).")
                </MudAlert>
                @if (_buildResult.ProjectId is not null)
                {
                    <MudAlert Severity="Severity.Info" Class="mb-2" data-testid="ai-build-saved">
                        Saved as <b>@_buildResult.Name</b> in your cBots — open it in the editor to fix the errors and rebuild.
                    </MudAlert>
                    <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="@(() => Nav.NavigateTo($"/builder/{_buildResult.ProjectId}"))"
                               data-testid="ai-build-open-failed">Open in editor</MudButton>
                }
            }
            @if (!string.IsNullOrEmpty(_buildResult.Code))
            {
                <MudExpansionPanels Class="mt-2" Elevation="0">
                    <MudExpansionPanel Expanded="true" data-testid="ai-build-code-panel">
                        <TitleContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle2">Generated @(_buildResult.Language == "Python" ? "Python" : "C#") code</MudText>
                                <MudSpacer />
                                <MudTooltip Text="Copy code">
                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                                   OnClick="CopyCode" data-testid="ai-build-copy" />
                                </MudTooltip>
                            </MudStack>
                        </TitleContent>
                        <ChildContent>
                            <pre style="white-space:pre; margin:0; max-height:420px; overflow:auto; font-size:0.8rem;"
                                 data-testid="ai-build-code">@_buildResult.Code</pre>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            }
            @if (!string.IsNullOrEmpty(_buildResult.Log))
            {
                <MudExpansionPanels Class="mt-2" Elevation="0">
                    <MudExpansionPanel Expanded="@(!_buildResult.Success)" data-testid="ai-build-log-panel">
                        <TitleContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle2">Build log</MudText>
                                <MudSpacer />
                                <MudTooltip Text="Copy build log">
                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                                   OnClick="CopyLog" data-testid="ai-build-copy-log" />
                                </MudTooltip>
                            </MudStack>
                        </TitleContent>
                        <ChildContent>
                            <pre style="white-space:pre-wrap; margin:0; max-height:280px; overflow:auto;">@_buildResult.Log</pre>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            }
        </MudPaper>
    }
</MudPaper>

@code {
    private string _language = "CSharp";
    private string _projectName = "MyBot";
    private string _description = "";
    private BuildResult? _buildResult;

    private async Task BuildBot()
    {
        if (string.IsNullOrWhiteSpace(_description))
        {
            Snack.Add("Describe your strategy first", Severity.Warning);
            return;
        }
        Loading = true;
        _buildResult = null;
        try
        {
            var response = await Http.PostAsJsonAsync(WithModel("/api/ai/build-strategy"),
                new { Name = _projectName, Language = _language, Description = _description });
            var text = await response.Content.ReadAsStringAsync();
            using var doc = JsonDocument.Parse(text);
            var root = doc.RootElement;
            _buildResult = new BuildResult(
                root.TryGetProperty("success", out var s) && s.ValueKind == JsonValueKind.True,
                root.TryGetProperty("cbotId", out var c) && c.ValueKind == JsonValueKind.String ? c.GetGuid() : null,
                root.TryGetProperty("projectId", out var p) && p.ValueKind == JsonValueKind.String ? p.GetGuid() : null,
                root.TryGetProperty("attempts", out var a) && a.ValueKind == JsonValueKind.Number ? a.GetInt32() : 0,
                root.TryGetProperty("log", out var l) ? l.GetString() : null,
                root.TryGetProperty("error", out var e) ? e.GetString() : null,
                root.TryGetProperty("code", out var cd) ? cd.GetString() : null,
                root.TryGetProperty("language", out var lang) ? lang.GetString() : _language,
                root.TryGetProperty("name", out var nm) ? nm.GetString() : null);
        }
        catch
        {
            Snack.Add("Request failed", Severity.Error);
        }
        finally
        {
            Loading = false;
        }
    }

    private async Task CopyCode()
    {
        if (string.IsNullOrEmpty(_buildResult?.Code)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _buildResult.Code);
            Snack.Add("Code copied", Severity.Success);
        }
        catch
        {
            Snack.Add("Copy failed", Severity.Warning);
        }
    }

    private async Task CopyLog()
    {
        if (string.IsNullOrEmpty(_buildResult?.Log)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _buildResult.Log);
            Snack.Add("Build log copied", Severity.Success);
        }
        catch
        {
            Snack.Add("Copy failed", Severity.Warning);
        }
    }

    private sealed record BuildResult(
        bool Success, Guid? CBotId, Guid? ProjectId, int Attempts, string? Log, string? Error, string? Code, string? Language,
        string? Name);
}
