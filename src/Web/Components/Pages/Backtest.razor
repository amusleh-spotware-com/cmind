@page "/backtest"
@using Web.Components.Dialogs
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs

<PageTitle>Backtest</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Backtest cBot</MudText>
    <MudSpacer />
    <MudButton Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNew">
        Backtest New cBot
    </MudButton>
</MudStack>

<MudText Typo="Typo.h6" Class="mt-4">Backtests</MudText>
<InstanceTable Type="Backtest" />

@code {
    private async Task OpenNew()
    {
        var dlg = await Dialogs.ShowAsync<BacktestDialog>("Backtest cBot",
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (BacktestDialog.BacktestDialogResult)res.Data!;
        var settings = System.Text.Json.JsonSerializer.Serialize(new
        {
            from = data.From?.ToString("yyyy-MM-dd"),
            to = data.To?.ToString("yyyy-MM-dd")
        });
        var r = await Http.PostAsJsonAsync("/api/instances/", new
        {
            data.CBotId, data.TradingAccountId, data.Symbol, data.Timeframe,
            data.ParamSetId, DockerImageTag = data.Image, Type = "Backtest", BacktestSettingsJson = settings
        });
        Snack.Add(r.IsSuccessStatusCode ? "Backtest queued" : "Failed",
            r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
    }
}
