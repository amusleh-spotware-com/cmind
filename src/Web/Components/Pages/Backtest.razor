@page "/backtest"
@using Web.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack

<PageTitle>Backtest</PageTitle>
<MudText Typo="Typo.h5" Class="mb-3">Backtest cBot</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudSelect T="Guid?" @bind-Value="_cbotId" @bind-Value:after="LoadParamSets" Label="cBot">
            @foreach (var c in _cbots) { <MudSelectItem T="Guid?" Value="@((Guid?)c.id)">@c.name</MudSelectItem> }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudSelect T="Guid?" @bind-Value="_acctId" Label="Trading account">
            @foreach (var a in _accts) { <MudSelectItem T="Guid?" Value="@((Guid?)a.id)">@a.accountNumber - @a.broker</MudSelectItem> }
        </MudSelect>
    </MudItem>
    <MudItem xs="6" md="3"><MudTextField @bind-Value="_symbol" Label="Symbol" /></MudItem>
    <MudItem xs="6" md="3"><MudTextField @bind-Value="_timeframe" Label="Timeframe" /></MudItem>
    <MudItem xs="6" md="3"><MudDatePicker @bind-Date="_from" Label="From" /></MudItem>
    <MudItem xs="6" md="3"><MudDatePicker @bind-Date="_to" Label="To" /></MudItem>
    <MudItem xs="12" md="6">
        <MudSelect T="Guid?" @bind-Value="_psId" Label="Parameter set">
            @foreach (var p in _paramsets) { <MudSelectItem T="Guid?" Value="@((Guid?)p.id)">@p.name</MudSelectItem> }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" md="6"><MudTextField @bind-Value="_image" Label="Image tag" /></MudItem>
</MudGrid>

<MudButton OnClick="Start" Color="Color.Primary" Variant="Variant.Filled" Class="mt-3">Start backtest</MudButton>

<MudText Typo="Typo.h6" Class="mt-4">Backtests</MudText>
<InstanceTable Type="Backtest" />

@code {
    private dynamic[] _cbots = [], _accts = [], _paramsets = [];
    private Guid? _cbotId, _acctId, _psId;
    private string _symbol = "EURUSD", _timeframe = "h1", _image = "latest";
    private DateTime? _from = DateTime.UtcNow.AddMonths(-1), _to = DateTime.UtcNow;

    protected override async Task OnInitializedAsync()
    {
        _cbots = await Http.GetDynamicArrayAsync("/api/cbots/");
        _accts = await Http.GetDynamicArrayAsync("/api/accounts/");
    }

    private async Task LoadParamSets()
    {
        _psId = null;
        _paramsets = _cbotId is null
            ? []
            : await Http.GetDynamicArrayAsync($"/api/paramsets?cbotId={_cbotId}");
    }

    private async Task Start()
    {
        var settings = System.Text.Json.JsonSerializer.Serialize(new
        {
            from = _from?.ToString("yyyy-MM-dd"),
            to = _to?.ToString("yyyy-MM-dd")
        });
        var r = await Http.PostAsJsonAsync("/api/instances/", new
        {
            CBotId = _cbotId, TradingAccountId = _acctId, Symbol = _symbol, Timeframe = _timeframe,
            ParamSetId = _psId, DockerImageTag = _image, Type = "Backtest", BacktestSettingsJson = settings
        });
        Snack.Add(r.IsSuccessStatusCode ? "Backtest queued" : "Failed",
            r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
    }
}
