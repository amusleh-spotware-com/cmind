@page "/alerts"
@using System.Net.Http.Json
@using Web.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack

<PageTitle>Alerts</PageTitle>

<MudText Typo="Typo.h5" Class="mb-3">AI Market Alerts</MudText>
<MudText Typo="Typo.body2" Class="mb-4">
    Watch a symbol. The AI checks current news and price action on a schedule and raises an alert only
    when something time-sensitive happens.
</MudText>

<AiFeatureNotice />

<MudGrid>
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-2">New rule</MudText>
            <MudTextField @bind-Value="_name" Label="Rule name" Placeholder="EURUSD news watch" />
            <MudTextField @bind-Value="_symbol" Label="Symbol" Class="mt-2" Placeholder="EURUSD" />
            <MudNumericField T="int" @bind-Value="_interval" Label="Check every (minutes)" Min="5" Max="1440" Class="mt-2" />
            <MudButton Class="mt-3" Color="Color.Primary" Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.AddAlert" OnClick="CreateRule" Disabled="_busy">
                Create rule
            </MudButton>
        </MudPaper>

        <MudPaper Class="pa-4 mt-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-2">Rules</MudText>
            @if (_rules.Length == 0)
            {
                <MudText Typo="Typo.body2">No rules yet.</MudText>
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true">
                    <thead><tr><th>Name</th><th>Symbol</th><th>Every</th><th>On</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var r in _rules)
                        {
                            <tr>
                                <td>@r.name</td>
                                <td>@r.symbol</td>
                                <td>@r.intervalMinutes m</td>
                                <td>@(((bool)r.enabled) ? "Yes" : "No")</td>
                                <td>
                                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete"
                                                   OnClick="@(() => DeleteRule((Guid)r.id))" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                <MudText Typo="Typo.h6">Alerts</MudText>
                <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadEvents">Refresh</MudButton>
            </MudStack>
            @if (_events.Length == 0)
            {
                <MudText Typo="Typo.body2">No alerts raised yet.</MudText>
            }
            else
            {
                @foreach (var e in _events)
                {
                    <MudAlert Severity="@SeverityOf((string)e.severity)" Class="mb-2"
                              ShowCloseIcon="@(!(bool)e.acknowledged)" CloseIconClicked="@(() => Ack((Guid)e.id))">
                        <b>@e.symbol</b> — @e.message
                        <MudText Typo="Typo.caption" Class="d-block">@FormatDate(e.createdAt) @(((bool)e.acknowledged) ? "· acknowledged" : "")</MudText>
                    </MudAlert>
                }
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private dynamic[] _rules = [], _events = [];
    private string _name = "", _symbol = "EURUSD";
    private int _interval = 60;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        await LoadRules();
        await LoadEvents();
    }

    private async Task LoadRules() => _rules = await Http.GetDynamicArrayAsync("/api/alerts/rules");
    private async Task LoadEvents() => _events = await Http.GetDynamicArrayAsync("/api/alerts/events");

    private async Task CreateRule()
    {
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_symbol))
        {
            Snack.Add("Name and symbol required", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/alerts/rules",
                new { Name = _name, Symbol = _symbol, IntervalMinutes = _interval, Enabled = true });
            if (response.IsSuccessStatusCode)
            {
                Snack.Add("Rule created", Severity.Success);
                _name = "";
                await LoadRules();
            }
            else
            {
                Snack.Add(await response.Content.ReadAsStringAsync(), Severity.Error);
            }
        }
        catch { Snack.Add("Request failed", Severity.Error); }
        finally { _busy = false; }
    }

    private async Task DeleteRule(Guid id)
    {
        var response = await Http.DeleteAsync($"/api/alerts/rules/{id}");
        if (response.IsSuccessStatusCode) await LoadRules();
        else Snack.Add("Delete failed", Severity.Error);
    }

    private async Task Ack(Guid id)
    {
        await Http.PostAsync($"/api/alerts/events/{id}/ack", null);
        await LoadEvents();
    }

    private static Severity SeverityOf(string severity) => severity switch
    {
        "critical" => Severity.Error,
        "warning" => Severity.Warning,
        _ => Severity.Info
    };

    private static string FormatDate(dynamic value)
    {
        if (value is null) return "-";
        DateTimeOffset dto = value;
        return dto.ToString("yyyy-MM-dd HH:mm");
    }
}
