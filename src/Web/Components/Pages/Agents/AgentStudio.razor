@page "/agent-studio"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@using System.Net.Http.Json
@using Web.Components.Dialogs
@using Web.Json
@inject HttpClient Http
@inject IDialogService Dialogs
@inject MudBlazor.ISnackbar Snack

<PageTitle>AI · Agent Studio</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Agent Studio</MudText>
    <HelpTip Text="Create persona-driven trading agents (no code). Each has a character and archetype, manages accounts toward your goals, and runs under the Autonomy & Safety Kernel — hard risk envelope, circuit breaker and kill switch." />
    <MudSpacer />
    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
               OnClick="CreateAgent" data-testid="agent-new">New agent</MudButton>
</MudStack>

@if (_agents.Count == 0)
{
    <MudText Typo="Typo.body2" Class="mud-text-secondary" data-testid="agents-empty">
        No agents yet. Create one to get started.
    </MudText>
}
else
{
    <MudTable Items="_agents" Dense="true" Hover="true" data-testid="agents-table">
        <HeaderContent>
            <MudTh>Agent</MudTh><MudTh>Type</MudTh><MudTh>Autonomy</MudTh><MudTh>Accounts</MudTh>
            <MudTh>Goals</MudTh><MudTh>Status</MudTh><MudTh>Last action</MudTh><MudTh>Controls</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.name</MudTd>
            <MudTd>@context.archetype</MudTd>
            <MudTd>@context.autonomy</MudTd>
            <MudTd>@context.accountCount</MudTd>
            <MudTd>@context.goalCount</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@StatusColor(context.status)">@context.status</MudChip></MudTd>
            <MudTd>@(context.lastAction ?? "—")</MudTd>
            <MudTd>
                <MudTooltip Text="Details">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" aria-label="Agent details"
                                   OnClick="() => OpenDetail(context.id, context.name)" data-testid="agent-details" />
                </MudTooltip>
                <MudTooltip Text="Edit agent">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" aria-label="Edit agent"
                                   OnClick="() => EditAgent(context)" data-testid="agent-edit" />
                </MudTooltip>
                <MudTooltip Text="Start agent">
                    <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                   aria-label="Start agent" Disabled="@(context.status == "Running")"
                                   OnClick="() => Start(context.id)" data-testid="agent-start" />
                </MudTooltip>
                <MudTooltip Text="Stop agent">
                    <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Warning"
                                   aria-label="Stop agent" Disabled="@(context.status is "Draft" or "Stopped")"
                                   OnClick="() => Stop(context.id)" data-testid="agent-stop" />
                </MudTooltip>
                <MudTooltip Text="Kill switch">
                    <MudIconButton Icon="@Icons.Material.Filled.PowerSettingsNew" Size="Size.Small" Color="Color.Error"
                                   aria-label="Kill agent" Disabled="@(context.status != "Running")"
                                   OnClick="() => Kill(context.id)" data-testid="agent-kill" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<AgentRow> _agents = [];
    private List<AgentCreateDialog.AgentAccountOption> _accounts = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAccounts();
        await Reload();
    }

    private async Task LoadAccounts()
    {
        try
        {
            var accts = await Http.GetDynamicArrayAsync("/api/accounts/");
            _accounts = accts.Select(a => new AgentCreateDialog.AgentAccountOption((Guid)a.id, (long)a.accountNumber)).ToList();
        }
        catch { _accounts = []; }
    }

    private async Task Reload()
    {
        try { _agents = await Http.GetFromJsonAsync<List<AgentRow>>("/api/agent-studio") ?? []; }
        catch { _agents = []; }
    }

    private async Task CreateAgent()
    {
        var parameters = new DialogParameters<AgentCreateDialog> { { x => x.Accounts, (IReadOnlyList<AgentCreateDialog.AgentAccountOption>)_accounts } };
        var dialog = await Dialogs.ShowAsync<AgentCreateDialog>("New agent", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: AgentCreateDialog.AgentCreateResult r })
        {
            var response = await Http.PostAsJsonAsync("/api/agent-studio", new
            {
                r.Name, r.Archetype, r.Autonomy, r.Aggressiveness, r.Patience, r.TrendBias, r.AccountIds
            });
            if (response.IsSuccessStatusCode) { await Reload(); StateHasChanged(); }
            else Snack.Add("Could not create the agent.", Severity.Error);
        }
    }

    private async Task EditAgent(AgentRow row)
    {
        var parameters = new DialogParameters<AgentEditDialog>
        {
            { x => x.AgentId, row.id },
            { x => x.Name, row.name },
            { x => x.Autonomy, row.autonomy },
            { x => x.Aggressiveness, row.aggressiveness },
            { x => x.Patience, row.patience },
            { x => x.TrendBias, row.trendBias },
            { x => x.AccountIds, (IReadOnlyList<Guid>)(row.accountIds ?? []) },
            { x => x.Accounts, (IReadOnlyList<AgentCreateDialog.AgentAccountOption>)_accounts }
        };
        var dialog = await Dialogs.ShowAsync<AgentEditDialog>("Edit agent", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true });
        var result = await dialog.Result;
        if (result is { Canceled: false }) { await Reload(); StateHasChanged(); }
    }

    private Task OpenDetail(Guid id, string name)
    {
        var parameters = new DialogParameters<AgentDetailDialog>
        {
            { x => x.AgentId, id },
            { x => x.Name, name }
        };
        return Dialogs.ShowAsync<AgentDetailDialog>(name, parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true });
    }

    private Task Start(Guid id) => Lifecycle(id, "start");
    private Task Stop(Guid id) => Lifecycle(id, "stop");
    private Task Kill(Guid id) => Lifecycle(id, "halt");

    private async Task Lifecycle(Guid id, string verb)
    {
        var response = await Http.PostAsync($"/api/agent-studio/{id}/{verb}", null);
        if (response.IsSuccessStatusCode) { await Reload(); StateHasChanged(); }
        else Snack.Add($"Could not {verb} the agent (check it has managed accounts).", Severity.Warning);
    }

    private static Color StatusColor(string status) => status switch
    {
        "Running" => Color.Success,
        "Halted" => Color.Error,
        "Stopped" => Color.Default,
        _ => Color.Info
    };

    private sealed record AgentRow(Guid id, string name, string archetype, string autonomy, string status,
        int accountCount, Guid[]? accountIds, double aggressiveness, double patience, double trendBias,
        string? lastAction, DateTimeOffset? lastActionAt, int goalCount);
}
