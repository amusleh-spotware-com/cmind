@page "/login"
@layout EmptyLayout

<PageTitle>Log in</PageTitle>

<div class="app-login-page">
    <div class="app-login-card">
        <div class="app-login-logo">
            <svg width="56" height="56" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
                <line x1="32" y1="10" x2="32" y2="18" stroke="#26C281" stroke-width="3" stroke-linecap="round"/>
                <circle cx="32" cy="8" r="3" fill="#26C281"/>
                <rect x="14" y="20" width="36" height="30" rx="6" fill="none" stroke="#26C281" stroke-width="3"/>
                <circle cx="24" cy="33" r="3.5" fill="#26C281"/>
                <circle cx="40" cy="33" r="3.5" fill="#26C281"/>
                <rect x="24" y="41" width="16" height="3" rx="1.5" fill="#26C281"/>
                <line x1="10" y1="30" x2="14" y2="30" stroke="#26C281" stroke-width="3" stroke-linecap="round"/>
                <line x1="10" y1="40" x2="14" y2="40" stroke="#26C281" stroke-width="3" stroke-linecap="round"/>
                <line x1="50" y1="30" x2="54" y2="30" stroke="#26C281" stroke-width="3" stroke-linecap="round"/>
                <line x1="50" y1="40" x2="54" y2="40" stroke="#26C281" stroke-width="3" stroke-linecap="round"/>
            </svg>
            <span class="app-login-brand">cMind</span>
        </div>

        <div class="app-login-tabs">
            <div class="app-login-tab app-login-tab-active">LOG IN</div>
        </div>

        <form method="post" action="/api/auth/login" class="app-login-form">
            <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />

            <div class="app-login-field">
                <svg class="app-login-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9BA3AF" stroke-width="2">
                    <rect x="3" y="5" width="18" height="14" rx="2"/>
                    <polyline points="3,7 12,13 21,7"/>
                </svg>
                <input type="email" name="Email" placeholder="Enter email" required autofocus />
            </div>

            <div class="app-login-field">
                <svg class="app-login-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9BA3AF" stroke-width="2">
                    <rect x="5" y="11" width="14" height="10" rx="2"/>
                    <path d="M8 11V7a4 4 0 0 1 8 0v4"/>
                </svg>
                <input type="password" name="Password" placeholder="Enter password" required />
            </div>

            <label class="app-login-remember">
                <input type="checkbox" name="RememberMe" value="true" role="switch" checked />
                <span>Remember me</span>
            </label>

            @if (HasError)
            {
                <div class="app-login-error">Invalid credentials</div>
            }

            <button class="app-login-button" type="submit">LOG IN</button>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery(Name = "error")] public string? Error { get; set; }
    private bool HasError => !string.IsNullOrEmpty(Error);
}
