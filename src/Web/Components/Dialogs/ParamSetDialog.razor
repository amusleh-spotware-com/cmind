@* Modal dialog for creating/editing a parameter set. Returns ParamSetDialogResult on confirm. *@
@using Web.Json
@inject HttpClient Http

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? "Edit Parameter Set" : "New Parameter Set")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            @if (!IsEdit)
            {
                <MudSelect T="Guid?" @bind-Value="_cbotId" Label="cBot" Required="true" RequiredError="cBot is required"
                           Class="mb-2" data-testid="paramset-cbot">
                    @foreach (var c in _cbots) { <MudSelectItem T="Guid?" Value="@((Guid?)(Guid)c.id)">@c.name</MudSelectItem> }
                </MudSelect>
                @if (_cbots.Length == 0)
                {
                    <MudText Color="Color.Error" Typo="Typo.caption" data-testid="paramset-no-cbots">
                        Create a cBot first — a parameter set belongs to a cBot.
                    </MudText>
                }
            }
            <MudTextField @bind-Value="_name" Label="Name" Required="true" RequiredError="Name is required" Class="mb-2" Immediate="true" />
            <MudTextField @bind-Value="_json" Label="JSON" Lines="8" Variant="Variant.Outlined" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                A flat JSON object mapping each parameter name to a value, e.g. <code>{"Period": 14, "Label": "trend"}</code>.
            </MudText>
            @if (_jsonError is not null)
            {
                <MudText Color="Color.Error" Typo="Typo.caption" data-testid="paramset-json-error">@_jsonError</MudText>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance Dialog { get; set; } = default!;

    [Parameter] public string? Name { get; set; }
    [Parameter] public string? Json { get; set; }
    [Parameter] public bool IsEdit { get; set; }
    // Optional cBot to preselect (the calling context's cBot). The dialog always lists EVERY cBot so the user
    // can see and pick one; on create a cBot is mandatory.
    [Parameter] public Guid? CBotId { get; set; }

    private MudForm? _form;
    private string _name = "";
    private string _json = "{}";
    private Guid? _cbotId;
    private string? _jsonError;
    private dynamic[] _cbots = [];

    protected override async Task OnInitializedAsync()
    {
        _name = Name ?? "";
        _json = string.IsNullOrWhiteSpace(Json) ? "{}" : Json!;
        _cbotId = CBotId;
        if (!IsEdit)
        {
            // Load all the user's cBots so the selector is a real picker (not a single fixed entry). Tolerate
            // a gated-off/unavailable endpoint so opening the dialog never throws into the circuit.
            try { _cbots = await Http.GetDynamicArrayAsync("/api/cbots/"); }
            catch { _cbots = []; }
        }
    }

    private async Task Submit()
    {
        if (_form is not null) await _form.Validate();
        if (string.IsNullOrWhiteSpace(_name)) return;
        if (!IsEdit && _cbotId is null) return;
        if (!Core.ParamSetJson.IsValidSchema(_json))
        {
            _jsonError = "Parameters must be a flat JSON object mapping each parameter name to a scalar value (no nested objects or arrays).";
            return;
        }
        _jsonError = null;
        Dialog.Close(DialogResult.Ok(new ParamSetDialogResult(_cbotId, _name.Trim(), _json)));
    }

    private void Cancel() => Dialog.Cancel();

    public sealed record ParamSetDialogResult(Guid? CBotId, string Name, string Json);
}
