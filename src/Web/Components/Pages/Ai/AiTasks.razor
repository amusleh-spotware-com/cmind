@page "/ai/tasks"
@using System.Net.Http.Json
@using System.Text.Json
@using Web.Json
@implements IDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs
@inject NavigationManager Nav

<PageTitle>AI · Tasks</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Class="mb-3">
    <MudText Typo="Typo.h5">AI Tasks</MudText>
    <HelpTip Text="Start a background AI task (e.g. build a cBot) with the model of your choice, then leave the page and come back to its result. Pick several models to compare — each runs as its own task." />
    <MudSpacer />
    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreate" Disabled="@(!_allowTasks)" data-testid="task-new">New task</MudButton>
</MudStack>

<AiFeatureNotice />

@if (!_allowTasks)
{
    <MudAlert Severity="Severity.Info" data-testid="tasks-disabled">
        AI tasks are turned off for this deployment.
    </MudAlert>
}
else
{
    <MudTable Items="_tasks" Dense="true" Breakpoint="Breakpoint.Sm" data-testid="tasks-table">
        <HeaderContent>
            <MudTh>Feature</MudTh><MudTh>Model</MudTh><MudTh>Status</MudTh><MudTh>Attempts</MudTh><MudTh /></HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Feature">@context.feature</MudTd>
            <MudTd DataLabel="Model" data-testid="task-model">@context.model</MudTd>
            <MudTd DataLabel="Status"><MudChip T="string" Size="Size.Small" Color="StatusColor((string)context.status)">@context.status</MudChip></MudTd>
            <MudTd DataLabel="Attempts">@context.attempts</MudTd>
            <MudTd DataLabel="">
                <MudTooltip Text="View task">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info"
                                   aria-label="View task" OnClick="@(() => OpenDetail((Guid)context.id))" data-testid="task-view" />
                </MudTooltip>
                <MudTooltip Text="@(IsActive((string)context.status) ? "Cancel task" : "Task already finished")">
                    <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Warning"
                                   Disabled="@(!IsActive((string)context.status))" aria-label="Cancel task"
                                   OnClick="@(() => Cancel((Guid)context.id))" data-testid="task-cancel-row" />
                </MudTooltip>
                <MudTooltip Text="@(IsActive((string)context.status) ? "Stop the task before deleting" : "Delete task")">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   Disabled="@IsActive((string)context.status)" aria-label="Delete task"
                                   OnClick="@(() => Delete((Guid)context.id))" data-testid="task-delete" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>

    @if (_tasks.Length == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-3" data-testid="tasks-empty">
            No tasks yet. Create one to build a cBot in the background.
        </MudText>
    }
}

<MudDialog @bind-Visible="_detailOpen" Options="_detailOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" Class="mr-2" />Task — @_detailStatus
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_detailActive)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
        }
        @if (!string.IsNullOrEmpty(_detailError))
        {
            <MudAlert Severity="Severity.Error" Class="mb-2" data-testid="task-detail-error">@_detailError</MudAlert>
        }
        @if (_detailCBotId is not null)
        {
            <MudStack Row="true" Spacing="2" Class="mb-2">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PlayArrow"
                           OnClick="@(() => Nav.NavigateTo($"/run?cbot={_detailCBotId}"))" data-testid="task-run">Run it</MudButton>
                <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Edit"
                           OnClick="@(() => Nav.NavigateTo($"/builder/{_detailProjectId}"))"
                           Disabled="@(_detailProjectId is null)" data-testid="task-open">Open in editor</MudButton>
            </MudStack>
        }
        <MudText Typo="Typo.subtitle2" Class="mt-2">Activity</MudText>
        <MudPaper Outlined="true" Class="pa-2" data-testid="task-log"
                  Style="max-height:40vh;overflow:auto;font-family:monospace;font-size:0.8rem;white-space:pre-wrap;">
            @if (_detailLogs.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Waiting for activity…</MudText>
            }
            else
            {
                @foreach (var line in _detailLogs)
                {
                    <div>@line</div>
                }
            }
        </MudPaper>
        @if (!string.IsNullOrEmpty(_detailResult))
        {
            <MudText Typo="Typo.subtitle2" Class="mt-3">Generated code</MudText>
            <pre style="white-space:pre; margin:0; max-height:40vh; overflow:auto; font-size:0.8rem;"
                 data-testid="task-result">@_detailResult</pre>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _detailOpen = false)" data-testid="task-detail-close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private dynamic[] _tasks = [];
    private bool _allowTasks = true;
    private bool _disposed;

    private static readonly DialogOptions _detailOptions =
        new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };

    private bool _detailOpen;
    private Guid _detailId;
    private string _detailStatus = "";
    private bool _detailActive;
    private string? _detailError;
    private string? _detailResult;
    private Guid? _detailCBotId;
    private Guid? _detailProjectId;
    private readonly List<string> _detailLogs = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadStatusAsync();
        await LoadAsync();
        _ = PollAsync();
    }

    private async Task LoadStatusAsync()
    {
        try
        {
            var status = await Http.GetFromJsonAsync<JsonElement>("/api/ai/status");
            _allowTasks = !status.TryGetProperty("allowTasks", out var a) || a.GetBoolean();
        }
        catch
        {
            _allowTasks = true;
        }
    }

    private async Task LoadAsync()
    {
        if (!_allowTasks) return;
        try { _tasks = await Http.GetDynamicArrayAsync("/api/ai/tasks"); }
        catch { _tasks = []; }
    }

    private async Task PollAsync()
    {
        while (!_disposed)
        {
            await Task.Delay(2500);
            if (_disposed) break;
            var anyActive = ((IEnumerable<dynamic>)_tasks).Any(t => IsActive((string)t.status));
            if (!anyActive && !_detailActive) continue;
            await LoadAsync();
            if (_detailOpen && _detailActive) await LoadDetailAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenCreate()
    {
        var dialog = await Dialogs.ShowAsync<Web.Components.Dialogs.AiTaskCreateDialog>("Create cBot task");
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }

    private async Task OpenDetail(Guid id)
    {
        _detailId = id;
        _detailLogs.Clear();
        _detailResult = null;
        _detailError = null;
        _detailCBotId = null;
        _detailProjectId = null;
        _detailOpen = true;
        await LoadDetailAsync();
    }

    private async Task LoadDetailAsync()
    {
        try
        {
            var d = await Http.GetFromJsonAsync<JsonElement>($"/api/ai/tasks/{_detailId}");
            _detailStatus = d.GetProperty("status").GetString() ?? "";
            _detailActive = IsActive(_detailStatus);
            _detailError = d.TryGetProperty("error", out var e) && e.ValueKind == JsonValueKind.String ? e.GetString() : null;
            _detailResult = d.TryGetProperty("resultText", out var rt) && rt.ValueKind == JsonValueKind.String ? rt.GetString() : null;

            _detailLogs.Clear();
            if (d.TryGetProperty("logs", out var logs) && logs.ValueKind == JsonValueKind.Array)
                foreach (var l in logs.EnumerateArray())
                    _detailLogs.Add(l.GetProperty("message").GetString() ?? "");

            _detailCBotId = null;
            _detailProjectId = null;
            if (d.TryGetProperty("resultRefsJson", out var refs) && refs.ValueKind == JsonValueKind.String
                && refs.GetString() is { Length: > 0 } refsJson)
            {
                using var refDoc = JsonDocument.Parse(refsJson);
                if (refDoc.RootElement.TryGetProperty("cBotId", out var c) && c.ValueKind == JsonValueKind.String)
                    _detailCBotId = c.GetGuid();
                if (refDoc.RootElement.TryGetProperty("projectId", out var p) && p.ValueKind == JsonValueKind.String)
                    _detailProjectId = p.GetGuid();
            }
        }
        catch
        {
            _detailError = "Could not load the task.";
        }
    }

    private async Task Cancel(Guid id)
    {
        var r = await Http.PostAsync($"/api/ai/tasks/{id}/cancel", null);
        if (!r.IsSuccessStatusCode) Snack.Add("Could not cancel the task", Severity.Error);
        await LoadAsync();
    }

    private async Task Delete(Guid id)
    {
        var ok = await Dialogs.ShowMessageBox("Delete task",
            "Delete this task and its result? This cannot be undone.", yesText: "Delete", cancelText: "Cancel");
        if (ok != true) return;
        var r = await Http.DeleteAsync($"/api/ai/tasks/{id}");
        if (!r.IsSuccessStatusCode) { Snack.Add("Could not delete the task", Severity.Error); return; }
        await LoadAsync();
    }

    private static bool IsActive(string status)
        => status is "Queued" or "Running";

    private static Color StatusColor(string status) => status switch
    {
        "Succeeded" => Color.Success,
        "Running" => Color.Info,
        "Queued" => Color.Default,
        "Failed" => Color.Error,
        "Cancelled" => Color.Warning,
        _ => Color.Default
    };

    public void Dispose() => _disposed = true;
}
