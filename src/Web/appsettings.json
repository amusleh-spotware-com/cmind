{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "App": {
    "DefaultDockerImage": "ghcr.io/spotware/ctrader-console",
    "DefaultDockerTag": "latest",
    "Branding": {
      "ProductName": "cMind",
      "CompanyName": "",
      "SupportUrl": "",
      "LogoUrl": "",
      "FaviconUrl": "favicon.svg",
      "PrimaryColor": "#26C281",
      "SecondaryColor": "#1FB97A",
      "AppBarColor": "#141414",
      "BackgroundColor": "#1A1A1A",
      "SurfaceColor": "#262626",
      "SuccessColor": "#26C281",
      "ErrorColor": "#E74C3C",
      "WarningColor": "#F39C12",
      "InfoColor": "#3498DB",
      "CustomCss": ""
    },
    "Features": {
      "Authoring": true,
      "Backtesting": true,
      "Execution": true,
      "CopyTrading": true,
      "Ai": true,
      "PortfolioAgent": true,
      "Alerts": true,
      "PropGuard": true,
      "PropFirm": true,
      "Accounts": true,
      "OpenApi": true,
      "Mcp": true,
      "Compliance": true
    },
    "Discovery": {
      "Enabled": false,
      "JoinToken": "",
      "HeartbeatTtl": "00:01:30",
      "MonitorInterval": "00:00:30",
      "HeartbeatInterval": "00:00:30"
    }
  }
}
