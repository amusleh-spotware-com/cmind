@page "/quant/tca"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@using System.Net.Http.Json
@implements IDisposable
@inject HttpClient Http
@inject IStringLocalizer<Ui> L
@inject MudBlazor.ISnackbar Snack

<PageTitle>Quant · Execution Cost (TCA)</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Transaction Cost Analysis</MudText>
    <HelpTip Text="Execution alpha is small per trade but compounds. TCA measures how far your achieved (VWAP) price drifted from the decision price — slippage in basis points and implementation shortfall — the number banks obsess over." />
</MudStack>

<MudGrid>
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="1">
            <MudNumericField @bind-Value="_arrival" Label="Arrival (decision) price" Min="0"
                             Step="0.0001" Variant="Variant.Outlined" Immediate="true" Format="0.#####"
                             Error="@(!ArrivalValid)" ErrorText="Enter an arrival price greater than 0." />
            <MudSelect @bind-Value="_side" Label="Side" Variant="Variant.Outlined" Class="mt-2">
                <MudSelectItem Value="@("Buy")">Buy</MudSelectItem>
                <MudSelectItem Value="@("Sell")">Sell</MudSelectItem>
            </MudSelect>

            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-3 mb-1">
                <MudText Typo="Typo.subtitle1">Fills</MudText>
                <HelpTip Text="Enter each execution fill as a price and a quantity in the numeric fields — one row per fill, no pasting. Add or remove rows as needed; both price and quantity must be greater than 0." />
            </MudStack>
            @for (var i = 0; i < _fills.Count; i++)
            {
                var index = i;
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                    <MudNumericField T="double?" @bind-Value="_fills[index].Price" Label="Price" Min="0"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Class="flex-grow-1"
                                     data-testid="@($"fill-price-{index}")" aria-label="@($"Fill {index + 1} price")" />
                    <MudNumericField T="double?" @bind-Value="_fills[index].Quantity" Label="Quantity" Min="0"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Class="flex-grow-1"
                                     data-testid="@($"fill-qty-{index}")" aria-label="@($"Fill {index + 1} quantity")" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error"
                                   Disabled="@(_fills.Count <= 1)" aria-label="Remove fill"
                                   OnClick="@(() => RemoveFill(index))" data-testid="@($"fill-remove-{index}")" />
                </MudStack>
            }
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-1">
                <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="AddFill"
                           data-testid="fill-add">Add fill</MudButton>
                <MudText Typo="Typo.caption" data-testid="fill-count"
                         Color="@(ReadyFillCount >= 1 ? Color.Success : Color.Default)">
                    @($"{ReadyFillCount} fill(s)" + (ReadyFillCount < 1 ? " — add at least one" : ""))
                </MudText>
            </MudStack>
            <MudButton Class="mt-3" Color="Color.Primary" Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Receipt" OnClick="Analyze"
                       Disabled="@(_loading || !ArrivalValid || ReadyFillCount < 1)" data-testid="tca-analyze">
                Analyze cost
            </MudButton>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="7">
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_result is { } r)
        {
            <MudPaper Class="pa-4" Elevation="1" data-testid="tca-result">
                <MudText Typo="Typo.h6" Class="mb-2">Slippage: <b>@r.slippageBps.ToString("0.0") bps</b></MudText>
                <MudSimpleTable Dense="true" Hover="true">
                    <tbody>
                        <tr><td>Arrival price</td><td>@r.arrivalPrice.ToString("0.#####")</td></tr>
                        <tr><td>Average fill (VWAP)</td><td>@r.averageFillPrice.ToString("0.#####")</td></tr>
                        <tr><td>Filled quantity</td><td>@r.filledQuantity.ToString("0.####")</td></tr>
                        <tr><td>Implementation shortfall</td><td>@r.implementationShortfall.ToString("0.#####")</td></tr>
                    </tbody>
                </MudSimpleTable>
                <MudText Typo="Typo.body2" Class="mt-3">@r.rationale</MudText>
            </MudPaper>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Enter the arrival price and your fills, then press Analyze cost.
            </MudText>
        }
    </MudItem>
</MudGrid>

@code {
    private double _arrival = 1.1000;
    private string _side = "Buy";
    // Structured numeric input — one price/quantity row per fill, never a free-text blob.
    private readonly List<FillRow> _fills = [new(), new()];
    private bool _loading;
    private TcaResult? _result;
    private readonly CancellationTokenSource _cts = new();

    private bool ArrivalValid => _arrival > 0;
    private int ReadyFillCount => _fills.Count(f => f.Price is > 0 && f.Quantity is > 0);

    private void AddFill() => _fills.Add(new FillRow());
    private void RemoveFill(int index) { if (_fills.Count > 1) _fills.RemoveAt(index); }

    private async Task Analyze()
    {
        var fills = _fills
            .Where(f => f.Price is > 0 && f.Quantity is > 0)
            .Select(f => new { Price = f.Price!.Value, Quantity = f.Quantity!.Value })
            .ToArray();
        if (fills.Length == 0)
        {
            Snack.Add(L["quant.tca.fill_positive"], Severity.Warning);
            return;
        }
        if (!ArrivalValid)
        {
            Snack.Add("Enter an arrival price greater than 0.", Severity.Warning);
            return;
        }

        _loading = true;
        _result = null;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/quant/tca",
                new { ArrivalPrice = _arrival, Side = _side, Fills = fills }, _cts.Token);
            if (_cts.IsCancellationRequested) return;
            if (response.IsSuccessStatusCode)
                _result = await response.Content.ReadFromJsonAsync<TcaResult>(_cts.Token);
            else
                Snack.Add("Could not analyze those fills.", Severity.Error);
        }
        catch (OperationCanceledException) { }
        catch
        {
            Snack.Add("Could not analyze those fills.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private sealed class FillRow
    {
        public double? Price { get; set; }
        public double? Quantity { get; set; }
    }

    private sealed record TcaResult(
        double arrivalPrice, double averageFillPrice, double filledQuantity, string side,
        double slippageBps, double implementationShortfall, string rationale);
}
