@using System.Globalization
@using Core.Constants
@using Microsoft.AspNetCore.Components.Web
@inject Microsoft.Extensions.Options.IOptionsMonitor<Core.Options.AppOptions> Options
@inject IStringLocalizer<Ui> L
@{
    var branding = Options.CurrentValue.Branding;
    var culture = CultureInfo.CurrentUICulture.Name is { Length: > 0 } cultureName ? cultureName : SupportedCultures.Default;
    var direction = SupportedCultures.Direction(culture);
}
<!DOCTYPE html>
<html lang="@culture" dir="@direction">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content="@branding.Description" />
    <title>@branding.ProductName</title>
    <base href="/" />
    <link rel="stylesheet" href="_content/MudBlazor/MudBlazor.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="css/site.css" />
    @((MarkupString)$"<style>{Web.Branding.BrandingCss.BuildRootVariables(branding)}</style>")
    @* Critical reconnect/session-expired overlay styling, inlined so the blocking full-screen overlay is
       GUARANTEED present even if css/site.css is delayed or served stale from the service-worker cache.
       It must never render inline in page flow. The card/text styling in site.css enhances it. *@
    <style>
        #components-reconnect-modal {
            position: fixed;
            inset: 0;
            z-index: 3000;
            display: none;
            align-items: center;
            justify-content: center;
            background: rgba(0, 0, 0, 0.72);
            backdrop-filter: blur(3px);
        }
        /* .NET 10 toggles the full state set on this element; every visible state must overlay, so the
           terminal "session could not be resumed" (resume-failed) / "rejected" states block the app too. */
        #components-reconnect-modal.components-reconnect-show,
        #components-reconnect-modal.components-reconnect-retrying,
        #components-reconnect-modal.components-reconnect-failed,
        #components-reconnect-modal.components-reconnect-paused,
        #components-reconnect-modal.components-reconnect-resume-failed,
        #components-reconnect-modal.components-reconnect-rejected { display: flex; }
    </style>
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="@branding.FaviconUrl" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <meta name="theme-color" content="@branding.AppBarColor" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="@branding.ProductName" />
    @if (!string.IsNullOrWhiteSpace(branding.CustomCss))
    {
        @((MarkupString)$"<style>{branding.CustomCss}</style>")
    }
    <HeadOutlet @rendermode="@RenderMode.InteractiveServer" />
</head>
<body>
    <Routes @rendermode="@RenderMode.InteractiveServer" />

    @* Custom Blazor reconnect UI — Blazor toggles the state classes; markup + styling are ours so it
       matches the app's dark theme instead of the default white box. *@
    <div id="components-reconnect-modal" class="app-reconnect">
        <div class="app-reconnect-card">
            <div class="app-reconnect-spinner" aria-hidden="true"></div>
            <div class="app-reconnect-title">
                <span class="app-reconnect-when-show">@L["app.reconnect.reconnecting"]</span>
                <span class="app-reconnect-when-failed">@L["app.reconnect.connectionLost"]</span>
                <span class="app-reconnect-when-rejected">@L["app.reconnect.sessionExpired"]</span>
            </div>
            <div class="app-reconnect-text">
                <span class="app-reconnect-when-show">@L["app.reconnect.restoring"]</span>
                <span class="app-reconnect-when-failed">@L["app.reconnect.retrying"]</span>
                <span class="app-reconnect-when-rejected">@L["app.reconnect.resume"]</span>
            </div>
            <div class="app-reconnect-actions">
                <button class="app-reconnect-btn app-reconnect-when-failed" onclick="window.Blazor.reconnect()">@L["app.reconnect.retryNow"]</button>
                <button class="app-reconnect-btn app-reconnect-when-rejected" onclick="location.reload()">@L["app.reconnect.reload"]</button>
            </div>
        </div>
    </div>
    <script src="_content/BlazorMonaco/jsInterop.js"></script>
    <script src="_content/BlazorMonaco/lib/monaco-editor/min/vs/loader.js"></script>
    <script src="_content/BlazorMonaco/lib/monaco-editor/min/vs/editor/editor.main.js"></script>
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script>
        window.copyToClipboard = (text) => navigator.clipboard.writeText(text);

        // Resolve design-token CSS custom properties to concrete colours so charts (which paint SVG,
        // not CSS) stay white-label-driven instead of hard-coding hex. Returns [] on any failure.
        window.appReadTokens = (names) => {
            try {
                const style = getComputedStyle(document.documentElement);
                return names.map(n => style.getPropertyValue(n).trim());
            } catch { return []; }
        };

        // PWA: register the app-shell service worker and capture the install prompt.
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () =>
                navigator.serviceWorker.register('/service-worker.js', { updateViaCache: 'none' })
                    .catch(() => { /* installability is best-effort */ }));
        }
        window.deferredInstallPrompt = null;
        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            window.deferredInstallPrompt = e;
        });
        window.appInstall = {
            available: () => !!window.deferredInstallPrompt,
            prompt: async () => {
                const p = window.deferredInstallPrompt;
                if (!p) return 'unavailable';
                p.prompt();
                const choice = await p.userChoice;
                window.deferredInstallPrompt = null;
                return (choice && choice.outcome) ? choice.outcome : 'dismissed';
            }
        };
    </script>
</body>
</html>
