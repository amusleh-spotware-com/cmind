@* Modal dialog to create a copy-trading profile: a source (master) account plus one or more
   destination (slave) accounts, with the full set of copy settings applied to every destination.
   Validates all inputs before returning NewCopyProfileResult on confirm. *@
@using Core.Domain

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">New Copy Profile</MudText>
    </TitleContent>
    <DialogContent>
        @if (_errors.Count > 0)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3" data-testid="copy-profile-errors">
                <ul style="margin:0;padding-left:18px;">
                    @foreach (var e in _errors)
                    {
                        <li>@e</li>
                    }
                </ul>
            </MudAlert>
        }

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_name" Label="Profile name" Required="true"
                              RequiredError="Profile name is required" Immediate="true" data-testid="copy-name" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="long" @bind-Value="_source" Label="Source (master) account" Required="true"
                           RequiredError="Source account is required">
                    @foreach (var a in Accounts)
                    {
                        <MudSelectItem T="long" Value="@a.Number">@a.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudSelect T="long" MultiSelection="true" @bind-SelectedValues="_destinations" Class="flex-grow-1"
                               Label="Destination (slave) accounts"
                               MultiSelectionTextFunc="@(v => $"{v?.Count ?? 0} account(s) selected")"
                               HelperText="Select one or more accounts to copy trades into (the master is excluded)">
                        @foreach (var a in Selectable)
                        {
                            <MudSelectItem T="long" Value="@a.Number">@a.Label</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="SelectAll" data-testid="copy-select-all">
                        Select all
                    </MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="ClearAll">Clear</MudButton>
                </MudStack>
            </MudItem>

            <MudItem xs="12"><MudText Typo="Typo.subtitle2" Class="mt-2">Sizing &amp; risk</MudText></MudItem>
            <MudItem xs="6" md="3">
                <MudSelect T="MoneyManagementMode" @bind-Value="_mode" Label="Money management">
                    @foreach (var m in Enum.GetValues<MoneyManagementMode>())
                    {
                        <MudSelectItem T="MoneyManagementMode" Value="@m">@m</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" md="3"><MudNumericField T="double" @bind-Value="_param" Label="Parameter" /></MudItem>
            <MudItem xs="6" md="3"><MudNumericField T="double" @bind-Value="_slippage" Label="Slippage (pips)" /></MudItem>
            <MudItem xs="6" md="3">
                <MudSelect T="CopyDirectionFilter" @bind-Value="_direction" Label="Direction">
                    @foreach (var d in Enum.GetValues<CopyDirectionFilter>())
                    {
                        <MudSelectItem T="CopyDirectionFilter" Value="@d">@d</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" md="3"><MudNumericField T="double" @bind-Value="_minLot" Label="Min lot" /></MudItem>
            <MudItem xs="6" md="3"><MudNumericField T="double" @bind-Value="_maxLot" Label="Max lot" /></MudItem>
            <MudItem xs="6" md="3"><MudNumericField T="int" @bind-Value="_maxDelay" Label="Max delay (s)" /></MudItem>
            <MudItem xs="6" md="3"><MudNumericField T="double" @bind-Value="_maxDrawdown" Label="Max drawdown %" /></MudItem>
            <MudItem xs="6" md="3"><MudNumericField T="double" @bind-Value="_dailyLoss" Label="Daily loss cap" /></MudItem>

            <MudItem xs="12"><MudText Typo="Typo.subtitle2" Class="mt-2">Copy behaviour</MudText></MudItem>
            <MudItem xs="6" md="3"><MudSwitch T="bool" @bind-Value="_reverse" Label="Reverse" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="3"><MudSwitch T="bool" @bind-Value="_forceMin" Label="Force min lot" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="3"><MudSwitch T="bool" @bind-Value="_copyStopLoss" Label="Copy SL" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="3"><MudSwitch T="bool" @bind-Value="_copyTakeProfit" Label="Copy TP" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="3"><MudSwitch T="bool" @bind-Value="_mirrorPartialClose" Label="Partial close" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="3"><MudSwitch T="bool" @bind-Value="_mirrorScaleIn" Label="Scale-in" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="3"><MudSwitch T="bool" @bind-Value="_copyPending" Label="Pending orders" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="3"><MudSwitch T="bool" @bind-Value="_copyTrailing" Label="Trailing stop" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="3"><MudSwitch T="bool" @bind-Value="_copyPendingExpiry" Label="Copy expiry" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="3"><MudSwitch T="bool" @bind-Value="_copyMasterSlippage" Label="Copy slippage" Color="Color.Primary" /></MudItem>

            <MudItem xs="12"><MudText Typo="Typo.subtitle2" Class="mt-2">Order types</MudText></MudItem>
            <MudItem xs="6" md="2"><MudSwitch T="bool" @bind-Value="_copyMarket" Label="Market" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="2"><MudSwitch T="bool" @bind-Value="_copyMarketRange" Label="Market range" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="2"><MudSwitch T="bool" @bind-Value="_copyLimit" Label="Limit" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="2"><MudSwitch T="bool" @bind-Value="_copyStop" Label="Stop" Color="Color.Primary" /></MudItem>
            <MudItem xs="6" md="2"><MudSwitch T="bool" @bind-Value="_copyStopLimit" Label="Stop limit" Color="Color.Primary" /></MudItem>

            <MudItem xs="12"><MudText Typo="Typo.subtitle2" Class="mt-2">Symbols</MudText></MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="SymbolFilterMode" @bind-Value="_filterMode" Label="Symbol filter">
                    @foreach (var f in Enum.GetValues<SymbolFilterMode>())
                    {
                        <MudSelectItem T="SymbolFilterMode" Value="@f">@f</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_filterText" Label="Filter symbols (comma separated)" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_symbolMapText" Label="Symbol map (SRC=DST, comma separated)" /></MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" data-testid="copy-create">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance Dialog { get; set; } = default!;

    [Parameter] public IReadOnlyList<CopyAccountOption> Accounts { get; set; } = [];

    private string _name = "";
    private long _source;
    private IEnumerable<long> _destinations = new HashSet<long>();

    private MoneyManagementMode _mode = MoneyManagementMode.LotMultiplier;
    private double _param = 1;
    private double _slippage;
    private CopyDirectionFilter _direction = CopyDirectionFilter.Both;
    private double _minLot;
    private double _maxLot;
    private int _maxDelay;
    private double _maxDrawdown;
    private double _dailyLoss;
    private bool _reverse;
    private bool _forceMin;
    private bool _copyStopLoss = true;
    private bool _copyTakeProfit = true;
    private bool _mirrorPartialClose = true;
    private bool _mirrorScaleIn;
    private bool _copyPending;
    private bool _copyTrailing;
    private bool _copyPendingExpiry = true;
    private bool _copyMasterSlippage = true;
    private bool _copyMarket = true;
    private bool _copyMarketRange = true;
    private bool _copyLimit = true;
    private bool _copyStop = true;
    private bool _copyStopLimit = true;
    private SymbolFilterMode _filterMode = SymbolFilterMode.None;
    private string _filterText = "";
    private string _symbolMapText = "";

    private readonly List<string> _errors = new();

    private IEnumerable<CopyAccountOption> Selectable => Accounts.Where(a => a.Number != _source);

    private void SelectAll() => _destinations = Selectable.Select(a => a.Number).ToHashSet();
    private void ClearAll() => _destinations = new HashSet<long>();

    private void Submit()
    {
        var destinations = _destinations.Where(d => d != _source).ToArray();
        if (!Validate(destinations)) return;

        Dialog.Close(DialogResult.Ok(new NewCopyProfileResult(
            _name.Trim(), _source, destinations,
            new CopyDestinationSettings(
                _mode, _param, _slippage, _direction, _minLot, _maxLot, _maxDelay, _maxDrawdown, _dailyLoss,
                _reverse, _forceMin, _copyStopLoss, _copyTakeProfit, _mirrorPartialClose, _mirrorScaleIn,
                _copyPending, _copyTrailing, _copyPendingExpiry, _copyMasterSlippage,
                SelectedOrderTypes(), _filterMode, _filterText, _symbolMapText))));
    }

    private bool Validate(long[] destinations)
    {
        _errors.Clear();
        if (string.IsNullOrWhiteSpace(_name)) _errors.Add("Profile name is required.");
        if (_source == 0) _errors.Add("Select a source (master) account.");
        if (destinations.Length == 0) _errors.Add("Select at least one destination (slave) account.");
        if (_param <= 0) _errors.Add("Parameter must be greater than zero.");
        if (_slippage < 0) _errors.Add("Slippage cannot be negative.");
        if (_minLot < 0) _errors.Add("Min lot cannot be negative.");
        if (_maxLot < 0) _errors.Add("Max lot cannot be negative.");
        if (_maxLot > 0 && _maxLot < _minLot) _errors.Add("Max lot must be greater than or equal to min lot.");
        if (_maxDelay < 0) _errors.Add("Max delay cannot be negative.");
        if (_maxDrawdown is < 0 or > 100) _errors.Add("Max drawdown % must be between 0 and 100.");
        if (_dailyLoss < 0) _errors.Add("Daily loss cap cannot be negative.");
        if (SelectedOrderTypes() == CopyOrderTypes.None) _errors.Add("Enable at least one order type.");
        if (_filterMode != SymbolFilterMode.None && string.IsNullOrWhiteSpace(_filterText))
            _errors.Add("Provide symbols for the selected symbol filter.");
        if (!AreSymbolMapPairsValid()) _errors.Add("Symbol map must be pairs of the form SRC=DST.");
        return _errors.Count == 0;
    }

    private bool AreSymbolMapPairsValid()
    {
        if (string.IsNullOrWhiteSpace(_symbolMapText)) return true;
        return _symbolMapText
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .All(pair => pair.Split('=', StringSplitOptions.TrimEntries) is { Length: 2 } parts
                         && parts.All(p => !string.IsNullOrWhiteSpace(p)));
    }

    private CopyOrderTypes SelectedOrderTypes()
    {
        var types = CopyOrderTypes.None;
        if (_copyMarket) types |= CopyOrderTypes.Market;
        if (_copyMarketRange) types |= CopyOrderTypes.MarketRange;
        if (_copyLimit) types |= CopyOrderTypes.Limit;
        if (_copyStop) types |= CopyOrderTypes.Stop;
        if (_copyStopLimit) types |= CopyOrderTypes.StopLimit;
        return types;
    }

    private void Cancel() => Dialog.Cancel();

    public sealed record CopyAccountOption(long Number, string Label);

    public sealed record CopyDestinationSettings(
        MoneyManagementMode Mode, double Parameter, double SlippagePips, CopyDirectionFilter Direction,
        double MinLot, double MaxLot, int MaxDelaySeconds, double MaxDrawdownPercent, double DailyLossLimit,
        bool Reverse, bool ForceMinLot, bool CopyStopLoss, bool CopyTakeProfit, bool MirrorPartialClose,
        bool MirrorScaleIn, bool CopyPendingOrders, bool CopyTrailingStop, bool CopyPendingExpiry,
        bool CopyMasterSlippage, CopyOrderTypes OrderTypes, SymbolFilterMode SymbolFilterMode,
        string FilterText, string SymbolMapText);

    public sealed record NewCopyProfileResult(
        string Name, long SourceAccountNumber, long[] DestinationAccountNumbers, CopyDestinationSettings Settings);
}
