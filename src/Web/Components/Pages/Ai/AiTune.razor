@page "/ai/tune"
@using System.Text.Json
@using Web.Components.Dialogs
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject IDialogService Dialogs

<PageTitle>AI · Tune Advisor</PageTitle>

<AiRunListView Feature="AiFeature.AssessStrategyDecay"
               Heading="Tune Advisor"
               HelpText="Pick a cBot and the AI compares its two most recent backtests, tells you if its edge is decaying, and suggests one adjustment to test. Tunes run in the background and are saved — open one anytime."
               NewLabel="New tune"
               RoutePrefix="/ai/tune"
               EmptyHint="Start a tune to see it here."
               StartInputProvider="StartAsync" />

@code {
    private async Task<AiRunListView.AiRunInput?> StartAsync()
    {
        CBotDto[] cbots;
        try { cbots = await Http.GetFromJsonAsync<CBotDto[]>("/api/cbots/") ?? []; }
        catch { cbots = []; }
        var options = cbots.Select(c => new AiTuneStartDialog.CBotOption(c.Id, c.Name)).ToList();

        var parameters = new DialogParameters<AiTuneStartDialog>
        {
            { x => x.Projects, (IReadOnlyList<AiTuneStartDialog.CBotOption>)options }
        };
        var opts = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await Dialogs.ShowAsync<AiTuneStartDialog>("New tune", parameters, opts);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not AiTuneStartDialog.Result r) return null;

        var source = JsonSerializer.Serialize(new { cbotId = r.CBotId, cbotName = r.CBotName });
        return new AiRunListView.AiRunInput(r.CBotName, source, r.ModelId);
    }

    private sealed record CBotDto(Guid Id, string Name);
}
