@page "/prop-firm"
@using System.Net.Http.Json
@using Web.Components.Dialogs
@using Web.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs

<PageTitle>Prop Firm</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Prop-Firm Challenges</MudText>
    <HelpTip Text="Track a prop-firm evaluation against its rules (max drawdown, daily loss, profit target, min trading days). Record equity manually, or enable live tracking to pull it from the account over the Open API." />
    <MudSpacer />
    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenNew">New Challenge</MudButton>
</MudStack>

@if (_challenges.Length == 0)
{
    <MudText Class="mud-text-secondary">No challenges yet.</MudText>
}
else
{
    <MudTable Items="_challenges" Dense="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Name</MudTh><MudTh>Kind</MudTh><MudTh>Phase</MudTh><MudTh>Status</MudTh><MudTh>Equity</MudTh>
            <MudTh>Peak</MudTh><MudTh>Days</MudTh><MudTh>Record equity</MudTh><MudTh /></HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.name</MudTd>
            <MudTd DataLabel="Kind">@context.kind</MudTd>
            <MudTd DataLabel="Phase">@context.phase</MudTd>
            <MudTd DataLabel="Status"><MudChip T="string" Size="Size.Small" Color="StatusColor((string)context.status)">@context.status</MudChip></MudTd>
            <MudTd DataLabel="Equity">@context.currentEquity</MudTd>
            <MudTd DataLabel="Peak">@context.peakEquity</MudTd>
            <MudTd DataLabel="Days">@context.tradingDaysCount</MudTd>
            <MudTd DataLabel="Record equity">
                <MudNumericField T="decimal" @bind-Value="_equityInput" Label="Equity" Margin="Margin.Dense" Style="max-width:140px" />
                <MudButton Size="Size.Small" Color="Color.Primary" OnClick="@(() => RecordEquity((Guid)context.id))">Record</MudButton>
            </MudTd>
            <MudTd DataLabel="">
                @if ((string)context.status == "Stopped")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                   aria-label="Start challenge" OnClick="@(() => Start((Guid)context.id))" />
                }
                else if ((string)context.status == "Active")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Warning"
                                   aria-label="Stop challenge" OnClick="@(() => Stop((Guid)context.id))" />
                }
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               Disabled="@((string)context.status == "Active")"
                               aria-label="Delete challenge" OnClick="@(() => Remove((Guid)context.id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private dynamic[] _challenges = [];
    private dynamic[] _accounts = [];
    private decimal _equityInput;

    protected override async Task OnInitializedAsync()
    {
        _accounts = await Http.GetDynamicArrayAsync("/api/accounts");
        await Load();
    }

    private async Task Load() => _challenges = await Http.GetDynamicArrayAsync("/api/prop-firm/challenges");

    private static Color StatusColor(string status) => status switch
    {
        "Passed" => Color.Success,
        "Failed" => Color.Error,
        "Active" => Color.Info,
        "Stopped" => Color.Warning,
        _ => Color.Default
    };

    private async Task OpenNew()
    {
        var options = ((IEnumerable<dynamic>)_accounts)
            .Select(a => new NewPropFirmChallengeDialog.PropFirmAccountOption((Guid)a.id, $"{a.accountNumber} ({a.broker})"))
            .ToList();
        var parameters = new DialogParameters
        {
            { nameof(NewPropFirmChallengeDialog.Accounts), (IReadOnlyList<NewPropFirmChallengeDialog.PropFirmAccountOption>)options }
        };
        var dlg = await Dialogs.ShowAsync<NewPropFirmChallengeDialog>(null, parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (NewPropFirmChallengeDialog.NewPropFirmChallengeResult)res.Data!;

        var r = await Http.PostAsJsonAsync("/api/prop-firm/challenges", new
        {
            data.Name,
            data.TradingAccountId,
            data.StartingBalance,
            data.ProfitTargetPercent,
            data.MaxDailyLossPercent,
            data.MaxTotalDrawdownPercent,
            data.DrawdownMode,
            data.MinTradingDays,
            data.SingleStep,
            data.Kind,
            data.DailyLossBasis,
            data.TrailingThresholdAmount,
            data.TrailingLockThreshold,
            data.ConsistencyMaxDayProfitSharePercent,
            data.MaxCalendarDays,
            data.MaxOpenPositions,
            data.AllowWeekendHolding,
            data.AllowNewsTrading
        });
        Snack.Add(r.IsSuccessStatusCode ? "Challenge created" : "Failed to create challenge",
            r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        await Load();
    }

    private async Task RecordEquity(Guid id)
    {
        var r = await Http.PostAsJsonAsync($"/api/prop-firm/challenges/{id}/equity", new { Equity = _equityInput });
        if (!r.IsSuccessStatusCode) Snack.Add("Could not record equity", Severity.Error);
        await Load();
    }

    private async Task Start(Guid id)
    {
        var r = await Http.PostAsync($"/api/prop-firm/challenges/{id}/start", null);
        if (!r.IsSuccessStatusCode) Snack.Add("Could not start challenge", Severity.Error);
        await Load();
    }

    private async Task Stop(Guid id)
    {
        var r = await Http.PostAsync($"/api/prop-firm/challenges/{id}/stop", null);
        if (!r.IsSuccessStatusCode) Snack.Add("Could not stop challenge", Severity.Error);
        await Load();
    }

    private async Task Remove(Guid id)
    {
        await Http.DeleteAsync($"/api/prop-firm/challenges/{id}");
        await Load();
    }
}
