@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Class="mr-2" />
            AI provider
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:min(90vw,420px);">
            <MudSelect T="int" @bind-Value="_kind" Label="Provider kind" Disabled="_isEdit"
                       @bind-Value:after="OnKindChanged" data-testid="ai-dlg-kind">
                <MudSelectItem T="int" Value="0">Anthropic</MudSelectItem>
                <MudSelectItem T="int" Value="1">OpenAI-compatible (OpenAI / local / OpenRouter / Groq / …)</MudSelectItem>
                <MudSelectItem T="int" Value="2">Azure OpenAI</MudSelectItem>
                <MudSelectItem T="int" Value="3">Google Gemini</MudSelectItem>
                <MudSelectItem T="int" Value="4">Demo AI (built-in — no key, no endpoint)</MudSelectItem>
                <MudSelectItem T="int" Value="5">Built-in local AI (ONNX — no key)</MudSelectItem>
            </MudSelect>

            @if (_kind == 1)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    Local models: Ollama → <code>http://localhost:11434/v1/</code>, LM Studio →
                    <code>http://localhost:1234/v1/</code>. No API key needed for local endpoints.
                </MudAlert>
            }

            <MudTextField @bind-Value="_baseUrl" Label="Base URL" Immediate="true"
                          Placeholder="https://…" data-testid="ai-dlg-baseurl" />
            <MudTextField @bind-Value="_model" Label="Model" Immediate="true"
                          Placeholder="@ModelHint()" data-testid="ai-dlg-model" />
            <MudTextField @bind-Value="_apiKey" Label="@KeyLabel()" InputType="InputType.Password"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Key"
                          HelperText="@(_isEdit ? "Leave blank to keep the stored key." : null)"
                          data-testid="ai-dlg-key" />
            <MudNumericField T="int" @bind-Value="_maxTokens" Label="Max tokens" Min="1" Max="200000"
                             data-testid="ai-dlg-maxtokens" />

            <MudText Typo="Typo.subtitle2">Capabilities</MudText>
            <MudSwitch T="bool" @bind-Value="_webSearch" Color="Color.Primary" data-testid="ai-dlg-websearch">Web search</MudSwitch>
            <MudSwitch T="bool" @bind-Value="_vision" Color="Color.Primary" data-testid="ai-dlg-vision">Vision (image input)</MudSwitch>
            <MudSwitch T="bool" @bind-Value="_systemRole" Color="Color.Primary" data-testid="ai-dlg-systemrole">System role</MudSwitch>
            <MudSwitch T="bool" @bind-Value="_activate" Color="Color.Success" data-testid="ai-dlg-activate">Set as active provider</MudSwitch>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" data-testid="ai-dlg-cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save"
                   Disabled="@(string.IsNullOrWhiteSpace(_baseUrl) || string.IsNullOrWhiteSpace(_model))"
                   data-testid="ai-dlg-save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;

    // The provider being edited (id + current values), or null when adding.
    [Parameter] public object? Existing { get; set; }

    private int _kind;
    private string _baseUrl = "https://api.anthropic.com/";
    private string _model = "claude-opus-4-8";
    private string _apiKey = "";
    private int _maxTokens = 8000;
    private bool _webSearch = true;
    private bool _vision = true;
    private bool _systemRole = true;
    private bool _tools = true;
    private bool _activate = true;
    private bool _isEdit;

    protected override void OnInitialized()
    {
        if (Existing is null) { ApplyKindDefaults(); return; }

        // Reflect over the anonymous ProviderView record the page passes in.
        var t = Existing.GetType();
        _isEdit = true;
        _kind = (int)(t.GetProperty("Kind")?.GetValue(Existing) ?? 0);
        _baseUrl = (string)(t.GetProperty("BaseUrl")?.GetValue(Existing) ?? "");
        _model = (string)(t.GetProperty("Model")?.GetValue(Existing) ?? "");
        _maxTokens = (int)(t.GetProperty("MaxTokens")?.GetValue(Existing) ?? 8000);
        _activate = (bool)(t.GetProperty("IsActive")?.GetValue(Existing) ?? true);
        var caps = t.GetProperty("Capabilities")?.GetValue(Existing);
        if (caps is not null)
        {
            var ct = caps.GetType();
            _webSearch = (bool)(ct.GetProperty("SupportsWebSearch")?.GetValue(caps) ?? false);
            _vision = (bool)(ct.GetProperty("SupportsVision")?.GetValue(caps) ?? false);
            _systemRole = (bool)(ct.GetProperty("SupportsSystemRole")?.GetValue(caps) ?? true);
            _tools = (bool)(ct.GetProperty("SupportsTools")?.GetValue(caps) ?? false);
        }
    }

    private void OnKindChanged() => ApplyKindDefaults();

    private void ApplyKindDefaults()
    {
        switch (_kind)
        {
            case 0:
                _baseUrl = "https://api.anthropic.com/"; _model = "claude-opus-4-8";
                _webSearch = true; _vision = true; _systemRole = true; _tools = true; break;
            case 1:
                _baseUrl = "https://api.openai.com/v1/"; _model = "gpt-4o";
                _webSearch = false; _vision = false; _systemRole = true; _tools = false; break;
            case 2:
                _baseUrl = "https://YOUR-RESOURCE.openai.azure.com/"; _model = "gpt-4o";
                _webSearch = false; _vision = true; _systemRole = true; _tools = false; break;
            case 3:
                _baseUrl = "https://generativelanguage.googleapis.com/"; _model = "gemini-2.0-flash";
                _webSearch = true; _vision = true; _systemRole = true; _tools = true; break;
            case 4:
                _baseUrl = "https://demo.local/"; _model = "cmind-demo";
                _webSearch = true; _vision = true; _systemRole = true; _tools = true; break;
            case 5:
                _baseUrl = "https://builtin.local/"; _model = "built-in-onnx";
                _webSearch = false; _vision = false; _systemRole = true; _tools = false; break;
        }
    }

    private string ModelHint() => _kind switch
    {
        0 => "claude-opus-4-8",
        1 => "gpt-4o / llama3.1:8b / qwen2.5-coder",
        2 => "your-deployment-name",
        3 => "gemini-2.0-flash",
        4 => "cmind-demo",
        5 => "built-in-onnx",
        _ => ""
    };

    private string KeyLabel() => _kind is 1 or 4 or 5 ? "API key (optional for local)" : "API key";

    private void Cancel() => MudDialog.Cancel();

    private void Save() => MudDialog.Close(DialogResult.Ok(new Result(
        _kind, _baseUrl.Trim(), _model.Trim(), _apiKey, _maxTokens,
        _webSearch, _vision, _systemRole, _tools, _activate)));

    public sealed record Result(
        int Kind, string BaseUrl, string Model, string? ApiKey, int MaxTokens,
        bool SupportsWebSearch, bool SupportsVision, bool SupportsSystemRole, bool SupportsTools, bool Activate);
}
