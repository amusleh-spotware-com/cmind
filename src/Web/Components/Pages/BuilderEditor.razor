@page "/builder/{Id:guid}"
@using Web.Json
@using System.Net.Http.Json
@using BlazorMonaco.Editor
@using Microsoft.AspNetCore.SignalR.Client
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>@(_projectName ?? "cBot Editor")</PageTitle>

@* Editor layout:
   - SignalR client uses Microsoft.AspNetCore.SignalR.Client (NuGet) connected from the server-side
     Blazor circuit. Cookie auth is forwarded because LogsHub allows the cookie scheme by default.
*@

<div class="builder-editor">
    <MudPaper Class="builder-toolbar pa-2" Square="true" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="width:100%">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/builder"
                           title="Back to projects" />
            <MudText Typo="Typo.subtitle1">@(_projectName ?? "Loading...")</MudText>
            @if (_projectLanguage is not null)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_projectLanguage</MudChip>
            }
            @if (_lastBuildOk is true)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Success">Build OK</MudChip>
            }
            else if (_lastBuildOk is false)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Error">Build failed</MudChip>
            }
            @if (_dirty)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Unsaved</MudChip>
            }
            <MudSpacer />
            <MudButton StartIcon="@Icons.Material.Filled.Save" OnClick="SaveAsync"
                       Variant="Variant.Outlined" Disabled="_busy">Save</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Build" OnClick="BuildAsync"
                       Color="Color.Primary" Variant="Variant.Filled" Disabled="_busy">Build</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="RunAsync"
                       Color="Color.Secondary" Variant="Variant.Filled" Disabled="_busy">Run</MudButton>
            @if (_streamingLogs)
            {
                <MudButton StartIcon="@Icons.Material.Filled.Stop" OnClick="StopStreamAsync"
                           Color="Color.Error" Variant="Variant.Outlined">Stop</MudButton>
            }
        </MudStack>
    </MudPaper>

    <div class="builder-sidebar">
        <MudPaper Class="pa-2" Square="true" Style="height:100%;overflow:auto;">
            <MudText Typo="Typo.overline" Style="color:#A0A0A0;">Files</MudText>
            <MudList T="string" Dense="true" SelectedValue="@_currentFile"
                     SelectedValueChanged="@(v => SelectFileAsync(v))">
                @foreach (var f in _files.Keys.OrderBy(k => k, StringComparer.Ordinal))
                {
                    <MudListItem T="string" Value="@f" Icon="@FileIcon(f)">
                        <MudText Typo="Typo.body2">
                            @f@(_dirtyFiles.Contains(f) ? " *" : "")
                        </MudText>
                    </MudListItem>
                }
            </MudList>
        </MudPaper>
    </div>

    <div class="builder-editor-center">
        @if (_currentFile is not null)
        {
            @* Re-mount the editor when switching files so Monaco picks the right language. *@
            <StandaloneCodeEditor @ref="_editor" @key="_currentFile" Id="@($"builder-monaco-{Id:N}")"
                                  CssClass="builder-monaco"
                                  ConstructionOptions="EditorOptions"
                                  OnDidChangeModelContent="OnEditorChanged" />
        }
        else
        {
            <div style="display:flex;align-items:center;justify-content:center;height:100%;color:#A0A0A0;">
                Select a file from the left panel
            </div>
        }
    </div>

    <div class="builder-bottom">
        <MudTabs @bind-ActivePanelIndex="_bottomTab" Elevation="0" Rounded="false" Border="false"
                 Class="builder-tabs" PanelClass="builder-tab-panel">
            <MudTabPanel Text="Build Result">
                <pre class="builder-log">@_buildLog</pre>
            </MudTabPanel>
            <MudTabPanel Text="Run Logs">
                <pre class="builder-log">@_runLog</pre>
            </MudTabPanel>
        </MudTabs>
    </div>
</div>

<style>
    .builder-editor {
        display: grid;
        grid-template-columns: 240px 1fr;
        grid-template-rows: auto 1fr 35vh;
        grid-template-areas:
            "toolbar toolbar"
            "sidebar editor"
            "bottom bottom";
        height: calc(100vh - 80px);
        gap: 0;
    }
    .builder-toolbar { grid-area: toolbar; }
    .builder-sidebar { grid-area: sidebar; border-right: 1px solid #2A2E36; min-height: 0; }
    .builder-editor-center {
        grid-area: editor; min-height: 0; min-width: 0;
        position: relative; overflow: hidden;
        background: #1E1E1E;
        padding: 12px;
    }
    .builder-monaco { position: absolute; inset: 12px; height: calc(100% - 24px); width: calc(100% - 24px); }
    .builder-monaco > .monaco-editor { height: 100% !important; width: 100% !important; }
    .builder-bottom { grid-area: bottom; border-top: 1px solid #2A2E36; overflow: hidden; }
    .builder-tabs { height: 100%; display: flex; flex-direction: column; }
    .builder-tab-panel { background: #0E1218; }
    .builder-log {
        background: #0E1218;
        color: #E6E8EC;
        font-family: 'Consolas', 'Courier New', monospace;
        font-size: 12px;
        margin: 0;
        padding: 8px;
        max-height: 30vh;
        height: 30vh;
        overflow: auto;
        white-space: pre-wrap;
        word-break: break-all;
    }
</style>

@code {
    [Parameter] public Guid Id { get; set; }

    private StandaloneCodeEditor? _editor;
    private Dictionary<string, string> _files = new(StringComparer.Ordinal);
    private readonly HashSet<string> _dirtyFiles = new(StringComparer.Ordinal);
    private string? _currentFile;
    private string? _projectName;
    private string? _projectLanguage;
    private bool? _lastBuildOk;
    private bool _dirty;
    private bool _busy;
    private bool _streamingLogs;
    private int _bottomTab;
    private string _buildLog = "";
    private string _runLog = "";

    private HubConnection? _hub;
    private CancellationTokenSource? _streamCts;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectAsync();
    }

    private async Task LoadProjectAsync()
    {
        var meta = await Http.GetDynamicAsync($"/api/builder/projects/{Id}");
        if (meta is null) { Snack.Add("Project not found", Severity.Error); Nav.NavigateTo("/builder"); return; }
        _projectName = (string)meta.name;
        _projectLanguage = (string)meta.language;
        _lastBuildOk = meta.lastBuildAt is null ? (bool?)null : (bool)meta.lastBuildSucceeded;
        _buildLog = (string?)meta.lastBuildLog ?? "";

        var filesResp = await Http.GetFromJsonAsync<FilesResponse>($"/api/builder/projects/{Id}/files");
        _files = filesResp?.Files is null
            ? new Dictionary<string, string>(StringComparer.Ordinal)
            : new Dictionary<string, string>(filesResp.Files, StringComparer.Ordinal);

        var main = _files.Keys.FirstOrDefault(k =>
                       k.EndsWith(".cs", StringComparison.Ordinal) ||
                       k.EndsWith(".py", StringComparison.Ordinal))
                   ?? _files.Keys.FirstOrDefault();
        if (main is not null) await SelectFileAsync(main);
    }

    private StandaloneEditorConstructionOptions EditorOptions(StandaloneCodeEditor _) => new()
    {
        AutomaticLayout = true,
        Language = LanguageFor(_currentFile),
        Theme = "vs-dark",
        Value = _currentFile is not null && _files.TryGetValue(_currentFile, out var v) ? v : "",
        FontSize = 14
    };

    private static string LanguageFor(string? path) => path switch
    {
        null => "plaintext",
        _ when path.EndsWith(".cs", StringComparison.Ordinal) => "csharp",
        _ when path.EndsWith(".py", StringComparison.Ordinal) => "python",
        _ when path.EndsWith(".csproj", StringComparison.Ordinal) => "xml",
        _ when path.EndsWith(".xml", StringComparison.Ordinal) => "xml",
        _ when path.EndsWith(".json", StringComparison.Ordinal) => "json",
        _ when path.EndsWith(".toml", StringComparison.Ordinal) => "ini",
        _ => "plaintext"
    };

    private static string FileIcon(string path) => path switch
    {
        _ when path.EndsWith(".cs", StringComparison.Ordinal) => Icons.Material.Filled.Code,
        _ when path.EndsWith(".py", StringComparison.Ordinal) => Icons.Material.Filled.Code,
        _ when path.EndsWith(".csproj", StringComparison.Ordinal) => Icons.Material.Filled.Settings,
        _ => Icons.Material.Filled.InsertDriveFile
    };

    private async Task SelectFileAsync(string? path)
    {
        if (path is null || !_files.ContainsKey(path)) return;
        // Capture current edits before switching
        if (_currentFile is not null && _editor is not null)
        {
            var current = await _editor.GetValue();
            if (!string.Equals(_files[_currentFile], current, StringComparison.Ordinal))
            {
                _files[_currentFile] = current;
                _dirtyFiles.Add(_currentFile);
                _dirty = true;
            }
        }
        _currentFile = path;
        // Editor is keyed on _currentFile and re-created with the correct language via EditorOptions.
        StateHasChanged();
    }

    private void OnEditorChanged(ModelContentChangedEvent _)
    {
        if (_currentFile is null) return;
        _dirtyFiles.Add(_currentFile);
        _dirty = true;
    }

    private async Task<bool> SyncEditorToStateAsync()
    {
        if (_currentFile is null || _editor is null) return true;
        var current = await _editor.GetValue();
        _files[_currentFile] = current;
        return true;
    }

    private async Task SaveAsync()
    {
        await SyncEditorToStateAsync();
        _busy = true;
        try
        {
            var resp = await Http.PutAsJsonAsync($"/api/builder/projects/{Id}/files", new { Files = _files });
            if (!resp.IsSuccessStatusCode) { Snack.Add("Save failed", Severity.Error); return; }
            _dirtyFiles.Clear();
            _dirty = false;
            Snack.Add("Saved", Severity.Success);
        }
        finally { _busy = false; }
    }

    private async Task EnsureSavedAsync()
    {
        await SyncEditorToStateAsync();
        if (_dirty || _dirtyFiles.Count > 0)
        {
            var resp = await Http.PutAsJsonAsync($"/api/builder/projects/{Id}/files", new { Files = _files });
            if (resp.IsSuccessStatusCode) { _dirtyFiles.Clear(); _dirty = false; }
        }
    }

    private async Task BuildAsync()
    {
        _busy = true;
        _bottomTab = 0;
        _buildLog = "Building...\n";
        try
        {
            await EnsureSavedAsync();
            var resp = await Http.PostAsJsonAsync($"/api/builder/projects/{Id}/build", new { });
            if (!resp.IsSuccessStatusCode) { _buildLog += $"HTTP {(int)resp.StatusCode}\n"; Snack.Add("Build request failed", Severity.Error); return; }
            var d = await resp.Content.ReadFromJsonAsync<BuildResponse>();
            if (d is null) { Snack.Add("Empty build response", Severity.Error); return; }
            _buildLog = d.Log ?? "";
            _lastBuildOk = d.Success;
            Snack.Add(d.Success ? "Build OK" : "Build failed", d.Success ? Severity.Success : Severity.Error);
        }
        finally { _busy = false; }
    }

    private async Task RunAsync()
    {
        _busy = true;
        _bottomTab = 1;
        _runLog = "Building and starting...\n";
        try
        {
            await EnsureSavedAsync();
            var resp = await Http.PostAsync($"/api/builder/projects/{Id}/quick-run", null);
            if (!resp.IsSuccessStatusCode) { _runLog += $"HTTP {(int)resp.StatusCode}\n"; Snack.Add("Quick run failed", Severity.Error); return; }
            var d = await resp.Content.ReadFromJsonAsync<QuickRunResponse>();
            if (d is null) { Snack.Add("Empty run response", Severity.Error); return; }
            _runLog = (d.Output ?? "") + "\n";
            if (!d.Success || d.InstanceId is null)
            {
                _lastBuildOk = false;
                Snack.Add("Build failed; cannot run", Severity.Error);
                return;
            }
            _lastBuildOk = true;
            await StartLogStreamAsync(d.InstanceId.Value);
        }
        finally { _busy = false; }
    }

    private async Task StartLogStreamAsync(Guid instanceId)
    {
        await StopStreamAsync();
        _streamCts = new CancellationTokenSource();
        try
        {
            _hub = new HubConnectionBuilder().WithUrl(Nav.ToAbsoluteUri("/hubs/logs")).Build();
            await _hub.StartAsync(_streamCts.Token);
        }
        catch (Exception ex)
        {
            _runLog += $"\n[stream connect failed: {ex.Message}]\n";
            return;
        }

        _streamingLogs = true;
        var stream = _hub.StreamAsync<string>("Tail", instanceId, _streamCts.Token);
        _ = Task.Run(async () =>
        {
            try
            {
                await foreach (var line in stream.WithCancellation(_streamCts.Token))
                {
                    _runLog += line + "\n";
                    if (_runLog.Length > 200_000) _runLog = _runLog[^150_000..];
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) { }
            catch (Exception ex)
            {
                _runLog += $"\n[stream error: {ex.Message}]\n";
                await InvokeAsync(StateHasChanged);
            }
            finally
            {
                _streamingLogs = false;
                await InvokeAsync(StateHasChanged);
            }
        });
    }

    private async Task StopStreamAsync()
    {
        try
        {
            _streamCts?.Cancel();
            if (_hub is not null) { await _hub.DisposeAsync(); _hub = null; }
        }
        catch { /* swallow */ }
        finally
        {
            _streamCts?.Dispose();
            _streamCts = null;
            _streamingLogs = false;
        }
    }

    public async ValueTask DisposeAsync() => await StopStreamAsync();

    private sealed record FilesResponse(Dictionary<string, string> Files);
    private sealed record BuildResponse(bool Success, string? Log);
    private sealed record QuickRunResponse(bool Success, string? Output, Guid? InstanceId);
}
