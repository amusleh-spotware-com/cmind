@page "/ai/review"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]

<PageTitle>AI · Review cBot</PageTitle>

<AiRunListView Feature="AiFeature.ReviewCBot"
               Heading="Review cBot"
               HelpText="Paste a cBot's source and the AI reviews it for bugs, risky trading logic, and missing safeguards. Reviews run in the background and are saved — open one anytime."
               NewLabel="New review"
               RoutePrefix="/ai/review"
               DialogTitle="New review"
               ConfirmLabel="Review"
               SourcePlaceholder="Paste cBot source to review for bugs and trading risks"
               EmptyHint="Start a review to see it here." />
