@page "/prop-guard"
@using System.Net.Http.Json
@using Web.Components.Dialogs
@using Web.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs

<PageTitle>Prop Guard</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
    <MudText Typo="Typo.h5">Prop-Firm Guard</MudText>
    <HelpTip Text="Set exposure limits per trading account. With auto-flatten on, the guard stops every live bot on an account the moment its concurrent live count exceeds the cap. Daily-loss and max-drawdown limits are recorded for account-level equity enforcement." />
    <MudSpacer />
    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenNew" Disabled="_busy">New rule</MudButton>
</MudStack>
<MudText Typo="Typo.body2" Class="mb-1">
    Set exposure limits per trading account. With auto-flatten on, the guard stops every live bot on an
    account the moment its concurrent live count exceeds the cap.
</MudText>
<MudText Typo="Typo.caption" Class="mb-4">
    Daily-loss and max-drawdown limits are recorded for account-level equity enforcement (pending a live
    equity feed); the active guardrail today is the concurrent live-instance cap and one-click flatten.
</MudText>

<MudPaper Class="pa-4" Elevation="1">
    <MudText Typo="Typo.h6" Class="mb-2">Rules</MudText>
    @if (_rules.Length == 0)
    {
        <MudText Typo="Typo.body2">No rules yet.</MudText>
    }
    else
    {
        <MudTable Items="_rules" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Name</MudTh><MudTh>Account</MudTh><MudTh>Max live</MudTh><MudTh>Auto-flatten</MudTh><MudTh>On</MudTh><MudTh /></HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.name</MudTd>
                <MudTd DataLabel="Account">@context.accountNumber</MudTd>
                <MudTd DataLabel="Max live">@context.maxConcurrentLiveInstances</MudTd>
                <MudTd DataLabel="Auto-flatten">@(((bool)context.autoFlatten) ? "Yes" : "No")</MudTd>
                <MudTd DataLabel="On">@(((bool)context.enabled) ? "Yes" : "No")</MudTd>
                <MudTd DataLabel="">
                    <MudButton Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => Flatten((Guid)context.tradingAccountId))" Disabled="_busy">Flatten</MudButton>
                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                   aria-label="Delete rule"
                                   OnClick="@(() => DeleteRule((Guid)context.id, (string)context.name))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private dynamic[] _accounts = [], _rules = [];
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        _accounts = await Http.GetDynamicArrayAsync("/api/accounts/");
        await LoadRules();
    }

    private async Task LoadRules() => _rules = await Http.GetDynamicArrayAsync("/api/prop/rules");

    private async Task OpenNew()
    {
        var options = ((IEnumerable<dynamic>)_accounts)
            .Select(a => new NewPropRuleDialog.PropRuleAccountOption((Guid)a.id, $"{a.accountNumber} - {a.broker}"))
            .ToList();
        var parameters = new DialogParameters<NewPropRuleDialog>
        {
            { d => d.Accounts, (IReadOnlyList<NewPropRuleDialog.PropRuleAccountOption>)options },
        };
        var dlg = await Dialogs.ShowAsync<NewPropRuleDialog>(null, parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (NewPropRuleDialog.NewPropRuleResult)res.Data!;

        _busy = true;
        try
        {
            var body = new
            {
                data.TradingAccountId,
                data.Name,
                data.MaxConcurrentLiveInstances,
                data.DailyLossLimit,
                data.MaxDrawdownPercent,
                data.AutoFlatten,
                Enabled = true
            };
            var response = await Http.PostAsJsonAsync("/api/prop/rules", body);
            if (response.IsSuccessStatusCode)
            {
                Snack.Add("Rule created", Severity.Success);
                await LoadRules();
            }
            else
            {
                Snack.Add(await response.Content.ReadAsStringAsync(), Severity.Error);
            }
        }
        catch { Snack.Add("Request failed", Severity.Error); }
        finally { _busy = false; }
    }

    private async Task DeleteRule(Guid id, string name)
    {
        if (!await Dialogs.ConfirmAsync("Delete rule",
                $"Delete the guard rule \"{name}\"? This stops protecting that account.",
                "Delete", "Cancel"))
            return;
        var response = await Http.DeleteAsync($"/api/prop/rules/{id}");
        if (response.IsSuccessStatusCode) await LoadRules();
        else Snack.Add("Delete failed", Severity.Error);
    }

    private async Task Flatten(Guid accountId)
    {
        _busy = true;
        try
        {
            var response = await Http.PostAsync($"/api/prop/flatten/{accountId}", null);
            if (response.IsSuccessStatusCode)
                Snack.Add("Flatten requested", Severity.Success);
            else
                Snack.Add("Flatten failed", Severity.Error);
        }
        catch { Snack.Add("Request failed", Severity.Error); }
        finally { _busy = false; }
    }
}
