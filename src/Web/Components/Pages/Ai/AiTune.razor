@page "/ai/tune"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inherits AiFeaturePageBase

<PageTitle>AI · Tune Advisor</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Tune Advisor</MudText>
    <HelpTip Text="Compares a cBot's two most recent backtests and tells you if its edge is decaying, with one adjustment to test." />
</MudStack>

<AiFeatureNotice EnabledChanged="OnAiStatus" />

<MudPaper Class="pa-4" Elevation="1">
    <MudText Typo="Typo.body2" Class="mb-2">
        Compares a cBot's two most recent backtests and flags edge decay, with one concrete adjustment to try.
    </MudText>
    <MudSelect T="Guid?" @bind-Value="_cbotId" Label="cBot" Dense="true" Style="max-width:240px;">
        @foreach (var c in _cbots) { <MudSelectItem T="Guid?" Value="@((Guid?)c.id)">@c.name</MudSelectItem> }
    </MudSelect>
    <MudButton Class="mt-3" Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.TrendingDown" OnClick="Run" Disabled="Busy">
        Check for decay
    </MudButton>
</MudPaper>

<AiOutputPanel Loading="Loading" Output="Output" />

@code {
    private dynamic[] _cbots = [];
    private Guid? _cbotId;

    protected override async Task OnInitializedAsync() => _cbots = await LoadOrEmptyAsync("/api/cbots/");

    private Task Run()
    {
        if (_cbotId is null)
        {
            Snack.Add("Pick a cBot", Severity.Warning);
            return Task.CompletedTask;
        }
        return PostTextAsync($"/api/ai/tune-advice/{_cbotId}", new { });
    }
}
