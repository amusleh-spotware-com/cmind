@* Modal dialog for starting a new cBot run. Returns RunDialogResult on confirm. When CBotFixed is set
   (the code editor's Run action) the cBot selector is replaced by a read-only label — the cBot is the one
   being edited (its id may still be null until the project has been built once). A parameter set is
   optional (no set ⇒ the cBot's default parameter values); the user can pick an existing set or create a
   new one inline. *@
@using Web.Json
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Run cBot</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            @if (!CBotFixed)
            {
                <MudSelect T="Guid?" @bind-Value="_cbotId" @bind-Value:after="LoadParamSets" Label="cBot"
                           Required="true" RequiredError="cBot is required" Class="mb-2">
                    @foreach (var c in _cbots) { <MudSelectItem T="Guid?" Value="@((Guid?)c.id)">@c.name</MudSelectItem> }
                </MudSelect>
            }
            else
            {
                <MudTextField Value="@(FixedCBotName ?? "cBot")" Label="cBot" ReadOnly="true" Class="mb-2"
                              data-testid="run-fixed-cbot" />
            }
            <MudSelect T="Guid?" @bind-Value="_acctId" Label="Trading account"
                       Required="true" RequiredError="Trading account is required" Class="mb-2">
                @foreach (var a in _accts) { <MudSelectItem T="Guid?" Value="@((Guid?)a.id)">@a.accountNumber - @a.broker</MudSelectItem> }
            </MudSelect>
            <MudTextField @bind-Value="_symbol" Label="Symbol" Required="true" RequiredError="Symbol is required" Class="mb-2" />
            <MudTextField @bind-Value="_timeframe" Label="Timeframe" Required="true" RequiredError="Timeframe is required" Class="mb-2" />
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
                <MudSelect T="Guid?" @bind-Value="_psId" Label="Parameter set (optional)" Clearable="true" Style="flex:1;">
                    @foreach (var p in _paramsets) { <MudSelectItem T="Guid?" Value="@((Guid?)p.id)">@p.name</MudSelectItem> }
                </MudSelect>
                <MudTooltip Text="Create a new parameter set for this cBot">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Disabled="_cbotId is null"
                                   OnClick="NewParamSet" data-testid="run-new-paramset" />
                </MudTooltip>
            </MudStack>
            <MudTextField @bind-Value="_image" Label="Image tag" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" data-testid="run-submit">Run</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance Dialog { get; set; } = default!;

    // When true, the cBot is fixed (the code editor's Run) — the selector is hidden. FixedCBotId is the
    // linked cBot (null until the project has been built once); FixedCBotName labels the read-only field.
    [Parameter] public bool CBotFixed { get; set; }
    [Parameter] public Guid? FixedCBotId { get; set; }
    [Parameter] public string? FixedCBotName { get; set; }

    private MudForm? _form;
    private dynamic[] _cbots = [], _accts = [], _paramsets = [];
    private Guid? _cbotId, _acctId, _psId;
    private string _symbol = "EURUSD", _timeframe = "h1", _image = "latest";

    protected override async Task OnInitializedAsync()
    {
        _accts = await LoadOrEmptyAsync("/api/accounts/");
        if (CBotFixed)
        {
            _cbotId = FixedCBotId;
            if (_cbotId is not null) await LoadParamSets();
        }
        else
        {
            _cbots = await LoadOrEmptyAsync("/api/cbots/");
        }
    }

    private async Task LoadParamSets()
    {
        _psId = null;
        _paramsets = _cbotId is null
            ? []
            : await LoadOrEmptyAsync($"/api/paramsets?cbotId={_cbotId}");
    }

    private async Task NewParamSet()
    {
        if (_cbotId is not { } cbotId) return;
        var parameters = new DialogParameters<ParamSetDialog>
        {
            { x => x.IsEdit, false },
            { x => x.CBotId, cbotId }
        };
        var dlg = await Dialogs.ShowAsync<ParamSetDialog>("New Parameter Set", parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (ParamSetDialog.ParamSetDialogResult)res.Data!;
        var targetCbot = data.CBotId ?? cbotId;
        var r = await Http.PostAsJsonAsync("/api/paramsets", new { CBotId = targetCbot, data.Name, JsonContent = data.Json });
        if (!r.IsSuccessStatusCode)
        {
            var reason = await r.Content.ReadAsStringAsync();
            Snack.Add(string.IsNullOrWhiteSpace(reason)
                ? "Could not create parameter set — check the JSON is a flat name/value object"
                : reason, Severity.Error);
            return;
        }
        Snack.Add("Parameter set created", Severity.Success);
        // Only surface the new set in this dialog when it was created for the cBot this run targets.
        if (targetCbot == cbotId)
        {
            await LoadParamSets();
            var created = _paramsets.FirstOrDefault(p => string.Equals((string)p.name, data.Name, StringComparison.Ordinal));
            if (created is not null) _psId = (Guid)created.id;
        }
    }

    // Tolerate a gated-off/unavailable endpoint (e.g. Authoring disabled → /api/cbots 404) so opening the
    // dialog never throws into the circuit; the affected selector is simply empty.
    private async Task<dynamic[]> LoadOrEmptyAsync(string url)
    {
        try
        {
            return await Http.GetDynamicArrayAsync(url);
        }
        catch
        {
            return [];
        }
    }

    private async Task Submit()
    {
        if (_form is not null) await _form.Validate();
        // In editor (fixed) mode the cBot is implicit — the quick-run endpoint resolves it from the source
        // project — so only the trading account is required there; on the /run page the cBot is required too.
        if ((!CBotFixed && _cbotId is null) || _acctId is null
            || string.IsNullOrWhiteSpace(_symbol) || string.IsNullOrWhiteSpace(_timeframe)) return;
        Dialog.Close(DialogResult.Ok(new RunDialogResult(_cbotId, _acctId, _symbol.Trim(), _timeframe.Trim(), _psId, _image.Trim())));
    }

    private void Cancel() => Dialog.Cancel();

    public sealed record RunDialogResult(Guid? CBotId, Guid? TradingAccountId, string Symbol, string Timeframe, Guid? ParamSetId, string Image);
}
