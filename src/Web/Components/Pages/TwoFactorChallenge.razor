@page "/login/2fa"
@layout EmptyLayout
@inject Web.Branding.IBrandingThemeProvider Branding

<PageTitle>Two-factor authentication — @Branding.Branding.ProductName</PageTitle>

<div class="app-auth">
    <aside class="app-auth-hero">
        <div class="app-auth-hero-glow"></div>
        <div class="app-auth-hero-content">
            <div class="app-auth-hero-brand">
                @if (!string.IsNullOrWhiteSpace(Branding.Branding.LogoUrl))
                {
                    <img src="@Branding.Branding.LogoUrl" alt="@Branding.Branding.ProductName" height="40" />
                }
                else
                {
                    <BrandMark Size="40" />
                }
                <span class="app-login-brand">@Branding.Branding.ProductName</span>
            </div>
            <h1 class="app-auth-hero-title">One more step.</h1>
            <p class="app-auth-hero-tagline">Enter the 6-digit code from your authenticator app to finish signing in.</p>
        </div>
    </aside>

    <main class="app-auth-panel">
        <div class="app-login-card">
            <div class="app-login-logo app-auth-panel-brand">
                <BrandMark Size="40" />
                <span class="app-login-brand">@Branding.Branding.ProductName</span>
            </div>

            <div class="app-login-tabs">
                <div class="app-login-tab app-login-tab-active">TWO-FACTOR</div>
            </div>

            <form method="post" action="/api/auth/login/verify-2fa" class="app-login-form" id="app-2fa-form" data-enhance="false">
                <div class="app-login-field">
                    <svg class="app-login-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9BA3AF" stroke-width="2">
                        <rect x="5" y="11" width="14" height="10" rx="2"/>
                        <path d="M8 11V7a4 4 0 0 1 8 0v4"/>
                    </svg>
                    <input type="text" name="Code" data-testid="mfa-code" placeholder="Authentication or backup code"
                           required autofocus autocomplete="one-time-code" inputmode="text"
                           aria-label="Authentication or backup code" />
                </div>

                @if (HasError)
                {
                    <div class="app-login-error" role="alert" data-testid="mfa-error">Invalid code. Try again or use a backup code.</div>
                }

                <button class="app-login-button" type="submit" id="app-2fa-submit" data-testid="mfa-submit">
                    <span class="app-login-button-label">VERIFY</span>
                    <span class="app-login-spinner" aria-hidden="true"></span>
                </button>
            </form>

            <p class="app-login-support">Lost your device? Enter one of your one-time backup codes above.</p>
            <a class="app-login-support" href="/login">Back to log in</a>
        </div>
    </main>
</div>

<script>
    (function () {
        var form = document.getElementById('app-2fa-form');
        var submit = document.getElementById('app-2fa-submit');
        if (form && submit) {
            form.addEventListener('submit', function () {
                submit.classList.add('app-login-button-loading');
                submit.disabled = true;
            });
        }
    })();
</script>

@code {
    [SupplyParameterFromQuery(Name = "error")] public string? Error { get; set; }
    private bool HasError => !string.IsNullOrEmpty(Error);
}
