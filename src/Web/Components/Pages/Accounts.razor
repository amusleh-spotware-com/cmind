@page "/accounts"
@using Web.Json
@using Web.Components.Dialogs
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs
@inject NavigationManager Nav

<PageTitle>cTrader Accounts</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">cTrader Accounts</MudText>
    <MudSpacer />
    <MudButton Color="Color.Secondary" Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.Api" OnClick="@(() => Nav.NavigateTo("/openapi-apps"))">
        Add via Open API
    </MudButton>
    <MudButton Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNew">
        New cID Account
    </MudButton>
</MudStack>

<MudList T="dynamic" Class="mt-3">
    @foreach (var c in _cids)
    {
        <MudListItem T="dynamic">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.subtitle1">@c.username</MudText>
                @if (c.ctidUserId is not null)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.Api">Open API</MudChip>
                }
                <MudButton Size="Size.Small" OnClick="@(() => DeleteCid(c.id))" Color="Color.Error">Remove</MudButton>
            </MudStack>
            <TradingAccountList CtidId="@((Guid)c.id)" />
        </MudListItem>
    }
</MudList>

@code {
    private dynamic[] _cids = [];

    protected override Task OnInitializedAsync() => Load();
    private async Task Load() => _cids = await Http.GetDynamicArrayAsync("/api/ctids/");

    private async Task OpenNew()
    {
        var dlg = await Dialogs.ShowAsync<NewCidAccountDialog>("New cID Account",
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (NewCidAccountDialog.NewCidAccountDialogResult)res.Data!;
        var r = await Http.PostAsJsonAsync("/api/ctids/", new { data.Username, data.Password });
        Snack.Add(r.IsSuccessStatusCode ? "Added" : "Failed", r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        if (r.IsSuccessStatusCode) await Load();
    }

    private async Task DeleteCid(Guid id)
    {
        await Http.DeleteAsync($"/api/ctids/{id}");
        await Load();
    }
}
