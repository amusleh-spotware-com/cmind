@* Modal dialog showing a freshly created MCP API key once, with a copy button. *@
@inject IJSRuntime JS
@inject ISnackbar Snack

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">MCP Key Created</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Warning" Class="mb-2">
            Copy this key now — it is shown only once.
        </MudText>
        <MudTextField Value="Key" ReadOnly="true" Label="API Key" Variant="Variant.Outlined"
                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                      OnAdornmentClick="Copy" T="string" />
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Copy">Copy</MudButton>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance Dialog { get; set; } = default!;

    [Parameter] public string Key { get; set; } = "";

    private async Task Copy()
    {
        await JS.InvokeVoidAsync("copyToClipboard", Key);
        Snack.Add("Copied to clipboard", Severity.Success);
    }

    private void Close() => Dialog.Close();
}
