@* Shows a banner + one-time dialog when AI is not configured, and reports enablement to the parent
   so it can dim its AI actions. Used by every AI feature page (Assistant, Portfolio Agent, Alerts). *@
@using Web.Json
@inject HttpClient Http
@inject IDialogService Dialogs
@inject NavigationManager Nav
@inject IStringLocalizer<Ui> L

@if (_loaded && !_enabled)
{
    <MudAlert Severity="Severity.Warning" Class="mb-3" data-testid="ai-not-configured">
        <div class="d-flex align-center" style="gap:12px;">
            <span>@L["ai.notice.banner"]</span>
            <MudSpacer />
            <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                       Href="/settings/ai" data-testid="ai-add-key">@L["ai.notice.configure"]</MudButton>
        </div>
    </MudAlert>
}

@code {
    [Parameter] public EventCallback<bool> EnabledChanged { get; set; }

    // Opt-in one-time dialog: dedicated AI feature pages that want the intrusive "configure a provider"
    // prompt set this true; AI-independent surfaces (Alerts, MCP keys, the Agent list) show the banner
    // only and never a blocking dialog.
    [Parameter] public bool PromptOnLoad { get; set; }

    private bool _enabled;
    private bool _loaded;
    private bool _promptPending;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var res = await Http.GetDynamicAsync("/api/ai/status");
            _enabled = res is not null && (bool)res.enabled;
        }
        catch
        {
            _enabled = false;
        }
        _loaded = true;
        _promptPending = PromptOnLoad && !_enabled;
        await EnabledChanged.InvokeAsync(_enabled);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_promptPending) return;
        _promptPending = false;
        var ok = await Dialogs.ShowMessageBox(
            L["ai.notice.title"],
            L["ai.notice.body"],
            yesText: L["ai.notice.openSettings"], cancelText: L["ai.notice.later"]);
        if (ok == true) Nav.NavigateTo("/settings/ai");
    }
}
