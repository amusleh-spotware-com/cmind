@page "/login"
@layout EmptyLayout
@inject NavigationManager Nav
@inject HttpClient Http

<PageTitle>Login</PageTitle>
<MudPaper Class="pa-6 mx-auto mt-12" Style="max-width:400px">
    <MudText Typo="Typo.h5" Class="mb-4">Sign in</MudText>
    <MudTextField @bind-Value="_email" Label="Email" />
    <MudTextField @bind-Value="_password" Label="Password" InputType="InputType.Password" Class="mt-2" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="SubmitAsync" FullWidth="true">
        Sign in
    </MudButton>
    @if (!string.IsNullOrEmpty(_error)) { <MudAlert Severity="Severity.Error" Class="mt-2">@_error</MudAlert> }
</MudPaper>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;

    private async Task SubmitAsync()
    {
        var resp = await Http.PostAsJsonAsync("/api/auth/login", new { Email = _email, Password = _password });
        if (resp.IsSuccessStatusCode) Nav.NavigateTo("/", forceLoad: true);
        else _error = "Invalid credentials";
    }
}
