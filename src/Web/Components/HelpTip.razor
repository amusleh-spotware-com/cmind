@* Reusable inline help affordance. Hover on desktop, tap on mobile (ShowOnClick). Place next to any
   label, control or action; source the text from docs so guidance stays in sync. Mandatory on new
   controls per docs/ui-guidelines.md. *@

<MudTooltip Text="@Text" Arrow="true" Placement="@Placement" ShowOnHover="true" ShowOnClick="true" ShowOnFocus="true">
    <span class="app-help-tip" data-testid="help-tip" tabindex="0" role="button" aria-label="@Text">
        <MudIcon Icon="@Icons.Material.Outlined.HelpOutline" Size="Size.Small" />
    </span>
</MudTooltip>

@code {
    [Parameter, EditorRequired] public string Text { get; set; } = string.Empty;
    [Parameter] public Placement Placement { get; set; } = Placement.Top;
}
