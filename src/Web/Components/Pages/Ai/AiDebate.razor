@page "/ai/debate"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]

<PageTitle>AI · Debate</PageTitle>

<AiRunListView Feature="AiFeature.DebateStrategy"
               Heading="Strategy Debate"
               HelpText="A bull, a bear, and a risk officer argue your cBot before you deploy it, then hand down a verdict. Debates run in the background and are saved — open one anytime."
