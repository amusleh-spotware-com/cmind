@using Core.Features
@inject IFeatureGate Gate
@inject IStringLocalizer<Ui> L

@* Mobile-only bottom navigation (hidden on tablet+ via CSS). Surfaces the highest-traffic
   destinations for thumb reach; the full grouped menu stays behind the app-bar hamburger. *@

<nav class="app-bottomnav" data-testid="bottom-nav">
    <NavLink class="app-bottomnav-item" href="/" Match="NavLinkMatch.All" ActiveClass="app-bottomnav-active">
        <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Small" />
        <span>@L["nav.bottom.home"]</span>
    </NavLink>

    @if (Gate.IsEnabled(FeatureFlag.Authoring))
    {
        <NavLink class="app-bottomnav-item" href="/cbots" ActiveClass="app-bottomnav-active">
            <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" />
            <span>@L["nav.cbots"]</span>
        </NavLink>
    }

    @if (Gate.IsEnabled(FeatureFlag.Execution))
    {
        <NavLink class="app-bottomnav-item" href="/run" ActiveClass="app-bottomnav-active">
            <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
            <span>@L["nav.run"]</span>
        </NavLink>
    }

    @if (Gate.IsEnabled(FeatureFlag.Ai))
    {
        <NavLink class="app-bottomnav-item" href="/ai/build" ActiveClass="app-bottomnav-active">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
            <span>@L["nav.group.ai"]</span>
        </NavLink>
    }

    <NavLink class="app-bottomnav-item" href="/account" ActiveClass="app-bottomnav-active">
        <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small" />
        <span>@L["nav.bottom.account"]</span>
    </NavLink>
</nav>
