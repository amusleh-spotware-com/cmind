@page "/strategy-builder"
@using System.Net.Http.Json
@using System.Text.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject NavigationManager Nav

<PageTitle>Strategy Builder</PageTitle>

<MudText Typo="Typo.h5" Class="mb-2">Strategy Builder</MudText>
<MudText Typo="Typo.body2" Class="mb-4">
    Describe a strategy in plain English. The AI writes the cBot, builds it, fixes its own compile
    errors (up to 3 tries), and — on success — creates a runnable cBot you can launch.
</MudText>

<MudPaper Class="pa-4" Elevation="1">
    <MudStack Row="true" Spacing="2">
        <MudSelect T="string" @bind-Value="_language" Label="Language" Dense="true" Style="max-width:180px;">
            <MudSelectItem Value="@("CSharp")">C#</MudSelectItem>
            <MudSelectItem Value="@("Python")">Python</MudSelectItem>
        </MudSelect>
        <MudTextField @bind-Value="_name" Label="Bot name" Style="max-width:280px;" Placeholder="MyBot" />
    </MudStack>
    <MudTextField @bind-Value="_description" Label="Describe your strategy" Lines="5" Class="mt-3"
                  Placeholder="e.g. RSI mean-reversion on EURUSD h1: buy when RSI < 30, sell when RSI > 70, 1.5% risk, ATR stop-loss" />
    <MudButton Class="mt-3" Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Bolt" OnClick="Build" Disabled="_busy">
        Build my bot
    </MudButton>
</MudPaper>

@if (_busy)
{
    <MudProgressLinear Indeterminate="true" Class="mt-3" />
    <MudText Typo="Typo.caption" Class="mt-1">Generating, building and self-repairing — this can take a minute.</MudText>
}

@if (_result is not null)
{
    <MudPaper Class="pa-4 mt-3" Elevation="1">
        @if (_result.Success)
        {
            <MudAlert Severity="Severity.Success" Class="mb-2">
                Built in @_result.Attempts attempt(s). Your runnable cBot is ready.
            </MudAlert>
            <MudStack Row="true" Spacing="2">
                <MudButton Color="Color.Primary" Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="GoToRun">Run it</MudButton>
                <MudButton Color="Color.Secondary" Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Edit" OnClick="GoToEditor">Open in editor</MudButton>
            </MudStack>
        }
        else
        {
            <MudAlert Severity="Severity.Error" Class="mb-2">
                @(_result.Error ?? $"Build failed after {_result.Attempts} attempt(s).")
            </MudAlert>
        }
        @if (!string.IsNullOrEmpty(_result.Log))
        {
            <MudText Typo="Typo.subtitle2" Class="mt-2">Build log</MudText>
            <pre style="white-space:pre-wrap; margin:0; max-height:320px; overflow:auto;">@_result.Log</pre>
        }
    </MudPaper>
}

@code {
    private string _language = "CSharp";
    private string _name = "MyBot";
    private string _description = "";
    private bool _busy;
    private BuildResult? _result;

    private async Task Build()
    {
        if (string.IsNullOrWhiteSpace(_description))
        {
            Snack.Add("Describe your strategy first", Severity.Warning);
            return;
        }
        _busy = true;
        _result = null;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/ai/build-strategy",
                new { Name = _name, Language = _language, Description = _description });
            var text = await response.Content.ReadAsStringAsync();
            using var doc = JsonDocument.Parse(text);
            var root = doc.RootElement;
            _result = new BuildResult(
                root.TryGetProperty("success", out var s) && s.ValueKind == JsonValueKind.True,
                root.TryGetProperty("cbotId", out var c) && c.ValueKind == JsonValueKind.String ? c.GetGuid() : null,
                root.TryGetProperty("projectId", out var p) && p.ValueKind == JsonValueKind.String ? p.GetGuid() : null,
                root.TryGetProperty("attempts", out var a) && a.ValueKind == JsonValueKind.Number ? a.GetInt32() : 0,
                root.TryGetProperty("log", out var l) ? l.GetString() : null,
                root.TryGetProperty("error", out var e) ? e.GetString() : null);
        }
        catch
        {
            Snack.Add("Request failed", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private void GoToRun()
    {
        if (_result?.CBotId is { } id) Nav.NavigateTo($"/run?cbot={id}");
    }

    private void GoToEditor()
    {
        if (_result?.ProjectId is { } id) Nav.NavigateTo($"/builder/{id}");
    }

    private sealed record BuildResult(bool Success, Guid? CBotId, Guid? ProjectId, int Attempts, string? Log, string? Error);
}
