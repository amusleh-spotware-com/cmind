@page "/quant/integrity"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@using System.Net.Http.Json
@using Web.Components.Quant
@implements IDisposable
@inject HttpClient Http
@inject MudBlazor.ISnackbar Snack

<PageTitle>Quant · Backtest Integrity</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Backtest Integrity Lab</MudText>
    <HelpTip Text="Is this backtest a real edge or an overfit fluke? We compute the Probabilistic and Deflated Sharpe Ratio (Bailey & López de Prado) and correct for how many configurations you tried, then give a Robust / Fragile / Overfit verdict." />
</MudStack>

<MudGrid>
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                <MudText Typo="Typo.subtitle1">Return / equity series</MudText>
                <HelpTip Text="Enter one value per period in the numeric fields — no pasting. Add or remove rows as needed. Toggle the mode if your values are an equity/balance curve rather than periodic returns. To score a real run, use the shield icon on any completed backtest instead of entering values here." />
            </MudStack>
            <MudRadioGroup @bind-Value="_mode" Class="mb-2">
                <MudRadio Value="@("returns")" Color="Color.Primary" Dense="true">Periodic returns (e.g. 0.01 = +1%)</MudRadio>
                <MudRadio Value="@("equity")" Color="Color.Primary" Dense="true">Equity / balance curve</MudRadio>
            </MudRadioGroup>

            @for (var i = 0; i < _values.Count; i++)
            {
                var index = i;
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="width:26px">@(index + 1)</MudText>
                    <MudNumericField T="double?" @bind-Value="_values[index]" Variant="Variant.Outlined"
                                     Margin="Margin.Dense" Immediate="true" Class="flex-grow-1"
                                     data-testid="@($"series-value-{index}")" aria-label="@($"Value {index + 1}")" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error"
                                   Disabled="@(_values.Count <= 2)" aria-label="Remove value"
                                   OnClick="@(() => RemoveValue(index))" data-testid="@($"series-remove-{index}")" />
                </MudStack>
            }
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-1">
                <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="AddValue"
                           data-testid="series-add">Add value</MudButton>
                <MudText Typo="Typo.caption" data-testid="series-count"
                         Color="@(SeriesValidCount >= 2 ? Color.Success : Color.Default)">
                    @($"{SeriesValidCount} value(s)" + (SeriesValidCount < 2 ? " — need at least 2" : ""))
                </MudText>
            </MudStack>

            <MudNumericField @bind-Value="_trials" Label="Configurations tried (trials)" Min="1"
                             Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3"
                             HelperText="How many parameter sets you tested to pick this one. More trials → stronger overfitting penalty." />
            <MudButton Class="mt-3" Color="Color.Primary" Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.VerifiedUser" OnClick="Analyze"
                       Disabled="@(_loading || SeriesValidCount < 2)" data-testid="integrity-analyze">
                Analyze
            </MudButton>
        </MudPaper>

        <MudPaper Class="pa-4 mt-4" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.subtitle1">Overfitting across trials (optional)</MudText>
                <HelpTip Text="Add a row per configuration you tried and enter each one's out-of-sample returns in the numeric fields. We run Combinatorially-Symmetric Cross-Validation to estimate the Probability of Backtest Overfitting: how often the in-sample winner fails out-of-sample." />
            </MudStack>

            @for (var t = 0; t < _grid.Count; t++)
            {
                var trialIndex = t;
                <MudPaper Class="pa-2 mt-2" Outlined="true" data-testid="@($"trial-{trialIndex}")">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                        <MudText Typo="Typo.caption">Trial @(trialIndex + 1)</MudText>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       Disabled="@(_grid.Count <= 2)" aria-label="Remove trial"
                                       OnClick="@(() => RemoveTrial(trialIndex))" data-testid="@($"trial-remove-{trialIndex}")" />
                    </MudStack>
                    <div class="d-flex flex-wrap align-center" style="gap:4px">
                        @for (var v = 0; v < _grid[trialIndex].Count; v++)
                        {
                            var valueIndex = v;
                            <MudNumericField T="double?" @bind-Value="_grid[trialIndex][valueIndex]"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                             HideSpinButtons="true" Style="width:88px"
                                             data-testid="@($"trial-{trialIndex}-value-{valueIndex}")"
                                             aria-label="@($"Trial {trialIndex + 1} value {valueIndex + 1}")" />
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary"
                                       aria-label="Add number" OnClick="@(() => AddTrialValue(trialIndex))"
                                       data-testid="@($"trial-{trialIndex}-add")" />
                    </div>
                </MudPaper>
            }
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="AddTrial"
                           data-testid="trial-add">Add trial</MudButton>
                <MudText Typo="Typo.caption" data-testid="trial-count"
                         Color="@(ReadyTrialCount >= 2 ? Color.Success : Color.Default)">
                    @($"{ReadyTrialCount} trial series ready" + (ReadyTrialCount < 2 ? " — need at least 2 (≥4 numbers each)" : ""))
                </MudText>
            </MudStack>
            <MudButton Class="mt-3" Color="Color.Secondary" Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.GridView" OnClick="AssessOverfitting"
                       Disabled="@(_loading || ReadyTrialCount < 2)" data-testid="integrity-pbo">
                Assess overfitting
            </MudButton>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="7">
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_result is { } r)
        {
            <MudPaper Class="pa-4" Elevation="1">
                <IntegrityResultView Result="r" />
            </MudPaper>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Enter a return series or equity curve and press Analyze.
            </MudText>
        }
    </MudItem>
</MudGrid>

@code {
    // Structured input — proper numeric controls, never a free-text blob. A value is "present" when its
    // field holds a number (null = an empty row the user hasn't filled yet).
    private readonly List<double?> _values = [null, null];
    private string _mode = "returns";
    private int _trials = 1;
    private readonly List<List<double?>> _grid = [[null, null, null, null], [null, null, null, null]];
    private bool _loading;
    private IntegrityResult? _result;
    private readonly CancellationTokenSource _cts = new();

    private int SeriesValidCount => _values.Count(v => v is not null);
    private int ReadyTrialCount => _grid.Count(trial => trial.Count(v => v is not null) >= 4);

    private void AddValue() => _values.Add(null);
    private void RemoveValue(int index) { if (_values.Count > 2) _values.RemoveAt(index); }
    private void AddTrial() => _grid.Add([null, null, null, null]);
    private void RemoveTrial(int index) { if (_grid.Count > 2) _grid.RemoveAt(index); }
    private void AddTrialValue(int trialIndex) => _grid[trialIndex].Add(null);

    private async Task Analyze()
    {
        var numbers = _values.Where(v => v is not null).Select(v => v!.Value).ToArray();
        if (numbers.Length < 2)
        {
            Snack.Add("Enter at least two values.", Severity.Warning);
            return;
        }

        _loading = true;
        _result = null;
        try
        {
            var body = _mode == "equity"
                ? (object)new { Equity = numbers, Trials = _trials }
                : new { Returns = numbers, Trials = _trials };
            var response = await Http.PostAsJsonAsync("/api/quant/integrity", body, _cts.Token);
            if (_cts.IsCancellationRequested) return;
            if (response.IsSuccessStatusCode)
            {
                _result = await response.Content.ReadFromJsonAsync<IntegrityResult>(_cts.Token);
            }
            else
            {
                Snack.Add("Could not analyze that series.", Severity.Error);
            }
        }
        catch (OperationCanceledException) { }
        catch
        {
            Snack.Add("Could not analyze that series.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task AssessOverfitting()
    {
        var grid = _grid
            .Select(trial => trial.Where(v => v is not null).Select(v => v!.Value).ToArray())
            .Where(r => r.Length >= 4)
            .ToArray();
        if (grid.Length < 2)
        {
            Snack.Add("Add at least two trials with four or more numbers each.", Severity.Warning);
            return;
        }

        _loading = true;
        _result = null;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/quant/pbo", new { Trials = grid }, _cts.Token);
            if (_cts.IsCancellationRequested) return;
            if (response.IsSuccessStatusCode)
                _result = await response.Content.ReadFromJsonAsync<IntegrityResult>(_cts.Token);
            else
                Snack.Add("Could not assess that trial grid.", Severity.Error);
        }
        catch (OperationCanceledException) { }
        catch
        {
            Snack.Add("Could not assess that trial grid.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
