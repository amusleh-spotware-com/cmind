@page "/paramsets"
@using Web.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack

<PageTitle>Parameter Sets</PageTitle>
<MudText Typo="Typo.h5" Class="mb-3">Parameter Sets</MudText>

<MudSelect T="Guid?" @bind-Value="_cbotId" Label="cBot" Class="mb-3">
    @foreach (var c in _cbots) { <MudSelectItem T="Guid?" Value="@((Guid?)c.id)">@c.name</MudSelectItem> }
</MudSelect>

@if (_cbotId is not null)
{
    <MudTextField @bind-Value="_name" Label="Name" Required="true" RequiredError="Name is required" />
    <MudTextField @bind-Value="_json" Label="JSON" Lines="8" Variant="Variant.Outlined" Class="mt-2" />
    <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Primary" Class="mt-2">Save</MudButton>

    <MudTable Items="_items" Class="mt-3" Dense="true">
        <HeaderContent><MudTh>Name</MudTh><MudTh /></HeaderContent>
        <RowTemplate>
            <MudTd>@context.name</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => Edit((Guid)context.id))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => Delete((Guid)context.id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private dynamic[] _cbots = [], _items = [];
    private Guid? _cbotId;
    private string _name = "", _json = "{}";
    private Guid? _editing;

    protected override async Task OnInitializedAsync() =>
        _cbots = await Http.GetDynamicArrayAsync("/api/cbots/");

    protected override async Task OnParametersSetAsync()
    {
        if (_cbotId is not null) _items = await Http.GetDynamicArrayAsync($"/api/paramsets?cbotId={_cbotId}");
    }

    private async Task Save()
    {
        if (_cbotId is null) return;
        if (string.IsNullOrWhiteSpace(_name)) { Snack.Add("Name is required", Severity.Error); return; }
        if (!IsNonEmptyJson(_json)) { Snack.Add("Content cannot be empty", Severity.Error); return; }

        var url = _editing is null ? "/api/paramsets" : $"/api/paramsets/{_editing}";
        var method = _editing is null ? HttpMethod.Post : HttpMethod.Put;
        var req = new HttpRequestMessage(method, url)
        {
            Content = JsonContent.Create(new { CBotId = _cbotId, Name = _name, JsonContent = _json })
        };
        var r = await Http.SendAsync(req);
        Snack.Add(r.IsSuccessStatusCode ? "Saved" : "Failed", r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        _name = ""; _json = "{}"; _editing = null;
        await OnParametersSetAsync();
    }

    private static bool IsNonEmptyJson(string content)
    {
        if (string.IsNullOrWhiteSpace(content)) return false;
        System.Text.Json.JsonDocument doc;
        try { doc = System.Text.Json.JsonDocument.Parse(content); }
        catch { return false; }
        using (doc)
        {
            return doc.RootElement.ValueKind switch
            {
                System.Text.Json.JsonValueKind.Object => doc.RootElement.EnumerateObject().Any(),
                System.Text.Json.JsonValueKind.Array => doc.RootElement.EnumerateArray().Any(),
                _ => true
            };
        }
    }

    private async Task Edit(Guid id)
    {
        var p = await Http.GetDynamicAsync($"/api/paramsets/{id}");
        if (p is not null) { _editing = id; _name = p.name; _json = p.jsonContent; }
    }

    private async Task Delete(Guid id) { await Http.DeleteAsync($"/api/paramsets/{id}"); await OnParametersSetAsync(); }
}
