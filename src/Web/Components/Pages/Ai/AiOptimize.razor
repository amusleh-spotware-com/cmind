@page "/ai/optimize"
@using System.Text.Json
@using Web.Components.Dialogs
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject IDialogService Dialogs

<PageTitle>AI · Optimize</PageTitle>

<AiRunListView Feature="AiFeature.ProposeParamSetSuite"
               Heading="Optimize"
               HelpText="Pick a cBot, a trading account and a symbol/timeframe. The AI proposes parameter sets and backtests each across your nodes in the background, then reports what it launched. Optimizations are saved — open one anytime."
               NewLabel="New optimization"
               RoutePrefix="/ai/optimize"
               EmptyHint="Start an optimization to see it here."
               StartInputProvider="StartAsync" />

@code {
    private async Task<AiRunListView.AiRunInput?> StartAsync()
    {
        CBotDto[] cbots;
        AccountDto[] accounts;
        try { cbots = await Http.GetFromJsonAsync<CBotDto[]>("/api/cbots/") ?? []; }
        catch { cbots = []; }
        try { accounts = await Http.GetFromJsonAsync<AccountDto[]>("/api/accounts") ?? []; }
        catch { accounts = []; }

        var parameters = new DialogParameters<AiOptimizeStartDialog>
        {
            { x => x.CBots, (IReadOnlyList<AiOptimizeStartDialog.CBotOption>)
                cbots.Select(c => new AiOptimizeStartDialog.CBotOption(c.Id, c.Name)).ToList() },
            { x => x.Accounts, (IReadOnlyList<AiOptimizeStartDialog.AccountOption>)
                accounts.Select(a => new AiOptimizeStartDialog.AccountOption(a.Id, a.AccountNumber, a.Broker)).ToList() }
        };
        var opts = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await Dialogs.ShowAsync<AiOptimizeStartDialog>("New optimization", parameters, opts);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not AiOptimizeStartDialog.Result r) return null;

        var source = JsonSerializer.Serialize(new
        {
            cbotId = r.CBotId, tradingAccountId = r.TradingAccountId,
            symbol = r.Symbol, timeframe = r.Timeframe, count = r.Count
        });
        var title = $"{r.CBotName} · {r.Symbol} {r.Timeframe}";
        return new AiRunListView.AiRunInput(title, source, r.ModelId);
    }

    private sealed record CBotDto(Guid Id, string Name);
    private sealed record AccountDto(Guid Id, long AccountNumber, string Broker);
}
