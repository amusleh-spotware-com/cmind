@inject HttpClient Http
@using Web.Json
@using Web.Components.Dialogs
@inject ISnackbar Snack
@inject IDialogService Dialogs

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2">
    <MudSpacer />
    <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNew">
        New Trading Account
    </MudButton>
</MudStack>

<MudTable Items="_items" Dense="true" Class="mt-2">
    <HeaderContent>
        <MudTh>Account</MudTh><MudTh>Broker</MudTh><MudTh>Live</MudTh><MudTh /></HeaderContent>
    <RowTemplate>
        <MudTd>@context.accountNumber</MudTd>
        <MudTd>@context.broker</MudTd>
        <MudTd>@context.isLive</MudTd>
        <MudTd><MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => Remove(context.id))" /></MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Parameter] public Guid CtidId { get; set; }
    private dynamic[] _items = [];

    protected override Task OnParametersSetAsync() => Load();

    private async Task Load() =>
        _items = await Http.GetDynamicArrayAsync($"/api/ctids/{CtidId}/accounts");

    private async Task OpenNew()
    {
        var dlg = await Dialogs.ShowAsync<NewTradingAccountDialog>("New Trading Account",
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (NewTradingAccountDialog.NewTradingAccountDialogResult)res.Data!;
        var r = await Http.PostAsJsonAsync($"/api/ctids/{CtidId}/accounts",
            new { data.AccountNumber, data.Broker, data.IsLive });
        if (r.IsSuccessStatusCode) await Load();
        else Snack.Add("Failed", Severity.Error);
    }

    private async Task Remove(Guid id) { await Http.DeleteAsync($"/api/accounts/{id}"); await Load(); }
}
