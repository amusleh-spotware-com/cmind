@page "/quant/regimes"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@using System.Net.Http.Json
@implements IDisposable
@inject HttpClient Http
@inject MudBlazor.ISnackbar Snack

<PageTitle>Quant · Regime Lab</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Regime Lab</MudText>
    <HelpTip Text="One Sharpe hides 'great in calm markets, dead in turbulence'. We label the history into Calm / Normal / Turbulent volatility regimes and show your performance in each, plus the Hurst exponent (trend vs mean-reversion)." />
</MudStack>

<MudGrid>
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                <MudText Typo="Typo.subtitle1">Return / equity series (oldest first)</MudText>
                <HelpTip Text="Enter one value per period in the numeric fields, oldest first — no pasting. At least six values are needed to label volatility regimes. Toggle the mode if your values are an equity/balance curve rather than periodic returns." />
            </MudStack>
            <MudRadioGroup @bind-Value="_mode" Class="mb-2">
                <MudRadio Value="@("returns")" Color="Color.Primary" Dense="true">Periodic returns (e.g. 0.01 = +1%)</MudRadio>
                <MudRadio Value="@("equity")" Color="Color.Primary" Dense="true">Equity / balance curve</MudRadio>
            </MudRadioGroup>

            @for (var i = 0; i < _values.Count; i++)
            {
                var index = i;
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="width:26px">@(index + 1)</MudText>
                    <MudNumericField T="double?" @bind-Value="_values[index]" Variant="Variant.Outlined"
                                     Margin="Margin.Dense" Immediate="true" Class="flex-grow-1"
                                     data-testid="@($"series-value-{index}")" aria-label="@($"Value {index + 1}")" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error"
                                   Disabled="@(_values.Count <= MinValues)" aria-label="Remove value"
                                   OnClick="@(() => RemoveValue(index))" data-testid="@($"series-remove-{index}")" />
                </MudStack>
            }
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-1">
                <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="AddValue"
                           data-testid="series-add">Add value</MudButton>
                <MudText Typo="Typo.caption" data-testid="series-count"
                         Color="@(SeriesValidCount >= MinValues ? Color.Success : Color.Default)">
                    @($"{SeriesValidCount} value(s)" + (SeriesValidCount < MinValues ? $" — need at least {MinValues}" : ""))
                </MudText>
            </MudStack>
            <MudButton Class="mt-3" Color="Color.Primary" Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Layers" OnClick="Analyze"
                       Disabled="@(_loading || SeriesValidCount < MinValues)" data-testid="regimes-analyze">
                Analyze regimes
            </MudButton>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="7">
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_result is { } r)
        {
            <MudPaper Class="pa-4" Elevation="1" data-testid="regimes-result">
                <MudText Typo="Typo.subtitle1" Class="mb-2">Hurst exponent: <b>@r.hurstExponent.ToString("0.00")</b></MudText>
                <MudSimpleTable Dense="true" Hover="true">
                    <thead>
                        <tr><th>Regime</th><th>Obs</th><th>Mean</th><th>Volatility</th><th>Sharpe</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var p in r.byRegime)
                        {
                            <tr>
                                <td>@p.regime</td>
                                <td>@p.observations</td>
                                <td>@((p.meanReturn * 100).ToString("0.00"))%</td>
                                <td>@((p.volatility * 100).ToString("0.00"))%</td>
                                <td>@p.sharpe.ToString("0.00")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
                <MudText Typo="Typo.body2" Class="mt-3">@r.rationale</MudText>
            </MudPaper>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Paste a return series (oldest first) and press Analyze regimes.
            </MudText>
        }
    </MudItem>
</MudGrid>

@code {
    private const int MinValues = 6;

    // Structured numeric input — one field per period (oldest first), never a free-text blob.
    private readonly List<double?> _values = [null, null, null, null, null, null];
    private string _mode = "returns";
    private bool _loading;
    private RegimeResult? _result;
    private readonly CancellationTokenSource _cts = new();

    private int SeriesValidCount => _values.Count(v => v is not null);
    private void AddValue() => _values.Add(null);
    private void RemoveValue(int index) { if (_values.Count > MinValues) _values.RemoveAt(index); }

    private async Task Analyze()
    {
        var numbers = _values.Where(v => v is not null).Select(v => v!.Value).ToArray();
        if (numbers.Length < MinValues)
        {
            Snack.Add("Enter at least six values.", Severity.Warning);
            return;
        }

        _loading = true;
        _result = null;
        try
        {
            var body = _mode == "equity" ? (object)new { Equity = numbers } : new { Returns = numbers };
            var response = await Http.PostAsJsonAsync("/api/quant/regimes", body, _cts.Token);
            if (_cts.IsCancellationRequested) return;
            if (response.IsSuccessStatusCode)
                _result = await response.Content.ReadFromJsonAsync<RegimeResult>(_cts.Token);
            else
                Snack.Add("Could not analyze that series.", Severity.Error);
        }
        catch (OperationCanceledException) { }
        catch
        {
            Snack.Add("Could not analyze that series.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private sealed record RegimeResult(double hurstExponent, List<RegimeRow> byRegime, int segments, string rationale);
    private sealed record RegimeRow(string regime, int observations, double meanReturn, double volatility, double sharpe);
}
