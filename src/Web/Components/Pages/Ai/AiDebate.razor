@page "/ai/debate"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inherits AiFeaturePageBase

<PageTitle>AI · Debate</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Strategy Debate</MudText>
    <HelpTip Text="A bull, a bear, and a risk officer argue your cBot before you deploy it, then hand down a verdict." />
</MudStack>

<AiFeatureNotice EnabledChanged="OnAiStatus" />

<MudPaper Class="pa-4" Elevation="1">
    <MudTextField @bind-Value="_source" Label="cBot source" Lines="10"
                  Placeholder="Paste cBot source to put it before the committee" />
    <MudButton Class="mt-3" Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Forum" OnClick="Run" Disabled="Busy">
        Run the debate
    </MudButton>
</MudPaper>

<AiOutputPanel Loading="@Loading" Output="@Output" />

@code {
    private string _source = "";
    private const string Language = "CSharp";

    private Task Run() => PostTextAsync("/api/ai/debate", new { Name = "cBot", Language, Source = _source });
}
