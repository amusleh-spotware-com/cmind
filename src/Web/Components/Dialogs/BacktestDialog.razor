@* Modal dialog for starting a new backtest. Returns BacktestDialogResult on confirm. *@
@using Web.Json
@inject HttpClient Http
@inject TimeProvider TimeProvider

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Backtest cBot</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            <MudSelect T="Guid?" @bind-Value="_cbotId" @bind-Value:after="LoadParamSets" Label="cBot"
                       Required="true" RequiredError="cBot is required" Class="mb-2">
                @foreach (var c in _cbots) { <MudSelectItem T="Guid?" Value="@((Guid?)c.id)">@c.name</MudSelectItem> }
            </MudSelect>
            <MudSelect T="Guid?" @bind-Value="_acctId" Label="Trading account"
                       Required="true" RequiredError="Trading account is required" Class="mb-2">
                @foreach (var a in _accts) { <MudSelectItem T="Guid?" Value="@((Guid?)a.id)">@a.accountNumber - @a.broker</MudSelectItem> }
            </MudSelect>
            <MudTextField @bind-Value="_symbol" Label="Symbol" Required="true" RequiredError="Symbol is required" Class="mb-2" />
            <MudTextField @bind-Value="_timeframe" Label="Timeframe" Required="true" RequiredError="Timeframe is required" Class="mb-2" />
            <MudDatePicker @bind-Date="_from" Label="From" Class="mb-2" data-testid="backtest-from" />
            <MudDatePicker @bind-Date="_to" Label="To" Class="mb-2" data-testid="backtest-to" />
            @if (_dateError is not null)
            {
                <MudText Color="Color.Error" Typo="Typo.caption" data-testid="backtest-date-error">@_dateError</MudText>
            }
            <MudSelect T="string" @bind-Value="_dataMode" Label="Data mode" Class="mb-2" data-testid="backtest-datamode">
                <MudSelectItem T="string" Value="@("m1")">m1 (1-minute bars)</MudSelectItem>
                <MudSelectItem T="string" Value="@("tick")">tick</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_balance" Label="Starting balance" Class="mb-2" data-testid="backtest-balance" />
            <MudTextField @bind-Value="_commission" Label="Commission" Class="mb-2" data-testid="backtest-commission" />
            <MudTextField @bind-Value="_spread" Label="Spread" Class="mb-2" data-testid="backtest-spread" />
            <MudTextField @bind-Value="_advanced" Label="Advanced options (one name=value per line)" Lines="3"
                          Variant="Variant.Outlined" Class="mb-1" data-testid="backtest-advanced"
                          HelperText="Any other cTrader backtest option, e.g. applyCommissionAutomatically=true" />
            <MudSelect T="Guid?" @bind-Value="_psId" Label="Parameter set" Clearable="true" Class="mb-2">
                @foreach (var p in _paramsets) { <MudSelectItem T="Guid?" Value="@((Guid?)p.id)">@p.name</MudSelectItem> }
            </MudSelect>
            <MudTextField @bind-Value="_image" Label="Image tag" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Start backtest</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance Dialog { get; set; } = default!;

    private MudForm? _form;
    private dynamic[] _cbots = [], _accts = [], _paramsets = [];
    private Guid? _cbotId, _acctId, _psId;
    private string _symbol = "EURUSD", _timeframe = "h1", _image = "latest";
    private string _dataMode = "m1", _balance = "10000", _commission = "0", _spread = "0", _advanced = "";
    private DateTime? _from, _to;
    private string? _dateError;

    protected override async Task OnInitializedAsync()
    {
        var now = TimeProvider.GetUtcNow().UtcDateTime;
        _from = now.AddMonths(-1);
        _to = now;
        _cbots = await LoadOrEmptyAsync("/api/cbots/");
        _accts = await LoadOrEmptyAsync("/api/accounts/");
    }

    private async Task LoadParamSets()
    {
        _psId = null;
        _paramsets = _cbotId is null
            ? []
            : await LoadOrEmptyAsync($"/api/paramsets?cbotId={_cbotId}");
    }

    // Tolerate a gated-off/unavailable endpoint (e.g. Authoring disabled → /api/cbots 404) so opening the
    // dialog never throws into the circuit; the affected selector is simply empty.
    private async Task<dynamic[]> LoadOrEmptyAsync(string url)
    {
        try
        {
            return await Http.GetDynamicArrayAsync(url);
        }
        catch
        {
            return [];
        }
    }

    private async Task Submit()
    {
        if (_form is not null) await _form.Validate();
        if (_cbotId is null || _acctId is null
            || string.IsNullOrWhiteSpace(_symbol) || string.IsNullOrWhiteSpace(_timeframe)) return;
        // A backtest with a missing or inverted window produces an empty --start/--end that the cTrader
        // Console rejects silently (B-05) — validate the dates before dispatching.
        if (_from is null || _to is null || _from >= _to)
        {
            _dateError = "Pick a valid From date earlier than the To date.";
            return;
        }
        _dateError = null;
        var settingsJson = BacktestSettings.ToJson(_from, _to, _dataMode, _balance, _commission, _spread, _advanced);
        Dialog.Close(DialogResult.Ok(new BacktestDialogResult(
            _cbotId, _acctId, _symbol.Trim(), _timeframe.Trim(), _psId, _image.Trim(), settingsJson)));
    }

    private void Cancel() => Dialog.Cancel();

    public sealed record BacktestDialogResult(
        Guid? CBotId, Guid? TradingAccountId, string Symbol, string Timeframe,
        Guid? ParamSetId, string Image, string SettingsJson);
}
