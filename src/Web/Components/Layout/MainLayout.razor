@inherits LayoutComponentBase
@implements IDisposable
@using System.Globalization
@using Core.Constants
@inject Web.Branding.IBrandingThemeProvider Branding
@inject NavigationManager Nav
@inject IStringLocalizer<Ui> L

<MudThemeProvider Theme="@Branding.Theme" IsDarkMode="true" />
<MudRTLProvider RightToLeft="@_rightToLeft">
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       aria-label="@L["layout.toggleNav"]"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        @if (!string.IsNullOrWhiteSpace(Branding.Branding.LogoUrl))
        {
            <MudImage Src="@Branding.Branding.LogoUrl" Alt="@Branding.Branding.ProductName" Height="28" Class="mr-2" />
        }
        else
        {
            <BrandMark Size="26" Class="mr-2" />
        }
        <MudText Typo="Typo.h6" data-testid="app-product-name" Class="app-brand-word">@Branding.Branding.ProductName</MudText>
        <MudText Typo="Typo.caption" Class="ml-2 mud-text-disabled" data-testid="app-version">v@(Core.VersionInfo.Product)</MudText>
        <MudSpacer />
        <LanguageSwitcher />
        <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" Href="/account" aria-label="@L["layout.account"]" />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Variant="@DrawerVariant.Responsive" Breakpoint="Breakpoint.Md" Elevation="1">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="app-main-content">
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-2 pa-md-6">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent>
                    <MudAlert Severity="Severity.Error" Class="my-4" data-testid="page-error">
                        @L["layout.pageError"]
                        <MudButton Class="ml-2" Variant="Variant.Text" Color="Color.Inherit"
                                   OnClick="RecoverError">@L["common.retry"]</MudButton>
                    </MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
    <BottomNav />
</MudLayout>
</MudRTLProvider>

@code {
    private bool _drawerOpen = true;
    private ErrorBoundary? _errorBoundary;
    private bool _rightToLeft;

    protected override void OnInitialized()
    {
        _rightToLeft = SupportedCultures.IsRightToLeft(CultureInfo.CurrentUICulture.Name);
        Nav.LocationChanged += OnLocationChanged;
        Branding.Changed += OnBrandingChanged;
    }

    // The branding provider is an app-wide singleton; an owner editing a branding override in Settings →
    // Deployment mutates it via IOptionsMonitor.OnChange. Blazor Server won't re-render this layout for a
    // singleton field mutation on its own, so re-render explicitly on the circuit's dispatcher.
    private void OnBrandingChanged() => InvokeAsync(StateHasChanged);

    // A Blazor ErrorBoundary latches on the first caught exception and keeps showing its error content on
    // every later render — so one page throwing would leave every subsequently navigated page (and the
    // dialogs on that circuit) stuck on the error UI. Recover on each navigation so an error never spreads
    // past the page that caused it.
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => _errorBoundary?.Recover();

    private void RecoverError() => _errorBoundary?.Recover();

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        Branding.Changed -= OnBrandingChanged;
    }
}
