@page "/settings/openapi"
@using System.Text.Json
@using Web.Json
@using Web.Components.Dialogs
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Open API</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Open API</MudText>
    <MudSpacer />
    @if (_configured)
    {
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Link"
                   OnClick="Authorize">Authorize accounts</MudButton>
    }
</MudStack>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    @if (_isOwner)
    {
        @* Owner's own account authorization. An owner registers a per-user Open API application exactly like
           any user, UNLESS a deployment shared application is configured below, which then supersedes it. *@
        <MudText Typo="Typo.h6" Class="mb-2">Your Open API application</MudText>
        @if (_sharedMode)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">
                A deployment shared application is configured, so your accounts authorize through it. Remove the
                shared application below if you want to register your own per-user application instead.
            </MudAlert>
        }
        else if (!_configured)
        {
            <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">
                Register your own cTrader Open API application, then authorize your cIDs to add their trading accounts.
            </MudText>
            <MudPaper Class="pa-6 mb-4" Elevation="0" Outlined="true">
                <MudStack AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.Api" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.subtitle1">No Open API application configured</MudText>
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="Configure">Add Application</MudButton>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudCard Class="mb-4">
                <MudCardContent>
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.subtitle1">@_name</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">Configured</MudChip>
                        </MudStack>
                        <MudText Typo="Typo.body2"><b>Client ID:</b> @_clientId</MudText>
                        <MudText Typo="Typo.body2"><b>Redirect URI:</b> <code>@_callbackUrl</code></MudText>
                    </MudStack>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Edit" OnClick="Configure">Edit</MudButton>
                    <MudButton Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="CopyInvite">Copy Invite Link</MudButton>
                    <MudSpacer />
                    <MudButton Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="Delete">Delete</MudButton>
                </MudCardActions>
            </MudCard>
        }

        <MudDivider Class="my-6" />

        @* Deployment shared application: one Open API app all users authorize through (white-label). *@
        <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">
            Optionally configure a single deployment-wide cTrader Open API application. When set, every user
            (including you) authorizes their accounts through it and the per-user application option is removed.
        </MudText>
        <MudCard Class="mb-4">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.subtitle1">Deployment shared application</MudText>
                    @if (_sharedConfigured)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">Configured</MudChip>
                    }
                </MudStack>
                @if (_sharedConfigured)
                {
                    <MudText Typo="Typo.body2"><b>Name:</b> @_sharedName</MudText>
                    <MudText Typo="Typo.body2"><b>Client ID:</b> @_sharedClientId</MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        No shared application configured. Users manage their own Open API application until you add one.
                    </MudText>
                }
                <MudTextField T="string" Value="@_redirectUrl" ReadOnly="true"
                              Label="Redirect URI (register this in cTrader)"
                              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                              AdornmentAriaLabel="Copy redirect URI"
                              OnAdornmentClick="CopyRedirect" Class="mt-2" />
            </MudCardContent>
            <MudCardActions>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Edit"
                           OnClick="ConfigureShared">@(_sharedConfigured ? "Edit" : "Add Shared Application")</MudButton>
                @if (_sharedConfigured)
                {
                    <MudSpacer />
                    <MudButton Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteShared">Delete</MudButton>
                }
            </MudCardActions>
        </MudCard>

        @* Per-message-type client rate limits (matches the cTrader Open API docs). 0 = unlimited. *@
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1" Class="mb-1">Client rate limits (per message type)</MudText>
                <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">
                    Outbound messages per second, per connection. Raise these if your broker negotiated higher
                    cTrader limits, or set 0 to disable pacing (unlimited).
                </MudText>
                <MudNumericField @bind-Value="_rateGeneral" Label="General (msgs/sec, 0 = unlimited)"
                                 Min="0" Class="mb-2" />
                <MudNumericField @bind-Value="_rateHistorical" Label="Historical data (msgs/sec, 0 = unlimited)"
                                 Min="0" Class="mb-2" />
            </MudCardContent>
            <MudCardActions>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save"
                           OnClick="SaveRateLimits">Save rate limits</MudButton>
            </MudCardActions>
        </MudCard>
    }
    else if (_sharedMode)
    {
        @* Normal user under shared-mode: no per-user app, just authorize through the provider's shared app. *@
        <MudPaper Class="pa-6" Elevation="0" Outlined="true">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Large" Color="Color.Success" />
                <MudText Typo="Typo.subtitle1">Open API is managed by your provider</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary">
                    You don't need to register your own Open API application. Authorize your cTrader accounts
                    through the provider's shared application.
                </MudText>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Link"
                           OnClick="Authorize">Authorize accounts</MudButton>
                <MudButton Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="CopyInvite">Copy Invite Link</MudButton>
            </MudStack>
        </MudPaper>
    }
    else if (!_configured)
    {
        <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">
            Configure a single cTrader Open API application, then authorize your cIDs to add their trading accounts.
        </MudText>
        <MudPaper Class="pa-6" Elevation="0" Outlined="true">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.Api" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.subtitle1">No Open API application configured</MudText>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
                           OnClick="Configure">Add Application</MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudCard>
            <MudCardContent>
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.subtitle1">@_name</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">Configured</MudChip>
                    </MudStack>
                    <MudText Typo="Typo.body2"><b>Client ID:</b> @_clientId</MudText>
                    <MudText Typo="Typo.body2"><b>Redirect URI:</b> <code>@_callbackUrl</code></MudText>
                </MudStack>
            </MudCardContent>
            <MudCardActions>
                <MudButton Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Edit" OnClick="Configure">Edit</MudButton>
                <MudButton Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="CopyInvite">Copy Invite Link</MudButton>
                <MudSpacer />
                <MudButton Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="Delete">Delete</MudButton>
            </MudCardActions>
        </MudCard>
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _isOwner;
    private bool _sharedMode;
    private bool _configured;
    private string _name = "";
    private string _clientId = "";
    private string _callbackUrl = "";
    private int _authorizedAccountCount;

    private bool _sharedConfigured;
    private string _sharedName = "";
    private string _sharedClientId = "";
    private string _redirectUrl = "";
    private int _rateGeneral;
    private int _rateHistorical;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _isOwner = state.User.IsInRole("Owner");
        }
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        try
        {
            var res = await Http.GetDynamicAsync("/api/openapi/application");
            if (res is not null)
            {
                _configured = (bool)res.configured;
                _sharedMode = (bool)res.sharedMode;
                _callbackUrl = (string)res.callbackUrl;
                _authorizedAccountCount = (int)res.authorizedAccountCount;
                if (_configured)
                {
                    _name = (string)res.name;
                    _clientId = (string)res.clientId;
                }
            }
            if (_isOwner) await LoadOwner();
        }
        catch
        {
            // Open API feature gated off/unavailable — show the empty state instead of crashing.
        }
        _loading = false;
    }

    private async Task LoadOwner()
    {
        var shared = await Http.GetDynamicAsync("/api/openapi/shared");
        if (shared is not null)
        {
            _sharedConfigured = (bool)shared.configured;
            _redirectUrl = (string)shared.redirectUrl;
            if (_sharedConfigured)
            {
                _sharedName = (string)shared.name;
                _sharedClientId = (string)shared.clientId;
            }
        }
        var rates = await Http.GetFromJsonAsync<Dictionary<string, int>>("/api/openapi/shared/rate-limits");
        if (rates is not null)
        {
            _rateGeneral = rates.GetValueOrDefault("General");
            _rateHistorical = rates.GetValueOrDefault("HistoricalData");
        }
    }

    private async Task Configure()
    {
        var parameters = new DialogParameters
        {
            { nameof(OpenApiAppDialog.IsEdit), _configured },
            { nameof(OpenApiAppDialog.CallbackUrl), _callbackUrl },
            { nameof(OpenApiAppDialog.Name), _configured ? _name : null },
            { nameof(OpenApiAppDialog.ClientId), _configured ? _clientId : null },
            { nameof(OpenApiAppDialog.AuthorizedAccountCount), _authorizedAccountCount },
        };
        var dlg = await Dialogs.ShowAsync<OpenApiAppDialog>(null,
            parameters, new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (OpenApiAppDialog.OpenApiAppDialogResult)res.Data!;
        var r = await Http.PutAsJsonAsync("/api/openapi/application",
            new { data.Name, data.ClientId, data.ClientSecret });
        Snack.Add(r.IsSuccessStatusCode ? "Application saved" : "Failed to save application",
            r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        if (r.IsSuccessStatusCode) await Load();
    }

    private async Task ConfigureShared()
    {
        var parameters = new DialogParameters
        {
            { nameof(OpenApiAppDialog.IsEdit), _sharedConfigured },
            { nameof(OpenApiAppDialog.CallbackUrl), _redirectUrl },
            { nameof(OpenApiAppDialog.Name), _sharedConfigured ? _sharedName : "Shared Open API Application" },
            { nameof(OpenApiAppDialog.ClientId), _sharedConfigured ? _sharedClientId : null },
            { nameof(OpenApiAppDialog.AuthorizedAccountCount), _authorizedAccountCount },
        };
        var dlg = await Dialogs.ShowAsync<OpenApiAppDialog>(null,
            parameters, new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (OpenApiAppDialog.OpenApiAppDialogResult)res.Data!;
        var r = await Http.PutAsJsonAsync("/api/openapi/shared",
            new { data.Name, data.ClientId, data.ClientSecret });
        Snack.Add(r.IsSuccessStatusCode ? "Shared application saved" : "Failed to save shared application",
            r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        if (r.IsSuccessStatusCode) await Load();
    }

    private async Task DeleteShared()
    {
        var r = await Http.DeleteAsync("/api/openapi/shared");
        if (r.IsSuccessStatusCode) { Snack.Add("Shared application deleted", Severity.Success); await Load(); }
        else Snack.Add("Failed to delete shared application", Severity.Error);
    }

    private async Task SaveRateLimits()
    {
        var ok = true;
        ok &= (await Http.PutAsJsonAsync("/api/openapi/shared/rate-limits",
            new { Category = "General", Value = _rateGeneral })).IsSuccessStatusCode;
        ok &= (await Http.PutAsJsonAsync("/api/openapi/shared/rate-limits",
            new { Category = "HistoricalData", Value = _rateHistorical })).IsSuccessStatusCode;
        Snack.Add(ok ? "Rate limits saved" : "Failed to save rate limits", ok ? Severity.Success : Severity.Error);
    }

    private async Task CopyRedirect()
    {
        if (string.IsNullOrEmpty(_redirectUrl)) return;
        try { await JS.InvokeVoidAsync("copyToClipboard", _redirectUrl); Snack.Add("Redirect URI copied", Severity.Success); }
        catch { Snack.Add($"Redirect URI: {_redirectUrl}", Severity.Info); }
    }

    private void Authorize() => Nav.NavigateTo("/api/openapi/authorize", forceLoad: true);

    private async Task CopyInvite()
    {
        var r = await Http.PostAsync("/api/openapi/application/invite", null);
        if (!r.IsSuccessStatusCode) { Snack.Add("Failed to create invite", Severity.Error); return; }
        using var doc = JsonDocument.Parse(await r.Content.ReadAsStringAsync());
        var url = doc.RootElement.GetProperty("url").GetString();
        if (string.IsNullOrEmpty(url)) { Snack.Add("Failed to create invite", Severity.Error); return; }
        try
        {
            await JS.InvokeVoidAsync("copyToClipboard", url);
            Snack.Add("Invite link copied to clipboard", Severity.Success);
        }
        catch
        {
            // Clipboard access can be denied (permissions / insecure context) — don't lose the link.
            Snack.Add($"Couldn't access the clipboard. Invite link: {url}", Severity.Info);
        }
    }

    private async Task Delete()
    {
        var r = await Http.DeleteAsync("/api/openapi/application");
        if (r.IsSuccessStatusCode) { Snack.Add("Application deleted", Severity.Success); await Load(); }
        else Snack.Add("Failed to delete application", Severity.Error);
    }
}
