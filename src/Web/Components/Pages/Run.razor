@page "/run"
@using Web.Components.Dialogs
@using Web.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs

<PageTitle>Run</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Run cBot</MudText>
    <MudSpacer />
    <MudTooltip Text="@(_hasAccounts ? "Run a cBot on a trading account" : "Add a cTrader trading account first")">
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="@(!_hasAccounts)"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNew" data-testid="run-new">
            Run New cBot
        </MudButton>
    </MudTooltip>
</MudStack>

@if (!_hasAccounts)
{
    <MudAlert Severity="Severity.Info" Class="mb-3" data-testid="run-no-accounts">
        Add a cTrader trading account before running a cBot — a run needs an account to connect to.
        <MudLink Href="/accounts" Class="ml-1">Add a trading account</MudLink>
    </MudAlert>
}

<MudText Typo="Typo.h6" Class="mt-4">Instances</MudText>
<InstanceTable @ref="_table" Type="Run" />

@code {
    private bool _hasAccounts;
    private InstanceTable? _table;

    protected override async Task OnInitializedAsync()
    {
        try { _hasAccounts = (await Http.GetDynamicArrayAsync("/api/accounts/")).Length > 0; }
        catch { _hasAccounts = false; }
    }

    private async Task OpenNew()
    {
        if (!_hasAccounts)
        {
            Snack.Add("Add a trading account before running a cBot", Severity.Warning);
            return;
        }
        var dlg = await Dialogs.ShowAsync<RunDialog>("Run cBot",
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (RunDialog.RunDialogResult)res.Data!;
        var r = await Http.PostAsJsonAsync("/api/instances/", new
        {
            data.CBotId, data.TradingAccountId, data.Symbol, data.Timeframe,
            data.ParamSetId, DockerImageTag = data.Image, Type = "Run"
        });
        Snack.Add(r.IsSuccessStatusCode ? "Started" : "Failed", r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        if (r.IsSuccessStatusCode && _table is not null) await _table.RefreshAsync();
    }
}
