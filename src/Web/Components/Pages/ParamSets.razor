@page "/paramsets"
@using Web.Json
@using Web.Components.Dialogs
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs

<PageTitle>Parameter Sets</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Parameter Sets</MudText>
    <MudSpacer />
    <MudButton Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNew">
        New Parameter Set
    </MudButton>
</MudStack>

<MudTable Items="FilteredItems" Class="mt-3" Dense="true" Hover="true">
    <ToolBarContent>
        <MudSelect T="Guid?" @bind-Value="_filterCbotId" Label="Filter by cBot" Clearable="true"
                   Dense="true" Class="mt-0" Style="max-width:260px;">
            @foreach (var c in _cbots) { <MudSelectItem T="Guid?" Value="@((Guid?)c.id)">@c.name</MudSelectItem> }
        </MudSelect>
        <MudSpacer />
        <MudTextField @bind-Value="_search" Placeholder="Search" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                      Immediate="true" Class="mt-0" Style="max-width:260px;" />
    </ToolBarContent>
    <HeaderContent><MudTh>Name</MudTh><MudTh>cBot</MudTh><MudTh /></HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.name</MudTd>
        <MudTd DataLabel="cBot">@context.cBotName</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => Edit((Guid)context.id))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => Delete((Guid)context.id))" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent><MudText>No parameter sets.</MudText></NoRecordsContent>
</MudTable>

@code {
    private dynamic[] _cbots = [], _items = [];
    private Guid? _filterCbotId;
    private string _search = "";

    private IEnumerable<dynamic> FilteredItems => _items.Where(i =>
        (_filterCbotId is null || (Guid)i.cBotId == _filterCbotId)
        && (string.IsNullOrWhiteSpace(_search)
            || ((string)i.name).Contains(_search, StringComparison.OrdinalIgnoreCase)
            || ((string?)i.cBotName ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        _cbots = await Http.GetDynamicArrayAsync("/api/cbots/");
        await LoadItems();
    }

    private async Task LoadItems() =>
        _items = await Http.GetDynamicArrayAsync("/api/paramsets");

    private async Task OpenNew()
    {
        var cbots = _cbots.Select(c => new ParamSetDialog.CBotOption((Guid)c.id, (string)c.name)).ToList();
        var res = await ShowDialogAsync(null, null, cbots, _filterCbotId);
        if (res is null) return;
        await Save(null, res.CBotId, res.Name, res.Json);
    }

    private async Task<ParamSetDialog.ParamSetDialogResult?> ShowDialogAsync(
        string? name, string? json, IReadOnlyList<ParamSetDialog.CBotOption> cbots, Guid? cbotId)
    {
        var parameters = new DialogParameters<ParamSetDialog>
        {
            { x => x.Name, name },
            { x => x.Json, json },
            { x => x.IsEdit, name is not null },
            { x => x.CBots, cbots },
            { x => x.CBotId, cbotId }
        };
        var dlg = await Dialogs.ShowAsync<ParamSetDialog>(name is null ? "New Parameter Set" : "Edit Parameter Set",
            parameters, new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return null;
        return (ParamSetDialog.ParamSetDialogResult)res.Data!;
    }

    private async Task Save(Guid? id, Guid? cbotId, string name, string json)
    {
        if (cbotId is null) return;
        if (!IsNonEmptyJson(json)) { Snack.Add("Content cannot be empty", Severity.Error); return; }

        var url = id is null ? "/api/paramsets" : $"/api/paramsets/{id}";
        var method = id is null ? HttpMethod.Post : HttpMethod.Put;
        var req = new HttpRequestMessage(method, url)
        {
            Content = JsonContent.Create(new { CBotId = cbotId, Name = name, JsonContent = json })
        };
        var r = await Http.SendAsync(req);
        Snack.Add(r.IsSuccessStatusCode ? "Saved" : "Failed", r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        await LoadItems();
    }

    private static bool IsNonEmptyJson(string content)
    {
        if (string.IsNullOrWhiteSpace(content)) return false;
        System.Text.Json.JsonDocument doc;
        try { doc = System.Text.Json.JsonDocument.Parse(content); }
        catch { return false; }
        using (doc)
        {
            return doc.RootElement.ValueKind switch
            {
                System.Text.Json.JsonValueKind.Object => doc.RootElement.EnumerateObject().Any(),
                System.Text.Json.JsonValueKind.Array => doc.RootElement.EnumerateArray().Any(),
                _ => true
            };
        }
    }

    private async Task Edit(Guid id)
    {
        var p = await Http.GetDynamicAsync($"/api/paramsets/{id}");
        if (p is null) return;
        var res = await ShowDialogAsync((string?)p.name ?? "", (string?)p.jsonContent ?? "{}", [], (Guid)p.cBotId);
        if (res is null) return;
        await Save(id, (Guid)p.cBotId, res.Name, res.Json);
    }

    private async Task Delete(Guid id) { await Http.DeleteAsync($"/api/paramsets/{id}"); await LoadItems(); }
}
