@page "/mcp"
@using Web.Json
@using Web.Components.Dialogs
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs

<PageTitle>MCP Keys</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">MCP API Keys</MudText>
    <HelpTip Text="Bearer tokens (mcpk_…) that let AI clients call this app's MCP server tools on your behalf. The full key is shown once at creation — copy it then. Revoke anytime." />
    <MudSpacer />
    <MudButton Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNew">
        New Key
    </MudButton>
</MudStack>

<AiFeatureNotice />

<MudTable Items="_items" Class="mt-3" Dense="true" Breakpoint="Breakpoint.Sm">
    <HeaderContent><MudTh>Label</MudTh><MudTh>Prefix</MudTh><MudTh>Last used</MudTh><MudTh /></HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Label">@context.label</MudTd>
        <MudTd DataLabel="Prefix">@context.keyPrefix</MudTd>
        <MudTd DataLabel="Last used">@((string?)(context.lastUsedAt?.ToString()) ?? "—")</MudTd>
        <MudTd DataLabel=""><MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" aria-label="Revoke key" OnClick="@(() => Revoke((Guid)context.id))" /></MudTd>
    </RowTemplate>
</MudTable>

@code {
    private dynamic[] _items = [];

    protected override Task OnInitializedAsync() => Load();
    private async Task Load() => _items = await Http.GetDynamicArrayAsync("/api/mcp-keys/");

    private async Task OpenNew()
    {
        var dlg = await Dialogs.ShowAsync<NewMcpKeyDialog>("New MCP Key",
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (NewMcpKeyDialog.NewMcpKeyDialogResult)res.Data!;
        var r = await Http.PostAsJsonAsync("/api/mcp-keys/", new { data.Label });
        if (r.IsSuccessStatusCode)
        {
            var d = await r.Content.ReadFromJsonAsync<TokenResponse>();
            await Load();
            if (!string.IsNullOrEmpty(d?.Token))
            {
                await Dialogs.ShowAsync<McpKeyCreatedDialog>("MCP Key Created",
                    new DialogParameters<McpKeyCreatedDialog> { { x => x.Key, d.Token } },
                    new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
            }
        }
        else Snack.Add("Failed", Severity.Error);
    }

    private async Task Revoke(Guid id) { await Http.DeleteAsync($"/api/mcp-keys/{id}"); await Load(); }

    private sealed record TokenResponse(string Token);
}
