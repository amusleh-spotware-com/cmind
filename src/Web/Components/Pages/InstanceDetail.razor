@page "/instance/{Id:guid}"
@using Web.Json
@using Core
@using Core.Calendar
@using Core.Features
@using Core.Options
@using Microsoft.Extensions.Options
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using Web.Hubs
@using ApexCharts
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http
@inject NavigationManager Nav
@inject ISnackbar Snack
@inject IJSRuntime JS
@inject IStringLocalizer<Ui> L
@inject IEconomicCalendar Calendar
@inject IFeatureGate Gate
@inject IOptionsMonitor<AppOptions> Options
@inject LogHubConnectionFactory HubFactory
@implements IAsyncDisposable

<PageTitle>Instance</PageTitle>

<div class="instance-detail-page">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudTooltip Text="Back">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="Back"
                           aria-label="Back" data-testid="instance-back-btn" />
        </MudTooltip>
        <MudText Typo="Typo.h5">@(_detail is not null ? $"{_detail.symbol} — {_detail.status}" : L["instance.title"])</MudText>
        @if (_detail is not null)
        {
            <MudChip T="string" Size="MudBlazor.Size.Small" Color="@StatusColor((string)_detail.status)">@_detail.status</MudChip>
        }
        <MudSpacer />
        @if (_detail is not null && IsActive)
        {
            <MudTooltip Text="Stop instance">
                <MudIconButton Icon="@Icons.Material.Filled.Stop" Color="MudBlazor.Color.Warning"
                               Disabled="_stopping" OnClick="StopAsync"
                               aria-label="Stop instance" data-testid="instance-detail-stop" />
            </MudTooltip>
        }
        else if (_detail is not null && IsTerminalStatus)
        {
            <MudTooltip Text="Start instance again">
                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Color="MudBlazor.Color.Success"
                               Disabled="_startingInstance" OnClick="StartAsync"
                               aria-label="Start instance" data-testid="instance-detail-start" />
            </MudTooltip>
        }
    </MudStack>

    @if (_loaded && _detail is null)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-3" data-testid="instance-not-found">
            @L["instance.notFound"]
            <MudButton Class="ms-2" Size="MudBlazor.Size.Small" Variant="Variant.Filled" Color="MudBlazor.Color.Primary"
                       OnClick="Back" data-testid="instance-back">@L["instance.back"]</MudButton>
        </MudAlert>
    }

    @if (_detail is not null)
    {
        <MudPaper Class="pa-2 mb-2 flex-none">
            <MudText Typo="Typo.body2">Symbol: @_detail.symbol &nbsp;·&nbsp; TF: @_detail.timeframe</MudText>
        </MudPaper>

        @if (_isBacktest && _equity.Count > 0)
        {
            <div class="flex-none instance-chart">
                <ApexChart TItem="EquityPoint" Title="Equity curve" Options="_chartOptions" Height="220">
                    <ApexPointSeries TItem="EquityPoint" Items="_equity" Name="Equity"
                                     XValue="@(p => p.Ts)" YValue="@(p => (decimal)p.Value)" SeriesType="SeriesType.Line" />
                </ApexChart>

                @if (_calendarEvents.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">@L["calendar.backtestEvents"]</MudText>
                    <MudStack Spacing="1" data-testid="backtest-calendar-events">
                        @foreach (var e in _calendarEvents)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary"><UserTime Value="e.EffectiveAt" Format="g" /></MudText>
                                <MudChip T="string" Size="MudBlazor.Size.Small" Color="@ImpactColor(e.Impact)">@e.SeriesCode</MudChip>
                            </MudStack>
                        }
                    </MudStack>
                }
            </div>
        }

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1 flex-none">
            <MudText Typo="Typo.overline">Logs</MudText>
            <MudSpacer />
            <MudSwitch T="bool" @bind-Value="_autoScroll" Color="MudBlazor.Color.Primary" Size="MudBlazor.Size.Small"
                       Label="Auto-scroll" data-testid="logs-autoscroll" />
            <MudTooltip Text="@(_logs.Count > 0 ? "Download logs" : "No logs yet")">
                <MudIconButton Icon="@Icons.Material.Filled.Download" Size="MudBlazor.Size.Small"
                               Disabled="@(_logs.Count == 0)" OnClick="DownloadLogsAsync"
                               aria-label="Download logs" data-testid="instance-detail-logs-download" />
            </MudTooltip>
        </MudStack>

        <MudPaper id="@LogsElementId" Class="instance-logs pa-2">
            @foreach (var l in _logs) { <div>@l</div> }
        </MudPaper>
    }
</div>

<style>
    .instance-detail-page { display: flex; flex-direction: column; height: calc(100vh - 90px); }
    .instance-detail-page .flex-none { flex: 0 0 auto; }
    /* Cap the equity chart so it never pushes the logs panel off-screen — it scrolls within its own box. */
    .instance-chart { max-height: 38vh; overflow: auto; }
    .instance-logs {
        flex: 1 1 auto; min-height: 120px; overflow: auto;
        background: #0E1218; color: #E6E8EC;
        font-family: 'Consolas', 'Courier New', monospace; font-size: 12px;
        white-space: pre-wrap; word-break: break-all;
    }
</style>

@code {
    [Parameter] public Guid Id { get; set; }
    private const string LogsElementId = "instance-detail-logs";
    private dynamic? _detail;
    private bool _loaded;
    private bool _isBacktest;
    private bool _autoScroll = true;
    private bool _stopping;
    private bool _startingInstance;
    private List<string> _logs = new();
    private List<EquityPoint> _equity = new();
    private List<CalendarEventView> _calendarEvents = new();
    private HubConnection? _hub;
    // The instance id changes on every TPH transition; track the current one plus a stable lineage key
    // (cBot + CreatedAt is preserved across transitions) so the page can follow the instance as it runs.
    private Guid _currentId;
    private Guid? _lineageCbotId;
    private DateTimeOffset? _lineageCreatedAt;
    private CancellationTokenSource? _pollCts;
    private readonly ApexChartOptions<EquityPoint> _chartOptions = new();

    // Configure the equity chart before first render (see DashActivityChart for the ApexCharts init gotcha):
    // a fixed height and a compact, integer Y axis with few ticks so the axis labels stay narrow and the
    // chart never needs its own scrollbars.
    protected override void OnInitialized()
    {
        _chartOptions.Chart = new Chart
        {
            Toolbar = new Toolbar { Show = false },
            Background = "transparent",
            Animations = new Animations { Enabled = false },
            FontFamily = "Inter, sans-serif"
        };
        _chartOptions.Theme = new ApexCharts.Theme { Mode = Mode.Dark };
        _chartOptions.Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 };
        _chartOptions.DataLabels = new DataLabels { Enabled = false };
        _chartOptions.Xaxis = new XAxis { Type = XAxisType.Datetime };
        _chartOptions.Yaxis =
        [
            new YAxis
            {
                DecimalsInFloat = 0,
                TickAmount = 5,
                Labels = new YAxisLabels
                {
                    Formatter = "function (val) { return val == null ? '' : Math.round(val).toLocaleString(); }"
                }
            }
        ];
    }

    private bool IsActive => _detail is not null
        && ((string)_detail.status) is "Running" or "Starting" or "Stopping";

    private bool IsTerminalStatus => _detail is not null
        && ((string)_detail.status) is "Stopped" or "Completed" or "Failed";

    public record EquityPoint(DateTime Ts, double Value);

    private async Task Back()
    {
        // When the instance loaded, route to the matching list; when it is missing/transitioned (kind
        // unknown), go back to wherever the user came from (run or backtest list) instead of always /run.
        if (_detail is not null) Nav.NavigateTo(_isBacktest ? "/backtest" : "/run");
        else await JS.InvokeVoidAsync("history.back");
    }

    private async Task StopAsync()
    {
        _stopping = true;
        Snack.Add("Stopping instance…", Severity.Info);
        StateHasChanged();
        try
        {
            var r = await Http.PostAsync($"/api/instances/{_currentId}/stop", null);
            Snack.Add(r.IsSuccessStatusCode ? "Instance stopped" : "Stop failed",
                r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
            await RefreshFromCurrentAsync();
        }
        finally { _stopping = false; }
    }

    private async Task StartAsync()
    {
        _startingInstance = true;
        Snack.Add("Starting instance…", Severity.Info);
        StateHasChanged();
        try
        {
            var r = await Http.PostAsync($"/api/instances/{_currentId}/start", null);
            if (!r.IsSuccessStatusCode) { Snack.Add("Start failed", Severity.Error); return; }
            Snack.Add("Instance started", Severity.Success);
            // Restart creates a NEW instance — navigate to it.
            var started = await r.Content.ReadFromJsonAsync<StartResponse>();
            if (started is not null) Nav.NavigateTo($"/instance/{started.Id}");
        }
        finally { _startingInstance = false; }
    }

    private sealed record StartResponse(Guid Id);

    private async Task DownloadLogsAsync()
    {
        try
        {
            var text = await Http.GetStringAsync($"/api/instances/{_currentId}/logs");
            await JS.InvokeVoidAsync("appDownloadText", $"instance-{_currentId:N}.log", text);
        }
        catch
        {
            Snack.Add("No logs available for this instance", Severity.Warning);
        }
    }

    private static MudBlazor.Color StatusColor(string status) => status switch
    {
        "Running" => MudBlazor.Color.Success,
        "Completed" or "Stopped" => MudBlazor.Color.Default,
        "Failed" => MudBlazor.Color.Error,
        _ => MudBlazor.Color.Info
    };

    protected override async Task OnInitializedAsync()
    {
        dynamic? detail = null;
        try { detail = await Http.GetDynamicAsync($"/api/instances/{Id}"); }
        catch { detail = null; }
        _loaded = true;
        if (detail is null) return;
        ApplyDetail(detail);

        await LoadCalendarOverlayAsync();

        // For a terminal instance the container is gone, so seed the persisted console log (last run) — it
        // stays viewable and downloadable. An active instance streams its logs live below instead.
        if (!IsActive) await SeedPersistedLogsAsync();

        await StartLogStreamAsync();
        StartPolling();
    }

    // Applies a fetched instance-detail payload: current id, kind, lineage key (captured once) and the
    // equity curve (re-parsed so a backtest's chart appears once it completes).
    private void ApplyDetail(dynamic detail)
    {
        _detail = detail;
        _currentId = (Guid)detail.id;
        _isBacktest = (string)detail.kind == "Backtest";
        _lineageCbotId ??= (Guid)detail.cBotId;
        _lineageCreatedAt ??= (DateTimeOffset)detail.createdAt;

        var points = new List<EquityPoint>();
        if (_isBacktest && detail.equity is not null)
            foreach (var p in detail.equity)
                points.Add(new EquityPoint(((DateTimeOffset)p.timestamp).UtcDateTime, (double)p.value));
        _equity = points;
    }

    private async Task SeedPersistedLogsAsync()
    {
        try
        {
            var persisted = await Http.GetStringAsync($"/api/instances/{_currentId}/logs");
            if (!string.IsNullOrEmpty(persisted))
                _logs = persisted.Replace("\r\n", "\n").Split('\n').TakeLast(500).ToList();
        }
        catch { /* no persisted logs for this instance */ }
    }

    private async Task StartLogStreamAsync()
    {
        try
        {
            _hub = HubFactory.Create();
            await _hub.StartAsync();
        }
        catch
        {
            _hub = null;
            return;
        }

        var stream = _hub.StreamAsync<string>("Tail", _currentId);
        // Stream errors (a terminal instance whose container is gone, a docker error, a dropped connection)
        // must never bubble out of this background task and tear down the Blazor circuit.
        _ = Task.Run(async () =>
        {
            try
            {
                await foreach (var line in stream)
                {
                    _logs.Add(line);
                    if (_logs.Count > 500) _logs.RemoveAt(0);
                    await InvokeAsync(async () =>
                    {
                        StateHasChanged();
                        if (_autoScroll)
                        {
                            try { await JS.InvokeVoidAsync("appScrollToEnd", LogsElementId); }
                            catch { /* JS unavailable (e.g. prerender) — ignore */ }
                        }
                    });
                }
            }
            catch { /* log stream ended or failed — nothing to tail */ }
        });
    }

    // Follow the instance across TPH transitions: poll the lineage until it reaches a terminal state, then
    // stop. Keeps the status chip, Stop/Start button and equity curve current without a manual refresh.
    private void StartPolling()
    {
        _pollCts = new CancellationTokenSource();
        var ct = _pollCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                while (!ct.IsCancellationRequested && !IsTerminalStatus
                       && _lineageCbotId is { } cbid && _lineageCreatedAt is { } cat)
                {
                    await Task.Delay(TimeSpan.FromSeconds(4), ct);
                    dynamic? current = null;
                    try { current = await Http.GetDynamicAsync(CurrentUrl(cbid, cat)); }
                    catch { current = null; }
                    if (current is null) continue;
                    var wasActive = IsActive;
                    await InvokeAsync(async () =>
                    {
                        ApplyDetail(current);
                        await LoadCalendarOverlayAsync();
                        if (wasActive && IsTerminalStatus) await SeedPersistedLogsAsync();
                        StateHasChanged();
                    });
                }
            }
            catch (OperationCanceledException) { /* disposed */ }
            catch { /* transient — polling ends */ }
        });
    }

    private async Task RefreshFromCurrentAsync()
    {
        if (_lineageCbotId is not { } cbid || _lineageCreatedAt is not { } cat) return;
        try
        {
            var wasActive = IsActive;
            var current = await Http.GetDynamicAsync(CurrentUrl(cbid, cat));
            if (current is not null)
            {
                ApplyDetail(current);
                if (wasActive && IsTerminalStatus) await SeedPersistedLogsAsync();
            }
        }
        catch { /* keep prior state */ }
    }

    private static string CurrentUrl(Guid cbotId, DateTimeOffset createdAt) =>
        $"/api/instances/current?cbotId={cbotId}&createdAt={Uri.EscapeDataString(createdAt.ToString("O"))}";

    // Point-in-time-correct economic-event overlay: the high-impact releases affecting the backtested
    // symbol that fell inside the backtest window (no look-ahead — asOf is the window end).
    private async Task LoadCalendarOverlayAsync()
    {
        if (!_isBacktest || _equity.Count == 0
            || !CalendarEnablement.IsEnabled(Options.CurrentValue.Branding, Gate)
            || _detail?.symbol is not { } symbolValue)
            return;

        try
        {
            var symbol = new Symbol((string)symbolValue);
            var from = new DateTimeOffset(_equity.Min(p => p.Ts), TimeSpan.Zero);
            var to = new DateTimeOffset(_equity.Max(p => p.Ts), TimeSpan.Zero);
            var events = await Calendar.GetEventsForSymbolAsync(symbol, from, to, to, CancellationToken.None);
            _calendarEvents = events.Where(e => e.Impact >= ImpactLevel.High).ToList();
        }
        catch
        {
            _calendarEvents = [];
        }
    }

    private static MudBlazor.Color ImpactColor(ImpactLevel level) => level switch
    {
        ImpactLevel.Critical => MudBlazor.Color.Error,
        ImpactLevel.High => MudBlazor.Color.Warning,
        _ => MudBlazor.Color.Default
    };

    public async ValueTask DisposeAsync()
    {
        try { _pollCts?.Cancel(); } catch { /* already disposed */ }
        _pollCts?.Dispose();
        if (_hub is not null) await _hub.DisposeAsync();
    }
}
