@* Copy-profile detail as a dialog: manage the destination (slave) accounts of a profile — list, remove,
   and add with the full copy settings. Account identity is shown as the human account number, never the
   internal GUID. Opened from the Copy Trading page when a profile row is clicked. *@
@using System.Net.Http.Json
@using Core.Domain
@using Web.Components.Copy
@using Web.Json
@inject HttpClient Http
@inject ISnackbar Snack

<MudDialog Class="copy-profile-dialog">
    <TitleContent>
        <MudText Typo="Typo.h6">Destinations — @Name</MudText>
    </TitleContent>
    <DialogContent>
        @if (_detail is null)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudTable Items="@(((IEnumerable<dynamic>)_detail.destinations))" Dense="true" Class="mb-3" Breakpoint="Breakpoint.Sm"
                      data-testid="copy-destinations">
                <HeaderContent>
                    <MudTh>Account</MudTh><MudTh>Mode</MudTh><MudTh>Param</MudTh><MudTh>Reverse</MudTh><MudTh>Direction</MudTh><MudTh>Partial</MudTh><MudTh>Pending</MudTh><MudTh>Trailing</MudTh><MudTh /></HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Account">@AccountNumber((Guid)context.destinationAccountId)</MudTd>
                    <MudTd DataLabel="Mode">@context.mode</MudTd>
                    <MudTd DataLabel="Param">@context.riskParameter</MudTd>
                    <MudTd DataLabel="Reverse">@YesNo(context.reverse)</MudTd>
                    <MudTd DataLabel="Direction">@context.direction</MudTd>
                    <MudTd DataLabel="Partial">@YesNo(context.mirrorPartialClose)</MudTd>
                    <MudTd DataLabel="Pending">@YesNo(context.copyPendingOrders)</MudTd>
                    <MudTd DataLabel="Trailing">@YesNo(context.copyTrailingStop)</MudTd>
                    <MudTd DataLabel=""><MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                          aria-label="Remove destination" OnClick="@(() => RemoveDestination((Guid)context.id))" /></MudTd>
                </RowTemplate>
            </MudTable>

            <MudText Typo="Typo.subtitle2">Add destination</MudText>
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudSelect T="long" MultiSelection="true" @bind-SelectedValues="_destAccounts" Class="flex-grow-1"
                                   Label="Destination (slave) accounts"
                                   MultiSelectionTextFunc="@(v => $"{v?.Count ?? 0} account(s)")">
                            @foreach (var a in Accounts)
                            {
                                <MudSelectItem T="long" Value="@a.Number">@a.Number</MudSelectItem>
                            }
                        </MudSelect>
                        <HelpTip Text="One or more destination (slave) accounts to add, each with the settings below." />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudSelect T="MoneyManagementMode" @bind-Value="_mode" Label="Money management" Class="flex-grow-1">
                            @foreach (var m in Enum.GetValues<MoneyManagementMode>())
                            {
                                <MudSelectItem T="MoneyManagementMode" Value="@m">@m</MudSelectItem>
                            }
                        </MudSelect>
                        <HelpTip Text="How each copied trade is sized relative to the master: a fixed lot, a multiplier, a proportion of balance/equity, or a fixed risk percent." />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudNumericField T="double" @bind-Value="_param" Label="Parameter" Class="flex-grow-1" />
                        <HelpTip Text="The number the sizing mode uses — e.g. the multiplier (1 = same size) or the risk percent." />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudNumericField T="double" @bind-Value="_slippage" Label="Slippage (pips)" Class="flex-grow-1" />
                        <HelpTip Text="Maximum price deviation, in pips, tolerated when placing the copied order before it is rejected." />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudSelect T="CopyDirectionFilter" @bind-Value="_direction" Label="Direction" Class="flex-grow-1">
                            @foreach (var d in Enum.GetValues<CopyDirectionFilter>())
                            {
                                <MudSelectItem T="CopyDirectionFilter" Value="@d">@d</MudSelectItem>
                            }
                        </MudSelect>
                        <HelpTip Text="Copy both directions, or only the master's long or only its short trades." />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudNumericField T="double" @bind-Value="_minLot" Label="Min lot" Class="flex-grow-1" />
                        <HelpTip Text="Smallest lot size a copy may use. 0 = no minimum." />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudNumericField T="double" @bind-Value="_maxLot" Label="Max lot" Class="flex-grow-1" />
                        <HelpTip Text="Largest lot size a copy may use. 0 = no maximum." />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudNumericField T="int" @bind-Value="_maxDelay" Label="Max delay (s)" Class="flex-grow-1" />
                        <HelpTip Text="Skip a copy if it can't be placed within this many seconds of the master's fill (stale-price guard). 0 = no limit." />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudNumericField T="double" @bind-Value="_maxDrawdown" Label="Max drawdown %" Class="flex-grow-1" />
                        <HelpTip Text="Pause copying to this destination if its equity drawdown exceeds this percent. 0 = disabled." />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudNumericField T="double" @bind-Value="_dailyLoss" Label="Daily loss cap" Class="flex-grow-1" />
                        <HelpTip Text="Stop copying for the day if the destination's realised loss reaches this amount (deposit currency). 0 = disabled." />
                    </MudStack>
                </MudItem>
                @SwitchTip(_reverse, v => _reverse = v, "Reverse", "Mirror the master's trades in the opposite direction (buy becomes sell).")
                @SwitchTip(_forceMin, v => _forceMin = v, "Force min lot", "If a computed size is below the minimum lot, place the minimum instead of skipping.")
                @SwitchTip(_copyStopLoss, v => _copyStopLoss = v, "Copy SL", "Copy the master's stop-loss onto the destination order.")
                @SwitchTip(_copyTakeProfit, v => _copyTakeProfit = v, "Copy TP", "Copy the master's take-profit onto the destination order.")
                @SwitchTip(_mirrorPartialClose, v => _mirrorPartialClose = v, "Partial close", "When the master partially closes a position, close the same proportion on the destination.")
                @SwitchTip(_mirrorScaleIn, v => _mirrorScaleIn = v, "Scale-in", "When the master adds to a position, add proportionally on the destination.")
                @SwitchTip(_copyPending, v => _copyPending = v, "Pending orders", "Copy the master's pending (limit/stop) orders, not only market fills.")
                @SwitchTip(_copyTrailing, v => _copyTrailing = v, "Trailing stop", "Copy the master's trailing-stop adjustments.")
                @SwitchTip(_copyPendingExpiry, v => _copyPendingExpiry = v, "Copy expiry", "Copy the expiry time of the master's pending orders.")
                @SwitchTip(_copyMasterSlippage, v => _copyMasterSlippage = v, "Copy slippage", "Use the master's own slippage setting instead of the value above.")
                <MudItem xs="12">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.caption">Copy order types</MudText>
                        <HelpTip Text="Which of the master's order types are copied. Disable a type to ignore those orders entirely." />
                    </MudStack>
                </MudItem>
                @SwitchTip(_copyMarket, v => _copyMarket = v, "Market", "Copy market orders.")
                @SwitchTip(_copyMarketRange, v => _copyMarketRange = v, "Market range", "Copy market-range orders.")
                @SwitchTip(_copyLimit, v => _copyLimit = v, "Limit", "Copy limit orders.")
                @SwitchTip(_copyStop, v => _copyStop = v, "Stop", "Copy stop orders.")
                @SwitchTip(_copyStopLimit, v => _copyStopLimit = v, "Stop limit", "Copy stop-limit orders.")
                <MudItem xs="12" md="4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudSelect T="SymbolFilterMode" @bind-Value="_filterMode" Label="Symbol filter" Class="flex-grow-1">
                            @foreach (var f in Enum.GetValues<SymbolFilterMode>())
                            {
                                <MudSelectItem T="SymbolFilterMode" Value="@f">@f</MudSelectItem>
                            }
                        </MudSelect>
                        <HelpTip Text="None = copy every symbol. Whitelist = copy only the listed symbols. Blacklist = copy all except the listed symbols." />
                    </MudStack>
                </MudItem>
                @if (_filterMode != SymbolFilterMode.None)
                {
                    <MudItem xs="12" md="8">
                        <SymbolListEditor Symbols="_filterSymbols" Label="Filter symbols" TestId="copy-dest-filter" />
                    </MudItem>
                }
                <MudItem xs="12">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                        <MudText Typo="Typo.subtitle2">Symbol map</MudText>
                        <HelpTip Text="Translate a master symbol to the destination broker's symbol, with an optional per-symbol volume multiplier. Import or export the whole map as a CSV file." />
                    </MudStack>
                    <SymbolMapEditor Rows="_symbolMap" />
                </MudItem>
                <MudItem xs="12">
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="SuggestSymbols">Suggest broker symbols</MudButton>
                    <HelpTip Text="Load the destination broker's tradable symbols. Click a chip to add it to the symbol filter." />
                    <MudChipSet T="string" Class="mt-1">
                        @foreach (var s in _suggested)
                        {
                            <MudChip T="string" Size="Size.Small" OnClick="@(() => AddSuggested(s))">@s</MudChip>
                        }
                    </MudChipSet>
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AddDestination" data-testid="copy-add-destination">Add destination</MudButton>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance Dialog { get; set; } = default!;
    [Parameter] public Guid ProfileId { get; set; }
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public IReadOnlyList<AccountRef> Accounts { get; set; } = [];

    private dynamic? _detail;

    private IEnumerable<long> _destAccounts = new HashSet<long>();
    private MoneyManagementMode _mode = MoneyManagementMode.LotMultiplier;
    private double _param = 1;
    private double _slippage;
    private CopyDirectionFilter _direction = CopyDirectionFilter.Both;
    private double _minLot;
    private double _maxLot;
    private int _maxDelay;
    private double _maxDrawdown;
    private double _dailyLoss;
    private bool _reverse;
    private bool _forceMin;
    private bool _copyStopLoss = true;
    private bool _copyTakeProfit = true;
    private bool _mirrorPartialClose = true;
    private bool _mirrorScaleIn;
    private bool _copyPending;
    private bool _copyTrailing;
    private bool _copyPendingExpiry = true;
    private bool _copyMasterSlippage = true;
    private bool _copyMarket = true;
    private bool _copyMarketRange = true;
    private bool _copyLimit = true;
    private bool _copyStop = true;
    private bool _copyStopLimit = true;
    private List<SymbolMapRow> _symbolMap = [];
    private List<string> _filterSymbols = [];
    private SymbolFilterMode _filterMode = SymbolFilterMode.None;
    private string[] _suggested = [];

    private RenderFragment SwitchTip(bool value, Action<bool> setter, string label, string tip) => __builder =>
    {
        <MudItem xs="6" sm="4" md="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudSwitch T="bool" Value="value" ValueChanged="@(v => setter(v))" Label="@label" Color="Color.Primary" />
                <HelpTip Text="@tip" />
            </MudStack>
        </MudItem>
    };

    private void AddSuggested(string symbol)
    {
        if (!_filterSymbols.Contains(symbol, StringComparer.OrdinalIgnoreCase))
            _filterSymbols.Add(symbol);
    }

    protected override Task OnInitializedAsync() => Load();

    private async Task Load() => _detail = await Http.GetDynamicAsync($"/api/copy/profiles/{ProfileId}");

    private string AccountNumber(Guid id)
    {
        foreach (var a in Accounts)
            if (a.Id == id) return a.Number.ToString(System.Globalization.CultureInfo.CurrentCulture);
        return "—";
    }

    // Render booleans as human Yes/No, not raw "True"/"False" (C-07).
    private static string YesNo(dynamic value) => (bool)value ? "Yes" : "No";

    private Guid AccountGuid(long number)
    {
        foreach (var a in Accounts)
            if (a.Number == number) return a.Id;
        return Guid.Empty;
    }

    private async Task AddDestination()
    {
        var accounts = _destAccounts.ToArray();
        if (accounts.Length == 0) { Snack.Add("Select at least one destination account", Severity.Warning); return; }

        var failed = false;
        foreach (var number in accounts)
        {
            var r = await Http.PostAsJsonAsync($"/api/copy/profiles/{ProfileId}/destinations", new
            {
                DestinationAccountId = AccountGuid(number),
                Mode = _mode,
                Parameter = _param,
                SlippagePips = _slippage,
                MaxDelaySeconds = _maxDelay,
                Reverse = _reverse,
                CopyStopLoss = _copyStopLoss,
                CopyTakeProfit = _copyTakeProfit,
                Direction = _direction,
                MinLot = _minLot,
                MaxLot = _maxLot,
                ForceMinLot = _forceMin,
                MaxDrawdownPercent = _maxDrawdown,
                DailyLossLimit = _dailyLoss,
                SymbolFilterMode = _filterMode,
                SymbolFilters = _filterSymbols.ToArray(),
                SymbolMap = _symbolMap
                    .Select(m => (object)new { m.Source, m.Destination, VolumeMultiplier = m.VolumeMultiplier })
                    .ToArray(),
                MirrorPartialClose = _mirrorPartialClose,
                MirrorScaleIn = _mirrorScaleIn,
                CopyPendingOrders = _copyPending,
                CopyTrailingStop = _copyTrailing,
                OrderTypes = SelectedOrderTypes(),
                CopyPendingExpiry = _copyPendingExpiry,
                CopyMasterSlippage = _copyMasterSlippage
            });
            if (!r.IsSuccessStatusCode) failed = true;
        }

        if (failed) Snack.Add("Some destinations could not be added", Severity.Error);
        _destAccounts = new HashSet<long>();
        await Load();
    }

    private CopyOrderTypes SelectedOrderTypes()
    {
        var types = CopyOrderTypes.None;
        if (_copyMarket) types |= CopyOrderTypes.Market;
        if (_copyMarketRange) types |= CopyOrderTypes.MarketRange;
        if (_copyLimit) types |= CopyOrderTypes.Limit;
        if (_copyStop) types |= CopyOrderTypes.Stop;
        if (_copyStopLimit) types |= CopyOrderTypes.StopLimit;
        return types == CopyOrderTypes.None ? CopyOrderTypes.All : types;
    }

    private async Task RemoveDestination(Guid destinationId)
    {
        await Http.DeleteAsync($"/api/copy/profiles/{ProfileId}/destinations/{destinationId}");
        await Load();
    }

    private async Task SuggestSymbols()
    {
        var first = _destAccounts.FirstOrDefault();
        if (first == 0) return;
        var guid = AccountGuid(first);
        if (guid == Guid.Empty) return;
        try { _suggested = await Http.GetFromJsonAsync<string[]>($"/api/copy/accounts/{guid}/symbols") ?? []; }
        catch { _suggested = []; }
    }

    private void Close() => Dialog.Close();

    public sealed record AccountRef(Guid Id, long Number);
}
