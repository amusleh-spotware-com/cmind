@using System.Net.Http.Json
@using Web.Json
@inject HttpClient Http
@inject ISnackbar Snack

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" Class="mr-2" />Create cBot task
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">
            Describe a strategy in plain English and pick one or more models. Each model runs as its own
            background task — you can leave this page and come back to the result.
        </MudText>
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudSelect T="string" @bind-Value="_language" Label="Language" Dense="true" data-testid="task-language">
                    <MudSelectItem Value="@("CSharp")">C#</MudSelectItem>
                    <MudSelectItem Value="@("Python")">Python</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_name" Label="Bot name" Placeholder="MyBot" data-testid="task-name" />
            </MudItem>
        </MudGrid>
        <MudSelect T="Guid" MultiSelection="true" @bind-SelectedValues="_selectedModels" Label="Models"
                   ToStringFunc="@ModelLabel" Dense="true" Class="mt-2" data-testid="task-models"
                   HelperText="Pick one or more models — one task is created per model.">
            @foreach (var m in _models)
            {
                <MudSelectItem T="Guid" Value="@m.Id">@ModelLabel(m.Id)</MudSelectItem>
            }
        </MudSelect>
        @if (_models.Count == 0)
        {
            <MudAlert Severity="Severity.Warning" Class="mt-2" data-testid="task-no-models">
                No AI model is configured. Add a provider in Settings → AI first.
            </MudAlert>
        }
        <MudTextField @bind-Value="_description" Label="Describe your strategy" Lines="5" Class="mt-3"
                      Placeholder="e.g. RSI mean-reversion on EURUSD h1, 1.5% risk, ATR stop-loss"
                      data-testid="task-description" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" data-testid="task-cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Bolt"
                   OnClick="Submit" Disabled="_busy" data-testid="task-create-confirm">Create task</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private string _language = "CSharp";
    private string _name = "MyBot";
    private string _description = "";
    private bool _busy;
    private IEnumerable<Guid> _selectedModels = [];
    private List<ModelOption> _models = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var rows = await Http.GetDynamicArrayAsync("/api/ai/usable-models");
            foreach (var r in rows)
                _models.Add(new ModelOption((Guid)r.id, (string)r.model, (string)r.kind, (bool)r.isActive));
        }
        catch
        {
            _models = [];
        }
        // Preselect the active model so a one-model deployment works with no extra clicks.
        var active = _models.FirstOrDefault(m => m.IsActive) ?? _models.FirstOrDefault();
        if (active is not null) _selectedModels = [active.Id];
    }

    private string ModelLabel(Guid id)
    {
        var m = _models.FirstOrDefault(x => x.Id == id);
        return m is null ? "—" : $"{m.Model} ({m.Kind})";
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_description))
        {
            Snack.Add("Describe your strategy first", Severity.Warning);
            return;
        }
        var ids = _selectedModels.ToArray();
        if (ids.Length == 0)
        {
            Snack.Add("Select at least one model", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/ai/tasks",
                new { Name = _name, Language = _language, Description = _description, CredentialIds = ids });
            if (!response.IsSuccessStatusCode)
            {
                Snack.Add("Could not create the task", Severity.Error);
                return;
            }
            Snack.Add(ids.Length > 1 ? $"{ids.Length} tasks created" : "Task created", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch
        {
            Snack.Add("Could not create the task", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed record ModelOption(Guid Id, string Model, string Kind, bool IsActive);
}
