@using System.Globalization
@using Core.Constants
@using Core.Features
@using Web.Components.Pages
@inject IFeatureGate Gate
@inject IStringLocalizer<Ui> L
@inject Web.Time.IUserTimeZone UserZone

@* Full-screen settings surface: a section list on the left, the selected settings panel on the right
   (Claude-settings style), replacing the old nested Settings nav items. Opened from the nav. *@

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center" style="width:100%;">
            <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
            <MudText Typo="Typo.h6">@L["settings.title"]</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Close" aria-label="@L["settings.close"]" OnClick="Close" />
        </div>
    </TitleContent>
    <DialogContent>
        <div class="app-settings" data-testid="settings-dialog">
            <div class="app-settings-nav">
                <MudNavMenu>
                    @if (Gate.IsEnabled(FeatureFlag.OpenApi))
                    {
                        <MudNavLink Icon="@Icons.Material.Filled.Api" data-testid="settings-section-openapi"
                                    OnClick="@(() => _active = Section.OpenApi)"
                                    Class="@ActiveClass(Section.OpenApi)">@L["settings.section.openApi"]</MudNavLink>
                    }
                    @if (Gate.IsEnabled(FeatureFlag.Ai))
                    {
                        <AuthorizeView Policy="Owner">
                            <MudNavLink Icon="@Icons.Material.Filled.AutoAwesome" data-testid="settings-section-ai"
                                        OnClick="@(() => _active = Section.Ai)"
                                        Class="@ActiveClass(Section.Ai)">@L["settings.section.ai"]</MudNavLink>
                        </AuthorizeView>
                    }
                    <AuthorizeView Policy="Owner">
                        <MudNavLink Icon="@Icons.Material.Filled.ToggleOn" data-testid="settings-section-features"
                                    OnClick="@(() => _active = Section.Features)"
                                    Class="@ActiveClass(Section.Features)">@L["settings.section.features"]</MudNavLink>
                    </AuthorizeView>
                    <AuthorizeView Policy="Owner">
                        <MudNavLink Icon="@Icons.Material.Filled.Tune" data-testid="settings-section-deployment"
                                    OnClick="@(() => _active = Section.Deployment)"
                                    Class="@ActiveClass(Section.Deployment)">@L["settings.section.deployment"]</MudNavLink>
                    </AuthorizeView>
                    <MudNavLink Icon="@Icons.Material.Filled.Language" data-testid="settings-section-language"
                                OnClick="@(() => _active = Section.Language)"
                                Class="@ActiveClass(Section.Language)">@L["settings.section.language"]</MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.Schedule" data-testid="settings-section-timezone"
                                OnClick="@(() => _active = Section.TimeZone)"
                                Class="@ActiveClass(Section.TimeZone)">@L["settings.section.timezone"]</MudNavLink>
                    @if (Gate.IsEnabled(FeatureFlag.Compliance))
                    {
                        <MudNavLink Icon="@Icons.Material.Filled.Gavel" data-testid="settings-section-legal"
                                    OnClick="@(() => _active = Section.Legal)"
                                    Class="@ActiveClass(Section.Legal)">@L["settings.section.legal"]</MudNavLink>
                    }
                </MudNavMenu>
            </div>
            <div class="app-settings-content">
                @switch (_active)
                {
                    case Section.OpenApi:
                        <OpenApiApplications />
                        break;
                    case Section.Ai:
                        <AuthorizeView Policy="Owner"><Authorized><AiSettings /></Authorized></AuthorizeView>
                        break;
                    case Section.Features:
                        <AuthorizeView Policy="Owner"><Authorized><FeatureSettings /></Authorized></AuthorizeView>
                        break;
                    case Section.Deployment:
                        <AuthorizeView Policy="Owner"><Authorized><DeploymentSettings /></Authorized></AuthorizeView>
                        break;
                    case Section.Language:
                        <div class="d-flex flex-column ga-3" data-testid="settings-language-panel">
                            <MudText Typo="Typo.h6">@L["language.title"]</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@L["language.description"]</MudText>
                            <div class="d-flex align-center ga-2">
                                <MudText Typo="Typo.body2">@L["language.current"]:</MudText>
                                <MudChip T="string" Color="Color.Primary" Size="Size.Small">@_currentLanguageName</MudChip>
                                <LanguageSwitcher />
                            </div>
                        </div>
                        break;
                    case Section.TimeZone:
                        <div class="d-flex flex-column ga-3" data-testid="settings-timezone-panel">
                            <MudText Typo="Typo.h6">@L["timezone.title"]</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@L["timezone.description"]</MudText>
                            <div class="d-flex align-center ga-2">
                                <MudText Typo="Typo.body2">@L["timezone.current"]:</MudText>
                                <MudChip T="string" Color="Color.Primary" Size="Size.Small" data-testid="timezone-current">@_currentZoneId</MudChip>
                            </div>
                            <TimeZoneSwitcher />
                        </div>
                        break;
                    case Section.Legal:
                        <Compliance />
                        break;
                }
            </div>
        </div>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance Dialog { get; set; } = default!;

    private enum Section { OpenApi, Ai, Features, Deployment, Language, TimeZone, Legal }

    private string _currentZoneId = SupportedTimeZones.Default;

    protected override async Task OnInitializedAsync() =>
        _currentZoneId = await UserZone.GetZoneIdAsync();

    private Section _active = Section.Features;
    private string _currentLanguageName = SupportedCultures.NativeNames[SupportedCultures.Default];

    protected override void OnInitialized()
    {
        var culture = CultureInfo.CurrentUICulture.Name;
        _currentLanguageName = SupportedCultures.NativeNames.TryGetValue(culture, out var native)
            ? native
            : SupportedCultures.NativeNames[SupportedCultures.Default];

        // Default to the first section the deployment exposes; owners land on Features otherwise.
        if (Gate.IsEnabled(FeatureFlag.OpenApi)) _active = Section.OpenApi;
        else if (Gate.IsEnabled(FeatureFlag.Ai)) _active = Section.Ai;
        else if (Gate.IsEnabled(FeatureFlag.Compliance)) _active = Section.Legal;
    }

    private string ActiveClass(Section section) => section == _active ? "app-settings-active" : "";

    private void Close() => Dialog.Close();
}
