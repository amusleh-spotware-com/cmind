@page "/copy-trading"
@using System.Net.Http.Json
@using Core.Domain
@using Web.Json
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs

<PageTitle>Copy Trading</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Class="mb-3">
    <MudText Typo="Typo.h5">Copy Trading</MudText>
    <HelpTip Text="Mirror a source (master) account's trades onto one or more destination (slave) accounts. Each destination controls its own sizing, direction, symbols and order handling. Start a profile to begin copying. Use the edit button to manage a profile's destinations (stop it first)." />
    <MudSpacer />
    <MudButton Color="Color.Secondary" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AutoAwesome"
               OnClick="OpenRecommendDialog" data-testid="ai-suggest">AI suggest</MudButton>
    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
               Href="/copy-trading/new" data-testid="copy-new-profile">New Profile</MudButton>
</MudStack>

<MudDialog @bind-Visible="_recommendOpen" Options="_recommendDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Class="mr-2" />AI copy-profile suggestion
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_riskProfile" Lines="5" Variant="Variant.Outlined" AutoGrow="true"
                      Label="Your risk profile"
                      Placeholder="Describe your risk appetite and the source (master) strategy — e.g. 'Conservative, low drawdown, majors only, mirror at half the master's size, always copy stop-loss'. The AI suggests safe copy-trading destination settings: sizing mode, drawdown & daily-loss limits, direction, and SL/TP copying."
                      data-testid="ai-risk-profile" />
        @if (_recommending)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-3" />
        }
        @if (!string.IsNullOrWhiteSpace(_recommendation))
        {
            <MudAlert Severity="Severity.Info" Class="mt-3" data-testid="ai-recommendation">
                <pre style="white-space:pre-wrap;margin:0">@_recommendation</pre>
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseRecommendDialog" data-testid="ai-suggest-cancel">Cancel</MudButton>
        <MudButton Color="Color.Secondary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.AutoAwesome"
                   OnClick="RecommendSettings" Disabled="_recommending" data-testid="ai-suggest-confirm">Suggest</MudButton>
    </DialogActions>
</MudDialog>

<MudTable Items="_profiles" Dense="true" Breakpoint="Breakpoint.Sm">
    <HeaderContent>
        <MudTh>Name</MudTh><MudTh>Source</MudTh><MudTh>Status</MudTh><MudTh>Destinations</MudTh><MudTh /></HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.name</MudTd>
        <MudTd DataLabel="Source" data-testid="copy-source">@AccountNumber((Guid)context.sourceAccountId)</MudTd>
        <MudTd DataLabel="Status"><MudChip T="string" Size="Size.Small" Color="StatusColor((string)context.status)">@context.status</MudChip></MudTd>
        <MudTd DataLabel="Destinations">@context.destinationCount</MudTd>
        <MudTd DataLabel="">
            <MudTooltip Text="Start copying">
                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                               Disabled="@IsRunning((string)context.status)" aria-label="Start profile"
                               OnClick="@(() => Action((Guid)context.id, "start"))" data-testid="copy-start" />
            </MudTooltip>
            <MudTooltip Text="Stop copying">
                <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Warning"
                               Disabled="@(!IsRunning((string)context.status))" aria-label="Stop profile"
                               OnClick="@(() => Action((Guid)context.id, "stop"))" data-testid="copy-stop" />
            </MudTooltip>
            <MudTooltip Text="@(IsRunning((string)context.status) ? "Stop the profile before editing" : "Edit profile & destinations")">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                               Disabled="@IsRunning((string)context.status)" aria-label="Edit profile"
                               Href="@($"/copy-trading/{(Guid)context.id}")" data-testid="copy-edit" />
            </MudTooltip>
            <MudTooltip Text="@(IsRunning((string)context.status) ? "Stop the profile before deleting" : "Delete profile")">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               Disabled="@IsRunning((string)context.status)" aria-label="Delete profile"
                               OnClick="@(() => DeleteProfile((Guid)context.id, (string)context.name))" data-testid="copy-delete" />
            </MudTooltip>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private dynamic[] _profiles = [];
    private dynamic[] _accounts = [];

    private string _riskProfile = "";
    private string _recommendation = "";
    private bool _recommendOpen;
    private bool _recommending;

    private static readonly DialogOptions _recommendDialogOptions =
        new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

    private void OpenRecommendDialog()
    {
        _recommendation = "";
        _recommendOpen = true;
    }

    private void CloseRecommendDialog() => _recommendOpen = false;

    protected override async Task OnInitializedAsync()
    {
        _accounts = await Http.GetDynamicArrayAsync("/api/accounts");
        await Load();
    }

    private async Task Load() => _profiles = await Http.GetDynamicArrayAsync("/api/copy/profiles");

    private static Color StatusColor(string status) => status switch
    {
        "Running" => Color.Success,
        "Paused" => Color.Warning,
        "Error" => Color.Error,
        _ => Color.Default
    };

    private static bool IsRunning(string status) => string.Equals(status, "Running", StringComparison.OrdinalIgnoreCase);

    private string AccountNumber(Guid id)
    {
        foreach (var a in _accounts)
            if ((Guid)a.id == id) return ((long)a.accountNumber).ToString(System.Globalization.CultureInfo.CurrentCulture);
        return "—";
    }

    private async Task RecommendSettings()
    {
        _recommending = true;
        _recommendation = "";
        try
        {
            var r = await Http.PostAsJsonAsync("/api/ai/recommend-copy-profile",
                new { RiskProfile = _riskProfile, SourceDescription = "cTrader copy-trading master account" });
            if (!r.IsSuccessStatusCode) { Snack.Add("AI request failed", Severity.Error); return; }
            var result = await r.Content.ReadFromJsonAsync<AiResultDto>();
            _recommendation = result is { success: true } ? result.text : result?.error ?? "AI unavailable";
        }
        finally
        {
            _recommending = false;
        }
    }

    private sealed record AiResultDto(bool success, string text, string? error);

    private async Task Action(Guid id, string action)
    {
        var r = await Http.PostAsync($"/api/copy/profiles/{id}/{action}", null);
        if (!r.IsSuccessStatusCode) Snack.Add($"Cannot {action} profile", Severity.Error);
        await Load();
    }

    private async Task DeleteProfile(Guid id, string name)
    {
        var profile = ((IEnumerable<dynamic>)_profiles).FirstOrDefault(p => (Guid)p.id == id);
        if (profile is not null && IsRunning((string)profile.status))
        {
            Snack.Add("Stop the profile before deleting it", Severity.Warning);
            return;
        }

        var ok = await Dialogs.ShowMessageBox("Delete copy profile",
            $"Delete '{name}'? This removes the profile and all its destinations and cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (ok != true) return;

        var r = await Http.DeleteAsync($"/api/copy/profiles/{id}");
        if (!r.IsSuccessStatusCode) { Snack.Add("Failed to delete profile", Severity.Error); return; }
        Snack.Add("Profile deleted", Severity.Success);
        await Load();
    }

}
