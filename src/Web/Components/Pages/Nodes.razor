@page "/nodes"
@using Web.Json
@using Web.Components.Dialogs
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "AdminOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs

<PageTitle>Nodes</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Nodes</MudText>
    <MudSpacer />
    <MudButton Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNew">
        New Node
    </MudButton>
</MudStack>

<MudTable Items="_items" Class="mt-3" Dense="true">
    <HeaderContent>
        <MudTh>Name</MudTh><MudTh>Host</MudTh><MudTh>Mode</MudTh><MudTh>Status</MudTh><MudTh>CPU</MudTh><MudTh>Mem</MudTh><MudTh>Disk</MudTh><MudTh>Backtest</MudTh><MudTh /></HeaderContent>
    <RowTemplate>
        <MudTd>@context.name</MudTd>
        <MudTd>@context.host</MudTd>
        <MudTd>@context.mode</MudTd>
        <MudTd>@context.status</MudTd>
        <MudTd>@(((double?)context.stats?.cpuPercent ?? 0).ToString("F1"))%</MudTd>
        <MudTd>@Fmt(context.stats?.memUsedBytes) / @Fmt(context.stats?.memTotalBytes)</MudTd>
        <MudTd>@Fmt(context.stats?.diskUsedBytes) / @Fmt(context.stats?.diskTotalBytes)</MudTd>
        <MudTd>@Fmt(context.stats?.backtestDataUsedBytes)</MudTd>
        <MudTd>
            @if ((bool?)context.isLocal == true)
            {
                <MudSwitch T="bool" Value="@((bool)context.enabled)" Color="Color.Primary"
                           ValueChanged="@((bool v) => ToggleLocal(v))" Label="Enabled" />
                <MudIconButton Icon="@Icons.Material.Filled.CleaningServices" Size="Size.Small" OnClick="@(() => Clean((Guid)context.id))" />
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.CleaningServices" Size="Size.Small" OnClick="@(() => Clean((Guid)context.id))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => Remove((Guid)context.id))" />
            }
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private dynamic[] _items = [];

    protected override Task OnInitializedAsync() => Load();
    private async Task Load() => _items = await Http.GetDynamicArrayAsync("/api/nodes/");

    private async Task OpenNew()
    {
        var dlg = await Dialogs.ShowAsync<NewNodeDialog>("New Node",
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (NewNodeDialog.NewNodeDialogResult)res.Data!;
        var r = await Http.PostAsJsonAsync("/api/nodes/", new
        {
            data.Name, data.BaseUrl, data.ApiSecret, data.Mode,
            DataDirPath = data.DataDir, data.MaxInstances
        });
        Snack.Add(r.IsSuccessStatusCode ? "Added" : "Failed", r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        await Load();
    }

    private async Task Remove(Guid id) { await Http.DeleteAsync($"/api/nodes/{id}"); await Load(); }
    private async Task Clean(Guid id) { await Http.PostAsync($"/api/nodes/{id}/clean-backtest-data", null); await Load(); }

    private async Task ToggleLocal(bool enabled)
    {
        var r = await Http.PostAsJsonAsync("/api/nodes/local/toggle", new { Enabled = enabled });
        Snack.Add(r.IsSuccessStatusCode ? (enabled ? "Local node enabled" : "Local node disabled") : "Toggle failed",
            r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        await Load();
    }

    private static string Fmt(dynamic? bytes)
    {
        if (bytes is null) return "-";
        var b = (long)bytes;
        string[] u = ["B","KB","MB","GB","TB"]; var i = 0; double v = b;
        while (v >= 1024 && i < u.Length - 1) { v /= 1024; i++; }
        return $"{v:F1} {u[i]}";
    }
}
