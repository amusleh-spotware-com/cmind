@page "/builder"
@using Web.Json
@using Web.Components.Dialogs
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs
@inject NavigationManager Nav

<PageTitle>cBot Builder</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">cBot Builder</MudText>
    <MudSpacer />
    <MudButton Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNew">
        New cBot
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_projects.Length == 0)
{
    <MudPaper Class="pa-6" Style="text-align:center;">
        <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Large" Class="mb-2" />
        <MudText Typo="Typo.body1" Class="mb-2">No cBot projects yet.</MudText>
        <MudText Typo="Typo.caption" Style="color:#A0A0A0;">Click "New cBot" to create your first project.</MudText>
    </MudPaper>
}
else
{
    <MudTable Items="_projects" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Language</MudTh>
            <MudTh>Last Build</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="width:140px;" />
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <MudLink Href="@($"/builder/{context.id}")">@context.name</MudLink>
            </MudTd>
            <MudTd DataLabel="Language">@context.language</MudTd>
            <MudTd DataLabel="Last Build">@FormatTs(context.lastBuildAt)</MudTd>
            <MudTd DataLabel="Status">@BuildStatusChip(context)</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => Nav.NavigateTo($"/builder/{context.id}"))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => Delete((Guid)context.id, (string)context.name))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private dynamic[] _projects = [];
    private bool _loading = true;

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        _loading = true;
        try { _projects = await Http.GetDynamicArrayAsync("/api/builder/projects"); }
        finally { _loading = false; }
    }

    private static string FormatTs(dynamic? v) =>
        v switch
        {
            null => "—",
            DateTimeOffset d => d.LocalDateTime.ToString("yyyy-MM-dd HH:mm"),
            _ => v.ToString() ?? "—"
        };

    private RenderFragment BuildStatusChip(dynamic p) => builder =>
    {
        if (p.lastBuildAt is null)
        {
            builder.OpenComponent<MudChip<string>>(0);
            builder.AddAttribute(1, "Size", Size.Small);
            builder.AddAttribute(2, "Color", Color.Default);
            builder.AddAttribute(3, "Variant", Variant.Outlined);
            builder.AddAttribute(4, "ChildContent", (RenderFragment)(b => b.AddContent(0, "—")));
            builder.CloseComponent();
            return;
        }
        var ok = (bool)p.lastBuildSucceeded;
        builder.OpenComponent<MudChip<string>>(0);
        builder.AddAttribute(1, "Size", Size.Small);
        builder.AddAttribute(2, "Color", ok ? Color.Success : Color.Error);
        builder.AddAttribute(3, "Variant", Variant.Filled);
        builder.AddAttribute(4, "ChildContent", (RenderFragment)(b => b.AddContent(0, ok ? "Success" : "Failed")));
        builder.CloseComponent();
    };

    private async Task OpenNew()
    {
        var dlg = await Dialogs.ShowAsync<NewProjectDialog>("New cBot Project",
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (NewProjectDialog.NewProjectDialogResult)res.Data!;
        var r = await Http.PostAsJsonAsync("/api/builder/projects", new { Name = data.Name, Language = data.Language });
        if (!r.IsSuccessStatusCode) { Snack.Add("Failed to create project", Severity.Error); return; }
        var d = await r.Content.ReadFromJsonAsync<dynamic?>(JsonDefaults.DynamicWeb);
        if (d is null) { Snack.Add("Failed to create project", Severity.Error); return; }
        Guid id = (Guid)d.id;
        Nav.NavigateTo($"/builder/{id}");
    }

    private async Task Delete(Guid id, string name)
    {
        var ok = await Dialogs.ShowMessageBox("Delete project",
            $"Delete '{name}'? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (ok != true) return;
        var r = await Http.DeleteAsync($"/api/builder/projects/{id}");
        if (r.IsSuccessStatusCode) { Snack.Add("Deleted", Severity.Success); await Load(); }
        else Snack.Add("Delete failed", Severity.Error);
    }
}
