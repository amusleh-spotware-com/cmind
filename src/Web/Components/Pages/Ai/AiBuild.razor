@page "/ai/build"
@using Web.Json
@using Web.Time
@using Web.Components.Dialogs
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs
@inject NavigationManager Nav
@inject IUserTimeZone UserZone

<PageTitle>AI · Build cBot</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Build cBot</MudText>
    <HelpTip Text="Create cBot projects with AI. Start from scratch or improve an existing cBot, then chat with a model to write and refine its code — every prompt and reply is saved. Build and run right from the project page." />
    <MudSpacer />
    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
               OnClick="StartNew" data-testid="ai-build-new">New cBot</MudButton>
</MudStack>

<AiFeatureNotice PromptOnLoad="true" />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_rows.Length == 0)
{
    <MudPaper Class="pa-6" Style="text-align:center;" data-testid="ai-build-empty">
        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Large" Class="mb-2" />
        <MudText Typo="Typo.body1" Class="mb-1">No AI cBot projects yet.</MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary">Click "New cBot" to create one from scratch or improve an existing cBot.</MudText>
    </MudPaper>
}
else
{
    <MudTable Items="_rows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1" data-testid="ai-build-projects">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh Style="width:64px;text-align:center;">Lang</MudTh>
            <MudTh>Last change</MudTh>
            <MudTh Style="width:120px;" />
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name"><MudLink Href="@($"/ai/build/{context.Id}")">@context.Name</MudLink></MudTd>
            <MudTd DataLabel="Lang" Style="text-align:center;">
                @if (context.Language is not null)
                {
                    <MudTooltip Text="@LanguageIcons.LabelFor(context.Language)">@LanguageIcons.For(context.Language)</MudTooltip>
                }
            </MudTd>
            <MudTd DataLabel="Last change">@FormatTs(context.LastChange)</MudTd>
            <MudTd>
                <MudTooltip Text="Open project">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => Nav.NavigateTo($"/ai/build/{context.Id}"))" data-testid="ai-build-view" />
                </MudTooltip>
                <MudTooltip Text="Delete">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => Delete(context))" data-testid="ai-build-delete" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private Row[] _rows = [];
    private bool _loading = true;
    private TimeZoneInfo _zone = TimeZoneInfo.Utc;

    protected override async Task OnInitializedAsync()
    {
        _zone = await UserZone.GetZoneAsync();
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        try
        {
            var arr = await Http.GetDynamicArrayAsync("/api/builder/projects");
            _rows = arr.Select(p => new Row(
                    (Guid)p.id,
                    (string)p.name,
                    (string?)p.language,
                    LastChangeOf(p)))
                .OrderByDescending(r => r.LastChange ?? DateTimeOffset.MinValue)
                .ToArray();
        }
        catch { _rows = []; }
        finally { _loading = false; }
    }

    private static DateTimeOffset? LastChangeOf(dynamic p)
    {
        if (p.updatedAt is not null) return (DateTimeOffset?)p.updatedAt;
        if (p.createdAt is not null) return (DateTimeOffset?)p.createdAt;
        return null;
    }

    private async Task StartNew()
    {
        var options = _rows.Select(r => new AiBuildStartDialog.ProjectOption(r.Id, r.Name)).ToList();
        var parameters = new DialogParameters<AiBuildStartDialog>
        {
            { x => x.Projects, (IReadOnlyList<AiBuildStartDialog.ProjectOption>)options }
        };
        var dialog = await Dialogs.ShowAsync<AiBuildStartDialog>("New AI Build", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not AiBuildStartDialog.AiBuildStartResult r) return;

        Guid projectId;
        if (r.IsNew)
        {
            var response = await Http.PostAsJsonAsync("/api/builder/projects", new { Name = r.Name, Language = r.Language });
            if (!response.IsSuccessStatusCode) { Snack.Add("Could not create the project", Severity.Error); return; }
            var created = await response.Content.ReadFromJsonAsync<dynamic?>(JsonDefaults.DynamicWeb);
            if (created is null) { Snack.Add("Could not create the project", Severity.Error); return; }
            projectId = (Guid)created.id;
        }
        else if (r.ProjectId is { } existing)
        {
            projectId = existing;
        }
        else
        {
            return;
        }

        var url = r.ModelId is { } model ? $"/ai/build/{projectId}?model={model}" : $"/ai/build/{projectId}";
        Nav.NavigateTo(url);
    }

    private async Task Delete(Row row)
    {
        var ok = await Dialogs.ShowMessageBox("Delete cBot",
            $"Delete '{row.Name}'? This removes its source and AI conversation. This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (ok != true) return;
        var response = await Http.DeleteAsync($"/api/builder/projects/{row.Id}");
        if (response.IsSuccessStatusCode) { Snack.Add("Deleted", Severity.Success); await Load(); }
        else Snack.Add("Delete failed", Severity.Error);
    }

    private string FormatTs(DateTimeOffset? v) =>
        v is null ? "—" : v.Value.ToUserString(_zone, "yyyy-MM-dd HH:mm");

    private sealed record Row(Guid Id, string Name, string? Language, DateTimeOffset? LastChange);
}
