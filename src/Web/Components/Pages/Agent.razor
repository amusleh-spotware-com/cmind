@page "/agent"
@using System.Net.Http.Json
@using Web.Json
@using Web.Time
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject HttpClient Http
@inject ISnackbar Snack
@inject IStringLocalizer<Ui> L
@inject IUserTimeZone UserZone

<PageTitle>Portfolio Agent</PageTitle>

<MudText Typo="Typo.h5" Class="mb-3">Autonomous Portfolio Agent</MudText>
<MudText Typo="Typo.body2" Class="mb-4">
    Give the agent a mandate. It proposes parameter sets to backtest and records its reasoning. In
    <b>Suggest</b>/<b>Approve</b> mode you approve each proposal; in <b>Auto</b> mode it backtests automatically.
</MudText>

<AiFeatureNotice EnabledChanged="OnAiStatus" />

<MudGrid>
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-2">New mandate</MudText>
            <MudTextField @bind-Value="_name" Label="Mandate name" Placeholder="Grow EURUSD safely" Immediate="true"
                          Error="@NameTaken" ErrorText="A mandate with that name already exists" data-testid="agent-mandate-name" />
            <MudSelect T="Guid?" @bind-Value="_cbotId" Label="cBot" Dense="true" Class="mt-2" data-testid="agent-cbot">
                @foreach (var c in _cbots) { <MudSelectItem T="Guid?" Value="@((Guid?)c.id)">@c.name</MudSelectItem> }
            </MudSelect>
            <MudSelect T="Guid?" @bind-Value="_accountId" Label="Trading account (required for Auto)" Dense="true" Class="mt-2">
                <MudSelectItem T="Guid?" Value="@((Guid?)null)">None</MudSelectItem>
                @foreach (var a in _accounts) { <MudSelectItem T="Guid?" Value="@((Guid?)a.id)">@a.accountNumber - @a.broker</MudSelectItem> }
            </MudSelect>
            <MudTextField @bind-Value="_objective" Label="Objective" Lines="2" Class="mt-2"
                          Placeholder="e.g. grow the account with low drawdown, avoid overfitting" />
            <MudStack Row="true" Spacing="2" Class="mt-2">
                <MudNumericField T="decimal" @bind-Value="_risk" Label="Risk % / trade" Min="0.1M" Max="100M" Step="0.1M" />
                <MudNumericField T="decimal" @bind-Value="_drawdown" Label="Max drawdown %" Min="1M" Max="100M" Step="1M" />
            </MudStack>
            <MudStack Row="true" Spacing="2" Class="mt-2">
                <MudTextField @bind-Value="_symbol" Label="Symbol" />
                <MudSelect T="string" @bind-Value="_timeframe" Label="Timeframe" Dense="true" data-testid="agent-timeframe">
                    @foreach (var tf in Core.Constants.Timeframes.Supported)
                    {
                        <MudSelectItem T="string" Value="@tf">@tf</MudSelectItem>
                    }
                </MudSelect>
            </MudStack>
            <MudSelect T="string" @bind-Value="_autonomy" Label="Autonomy" Dense="true" Class="mt-2">
                <MudSelectItem Value="@("Suggest")">Suggest (record only)</MudSelectItem>
                <MudSelectItem Value="@("Approve")">Approve (queue for me)</MudSelectItem>
                <MudSelectItem Value="@("Auto")">Auto (backtest automatically)</MudSelectItem>
            </MudSelect>
            <MudSwitch @bind-Value="_enabled" Label="Enabled" Color="Color.Primary" Class="mt-2" />
            <MudTooltip Text="@(_aiEnabled ? "" : L["agent.aiRequired"])" Disabled="_aiEnabled">
                <MudButton Class="mt-3" Color="Color.Primary" Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="CreateMandate"
                           Disabled="@(!CanCreate)" data-testid="agent-create-mandate">
                    Create mandate
                </MudButton>
            </MudTooltip>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-2">Mandates</MudText>
            @if (_mandates.Length == 0)
            {
                <MudText Typo="Typo.body2">No mandates yet.</MudText>
            }
            else
            {
                <MudTable Items="_mandates" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" data-testid="agent-mandates">
                    <HeaderContent>
                        <MudTh>Name</MudTh><MudTh>cBot</MudTh><MudTh>Autonomy</MudTh><MudTh>Enabled</MudTh><MudTh>Last run</MudTh><MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Name">@context.name</MudTd>
                        <MudTd DataLabel="cBot">@context.cbotName</MudTd>
                        <MudTd DataLabel="Autonomy">@context.autonomy</MudTd>
                        <MudTd DataLabel="Enabled">@(((bool)context.enabled) ? "Yes" : "No")</MudTd>
                        <MudTd DataLabel="Last run">@FormatDate(context.lastRunAt)</MudTd>
                        <MudTd DataLabel="">
                            <MudTooltip Text="@(_aiEnabled ? "Run now" : L["agent.aiRequired"])">
                                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Success"
                                               aria-label="Run now" Disabled="@(_busy || !_aiEnabled || !(bool)context.enabled)"
                                               OnClick="@(() => RunNow((Guid)context.id))" data-testid="agent-run-now" />
                            </MudTooltip>
                            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete" aria-label="Delete mandate"
                                           OnClick="@(() => DeleteMandate((Guid)context.id))" data-testid="agent-mandate-delete" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

<MudPaper Class="pa-4 mt-4" Elevation="1">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
        <MudText Typo="Typo.h6">Decision journal</MudText>
        <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadProposals">Refresh</MudButton>
    </MudStack>
    @if (_proposals.Length == 0)
    {
        <MudText Typo="Typo.body2">No proposals yet. The agent runs on a schedule when a mandate is enabled.</MudText>
    }
    else
    {
        <MudTable Items="_proposals" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>When</MudTh><MudTh>Mandate</MudTh><MudTh>Proposal</MudTh><MudTh>Reasoning</MudTh><MudTh>Status</MudTh><MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="When">@FormatDate(context.createdAt)</MudTd>
                <MudTd DataLabel="Mandate">@context.mandateName</MudTd>
                <MudTd DataLabel="Proposal">@context.proposedName</MudTd>
                <MudTd DataLabel="Reasoning" Style="max-width:360px; white-space:pre-wrap;">@context.reasoning</MudTd>
                <MudTd DataLabel="Status">@context.status @(context.failureReason is null ? "" : $"({context.failureReason})")</MudTd>
                <MudTd DataLabel="">
                    @if ((string)context.status == "Pending")
                    {
                        <MudButton Size="Size.Small" Color="Color.Success" OnClick="@(() => Approve((Guid)context.id))" Disabled="_busy">Approve</MudButton>
                        <MudButton Size="Size.Small" Color="Color.Error" OnClick="@(() => Reject((Guid)context.id))" Disabled="_busy">Reject</MudButton>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private dynamic[] _cbots = [], _accounts = [], _mandates = [], _proposals = [];
    private Guid? _cbotId, _accountId;
    private string _name = "", _objective = "", _symbol = "EURUSD", _timeframe = "h1", _autonomy = "Suggest";
    private decimal _risk = 1.0M, _drawdown = 20.0M;
    private bool _enabled = true, _busy, _aiEnabled;

    // The Create button stays disabled until the mandate name is non-blank and unique among existing mandates.
    private bool NameTaken =>
        !string.IsNullOrWhiteSpace(_name) &&
        _mandates.Any(m => string.Equals((string)m.name, _name.Trim(), StringComparison.OrdinalIgnoreCase));

    private bool CanCreate =>
        _aiEnabled && !_busy && !NameTaken && _cbotId is not null && !string.IsNullOrWhiteSpace(_name);

    private void OnAiStatus(bool enabled)
    {
        _aiEnabled = enabled;
        StateHasChanged();
    }

    private async Task RunNow(Guid id)
    {
        _busy = true;
        try
        {
            var response = await Http.PostAsync($"/api/agent/mandates/{id}/run", null);
            if (response.IsSuccessStatusCode)
            {
                Snack.Add("Agent is running in the background — watch the decision journal.", Severity.Info);
                await LoadMandates();
                await LoadProposals();
            }
            else Snack.Add("Could not start the run", Severity.Error);
        }
        catch { Snack.Add("Request failed", Severity.Error); }
        finally { _busy = false; }
    }

    private TimeZoneInfo _zone = TimeZoneInfo.Utc;

    protected override async Task OnInitializedAsync()
    {
        _zone = await UserZone.GetZoneAsync();
        // Load each source independently and tolerate a disabled/unavailable feature (e.g. Authoring off
        // makes /api/cbots return 404). A failed load leaves that list empty and the page usable rather
        // than throwing into the ErrorBoundary.
        _cbots = await LoadOrEmptyAsync("/api/cbots/");
        _accounts = await LoadOrEmptyAsync("/api/accounts/");
        await LoadMandates();
        await LoadProposals();
    }

    private async Task LoadMandates() => _mandates = await LoadOrEmptyAsync("/api/agent/mandates");
    private async Task LoadProposals() => _proposals = await LoadOrEmptyAsync("/api/agent/proposals");

    private async Task<dynamic[]> LoadOrEmptyAsync(string url)
    {
        try
        {
            return await Http.GetDynamicArrayAsync(url);
        }
        catch
        {
            return [];
        }
    }

    private async Task CreateMandate()
    {
        if (_cbotId is null) { Snack.Add("Pick a cBot", Severity.Warning); return; }
        if (string.IsNullOrWhiteSpace(_name)) { Snack.Add("Name required", Severity.Warning); return; }
        _busy = true;
        try
        {
            var body = new
            {
                CBotId = _cbotId,
                TradingAccountId = _accountId,
                Name = _name,
                Objective = _objective,
                RiskPercentPerTrade = (double)_risk,
                MaxDrawdownPercent = (double)_drawdown,
                Symbol = _symbol,
                Timeframe = _timeframe,
                Autonomy = _autonomy,
                Enabled = _enabled
            };
            var response = await Http.PostAsJsonAsync("/api/agent/mandates", body);
            if (response.IsSuccessStatusCode)
            {
                Snack.Add("Mandate created", Severity.Success);
                _name = ""; _objective = "";
                await LoadMandates();
            }
            else
            {
                Snack.Add(await response.Content.ReadAsStringAsync(), Severity.Error);
            }
        }
        catch { Snack.Add("Request failed", Severity.Error); }
        finally { _busy = false; }
    }

    private async Task DeleteMandate(Guid id)
    {
        var response = await Http.DeleteAsync($"/api/agent/mandates/{id}");
        if (response.IsSuccessStatusCode) await LoadMandates();
        else Snack.Add("Delete failed", Severity.Error);
    }

    private async Task Approve(Guid id)
    {
        _busy = true;
        try
        {
            var response = await Http.PostAsync($"/api/agent/proposals/{id}/approve", null);
            var text = await response.Content.ReadAsStringAsync();
            if (text.Contains("\"success\":true")) Snack.Add("Backtest launched", Severity.Success);
            else Snack.Add("Approve failed: " + text, Severity.Error);
            await LoadProposals();
        }
        catch { Snack.Add("Request failed", Severity.Error); }
        finally { _busy = false; }
    }

    private async Task Reject(Guid id)
    {
        _busy = true;
        try
        {
            await Http.PostAsync($"/api/agent/proposals/{id}/reject", null);
            await LoadProposals();
        }
        catch { Snack.Add("Request failed", Severity.Error); }
        finally { _busy = false; }
    }

    private string FormatDate(dynamic value)
    {
        if (value is null) return "-";
        DateTimeOffset dto = value;
        return dto.ToUserString(_zone, "yyyy-MM-dd HH:mm");
    }
}
