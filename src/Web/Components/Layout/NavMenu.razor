@using Core.Features
@using Web.Components.Dialogs
@inject IFeatureGate Gate
@inject IDialogService Dialogs

@* Expandable, grouped navigation (TradingView/cTrader-inspired). Feature-gated groups collapse to
   nothing when all their children are disabled. Settings is pinned to the bottom of the drawer. *@

<div class="nav-shell d-flex flex-column">
    <MudNavMenu Class="flex-grow-1">
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>

        @if (AnyAuthoring)
        {
            <MudNavGroup Title="cBots" Icon="@Icons.Material.Filled.Memory" Expanded="false">
                @if (Gate.IsEnabled(FeatureFlag.Authoring))
                {
                    <MudNavLink Href="/cbots" Icon="@Icons.Material.Filled.Code">cBots</MudNavLink>
                }
                @if (Gate.IsEnabled(FeatureFlag.Execution))
                {
                    <MudNavLink Href="/run" Icon="@Icons.Material.Filled.PlayArrow">Run</MudNavLink>
                }
                @if (Gate.IsEnabled(FeatureFlag.Backtesting))
                {
                    <MudNavLink Href="/backtest" Icon="@Icons.Material.Filled.History">Backtest</MudNavLink>
                    <MudNavLink Href="/optimize" Icon="@Icons.Material.Filled.Tune">Optimize</MudNavLink>
                    <MudNavLink Href="/quant/integrity" Icon="@Icons.Material.Filled.VerifiedUser">Integrity</MudNavLink>
                    <MudNavLink Href="/quant/sizing" Icon="@Icons.Material.Filled.Balance">Position Sizing</MudNavLink>
                }
            </MudNavGroup>
        }

        @if (Gate.IsEnabled(FeatureFlag.Ai))
        {
            <MudNavGroup Title="AI" Icon="@Icons.Material.Filled.AutoAwesome" Expanded="false">
                <MudNavLink Href="/ai/build" Icon="@Icons.Material.Filled.Bolt">Build cBot</MudNavLink>
                <MudNavLink Href="/ai/review" Icon="@Icons.Material.Filled.RateReview">Review</MudNavLink>
                <MudNavLink Href="/ai/debate" Icon="@Icons.Material.Filled.Forum">Debate</MudNavLink>
                <MudNavLink Href="/ai/sentiment" Icon="@Icons.Material.Filled.Insights">Market Sentiment</MudNavLink>
                <MudNavLink Href="/ai/exposure" Icon="@Icons.Material.Filled.Radar">Exposure Check</MudNavLink>
                <MudNavLink Href="/ai/digest" Icon="@Icons.Material.Filled.Summarize">Portfolio Digest</MudNavLink>
                <MudNavLink Href="/ai/tune" Icon="@Icons.Material.Filled.TrendingDown">Tune Advisor</MudNavLink>
                <MudNavLink Href="/ai/optimize" Icon="@Icons.Material.Filled.AutoFixHigh">Optimize</MudNavLink>
                @if (Gate.IsEnabled(FeatureFlag.PortfolioAgent))
                {
                    <MudNavLink Href="/agent" Icon="@Icons.Material.Filled.SmartToy">Portfolio Agent</MudNavLink>
                }
                @if (Gate.IsEnabled(FeatureFlag.Alerts))
                {
                    <MudNavLink Href="/alerts" Icon="@Icons.Material.Filled.NotificationsActive">Alerts</MudNavLink>
                }
                @if (Gate.IsEnabled(FeatureFlag.Mcp))
                {
                    <MudNavLink Href="/mcp" Icon="@Icons.Material.Filled.Key">MCP Keys</MudNavLink>
                }
            </MudNavGroup>
        }

        @if (AnyProp)
        {
            <MudNavGroup Title="Prop" Icon="@Icons.Material.Filled.EmojiEvents" Expanded="false">
                @if (Gate.IsEnabled(FeatureFlag.PropGuard))
                {
                    <MudNavLink Href="/prop-guard" Icon="@Icons.Material.Filled.Shield">Prop Guard</MudNavLink>
                }
                @if (Gate.IsEnabled(FeatureFlag.PropFirm))
                {
                    <MudNavLink Href="/prop-firm" Icon="@Icons.Material.Filled.EmojiEvents">Challenges</MudNavLink>
                }
            </MudNavGroup>
        }

        @if (Gate.IsEnabled(FeatureFlag.Accounts))
        {
            <MudNavLink Href="/accounts" Icon="@Icons.Material.Filled.AccountBalance">Trading Accounts</MudNavLink>
        }
        @if (Gate.IsEnabled(FeatureFlag.CopyTrading))
        {
            <MudNavLink Href="/copy-trading" Icon="@Icons.Material.Filled.Repeat">Copy Trading</MudNavLink>
        }

        <AuthorizeView Policy="AdminOrAbove">
            <MudNavLink Href="/nodes" Icon="@Icons.Material.Filled.Hub">Nodes</MudNavLink>
            <MudNavLink Href="/users" Icon="@Icons.Material.Filled.Group">Users</MudNavLink>
        </AuthorizeView>
    </MudNavMenu>

    <MudDivider />
    <MudNavMenu>
        <MudNavLink Icon="@Icons.Material.Filled.Settings" data-testid="nav-settings" OnClick="OpenSettings">Settings</MudNavLink>
    </MudNavMenu>
</div>

<style>
    .nav-shell { height: 100%; min-height: 0; }
</style>

@code {
    private bool AnyAuthoring =>
        Gate.IsEnabled(FeatureFlag.Authoring)
        || Gate.IsEnabled(FeatureFlag.Execution)
        || Gate.IsEnabled(FeatureFlag.Backtesting);

    private bool AnyProp =>
        Gate.IsEnabled(FeatureFlag.PropGuard) || Gate.IsEnabled(FeatureFlag.PropFirm);

    private Task OpenSettings() =>
        Dialogs.ShowAsync<SettingsDialog>(string.Empty,
            new DialogOptions { FullScreen = true, CloseOnEscapeKey = true });
}
