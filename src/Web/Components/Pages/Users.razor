@page "/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "AdminOrAbove")]
@using Web.Json
@using Web.Components.Dialogs
@inject HttpClient Http
@inject ISnackbar Snack
@inject IDialogService Dialogs

<PageTitle>Users</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h5">Users</MudText>
    <HelpTip Text="Team members who can sign in. Roles gate access: Owner > Admin > User > Viewer. Reset issues a temporary password; the user must change it on next sign-in." />
    <MudSpacer />
    <MudButton Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNew">
        New User
    </MudButton>
</MudStack>

<MudTable Items="_items" Dense="true" Breakpoint="Breakpoint.Sm">
    <HeaderContent><MudTh>Email</MudTh><MudTh>Role</MudTh><MudTh>Locked</MudTh><MudTh /></HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Email">@context.email</MudTd>
        <MudTd DataLabel="Role">@context.role</MudTd>
        <MudTd DataLabel="Locked">@context.isLockedOut</MudTd>
        <MudTd DataLabel="">
            <MudIconButton Icon="@Icons.Material.Filled.LockReset" Size="Size.Small" aria-label="Reset password" OnClick="@(() => Reset((Guid)context.id))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" aria-label="Delete user" OnClick="@(() => Remove((Guid)context.id))" />
        </MudTd>
    </RowTemplate>
</MudTable>

@if (_pending.Length > 0)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-6 mb-3">
        <MudText Typo="Typo.h6">Pending approval</MudText>
        <HelpTip Text="Self-registered accounts awaiting your approval before they can sign in." />
    </MudStack>
    <MudTable Items="_pending" Dense="true" Breakpoint="Breakpoint.Sm" data-testid="users-pending">
        <HeaderContent><MudTh>Email</MudTh><MudTh>Role</MudTh><MudTh /></HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Email">@context.email</MudTd>
            <MudTd DataLabel="Role">@context.role</MudTd>
            <MudTd DataLabel="">
                <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                           OnClick="@(() => Approve((Guid)context.id))">Approve</MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               aria-label="Reject user" OnClick="@(() => Remove((Guid)context.id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private dynamic[] _items = [];
    private dynamic[] _pending = [];

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        _items = await Http.GetDynamicArrayAsync("/api/users/");
        _pending = await Http.GetDynamicArrayAsync("/api/users/pending");
    }

    private async Task Approve(Guid id)
    {
        var r = await Http.PostAsJsonAsync($"/api/users/{id}/approve", new { });
        Snack.Add(r.IsSuccessStatusCode ? "Approved" : "Failed",
            r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        await Load();
    }

    private async Task OpenNew()
    {
        var dlg = await Dialogs.ShowAsync<NewUserDialog>("New User",
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        var data = (NewUserDialog.NewUserDialogResult)res.Data!;
        var r = await Http.PostAsJsonAsync("/api/users/", new { data.Email, data.Password, data.Role });
        Snack.Add(r.IsSuccessStatusCode ? "Created" : "Failed", r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        await Load();
    }

    private async Task Reset(Guid id)
    {
        var pw = Guid.NewGuid().ToString("N")[..12];
        var r = await Http.PostAsJsonAsync($"/api/users/{id}/reset-password", new { NewPassword = pw });
        if (!r.IsSuccessStatusCode)
        {
            Snack.Add("Reset failed", Severity.Error);
            return;
        }
        await Dialogs.ShowAsync<TempPasswordDialog>("Temporary password",
            new DialogParameters<TempPasswordDialog> { { x => x.Password, pw } },
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });
    }

    private async Task Remove(Guid id)
    {
        if (!await Dialogs.ConfirmAsync(
            "Delete user?",
            "This permanently removes the user and cannot be undone.",
            "Delete", "Cancel")) return;
        var r = await Http.DeleteAsync($"/api/users/{id}");
        Snack.Add(r.IsSuccessStatusCode ? "User deleted" : "Delete failed",
            r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        await Load();
    }
}
