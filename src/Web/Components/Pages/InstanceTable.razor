@inject HttpClient Http
@using Web.Json
@using Web.Components.Dialogs
@using Microsoft.JSInterop
@inject NavigationManager Nav
@inject IDialogService Dialogs
@inject ISnackbar Snack
@inject IJSRuntime JS

<MudTable Items="_items" Dense="true" Breakpoint="Breakpoint.Sm">
    <HeaderContent>
        <MudTh>cBot</MudTh><MudTh>Symbol</MudTh><MudTh>TF</MudTh><MudTh>Status</MudTh><MudTh>Node</MudTh><MudTh /></HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="cBot">@context.cBot</MudTd>
        <MudTd DataLabel="Symbol">@context.symbol</MudTd>
        <MudTd DataLabel="TF">@context.timeframe</MudTd>
        <MudTd DataLabel="Status"><MudChip T="string" Size="Size.Small" Color="StatusColor((string)context.status)">@context.status</MudChip></MudTd>
        <MudTd DataLabel="Node">@context.node</MudTd>
        <MudTd DataLabel="">
            <MudTooltip Text="View instance">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" aria-label="View instance"
                               OnClick="@(() => Open((Guid)context.id, (Guid)context.lineageId))" data-testid="instance-view" />
            </MudTooltip>
            <MudTooltip Text="@((bool)context.hasLogs ? "Download console logs" : "No logs available")">
                <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small" aria-label="Download console logs"
                               Disabled="@(!(bool)context.hasLogs)"
                               OnClick="@(() => DownloadLogs((Guid)context.id))" data-testid="instance-logs-download" />
            </MudTooltip>
            @if (Type == "Backtest")
            {
                <MudTooltip Text="@((bool)context.hasReportJson ? "Download JSON report" : "Report available only for a completed backtest")">
                    <MudIconButton Icon="@Icons.Material.Filled.DataObject" Size="Size.Small" aria-label="Download JSON report"
                                   Disabled="@(!(bool)context.hasReportJson)"
                                   OnClick="@(() => DownloadReport((Guid)context.id, "json"))" data-testid="instance-report-json" />
                </MudTooltip>
                <MudTooltip Text="@((bool)context.hasReportHtml ? "Download HTML report" : "Report available only for a completed backtest")">
                    <MudIconButton Icon="@Icons.Material.Filled.Html" Size="Size.Small" aria-label="Download HTML report"
                                   Disabled="@(!(bool)context.hasReportHtml)"
                                   OnClick="@(() => DownloadReport((Guid)context.id, "html"))" data-testid="instance-report-html" />
                </MudTooltip>
                <MudTooltip Text="@((bool)context.hasReportJson ? "Check backtest integrity" : "Integrity check needs a completed backtest report")">
                    <MudIconButton Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" aria-label="Check backtest integrity"
                                   Disabled="@(!(bool)context.hasReportJson)"
                                   OnClick="@(() => Integrity((Guid)context.id))" data-testid="instance-integrity" />
                </MudTooltip>
            }
            @if (IsActive((string)context.status))
            {
                <MudTooltip Text="@(_stopping.Contains((Guid)context.id) ? "Stopping…" : "Stop instance")">
                    <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Warning"
                                   Disabled="@(_stopping.Contains((Guid)context.id))" aria-label="Stop instance"
                                   OnClick="@(() => Stop((Guid)context.id))" data-testid="instance-stop" />
                </MudTooltip>
            }
            else if (IsTerminal((string)context.status))
            {
                <MudTooltip Text="@(_starting.Contains((Guid)context.id) ? "Starting…" : "Start instance again")">
                    <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                   Disabled="@(_starting.Contains((Guid)context.id))" aria-label="Start instance"
                                   OnClick="@(() => Start((Guid)context.id))" data-testid="instance-start" />
                </MudTooltip>
            }
            <MudTooltip Text="@(IsTerminal((string)context.status) ? "Edit & re-run with changed settings" : "Stop the instance before editing")">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info"
                               Disabled="@(!IsTerminal((string)context.status))" aria-label="Edit instance"
                               OnClick="@(() => Edit((Guid)context.id))" data-testid="instance-edit" />
            </MudTooltip>
            <MudTooltip Text="@(IsActive((string)context.status) ? "Stop the instance before deleting" : "Delete instance")">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               Disabled="@IsActive((string)context.status)" aria-label="Delete instance"
                               OnClick="@(() => Delete((Guid)context.id))" data-testid="instance-delete" />
            </MudTooltip>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Parameter] public string Type { get; set; } = "Run";
    private dynamic[] _items = [];
    // Instances whose Stop/Start request is in flight — their control is disabled until it resolves.
    private readonly HashSet<Guid> _stopping = new();
    private readonly HashSet<Guid> _starting = new();

    protected override Task OnInitializedAsync() => Load();

    // Lets the host page (Run/Backtest) refresh the list immediately after queuing a new instance, so it
    // shows up without waiting for a manual reload. StateHasChanged is required because the parent invoking
    // this method does not re-render this child (its parameters are unchanged).
    public async Task RefreshAsync()
    {
        await Load();
        StateHasChanged();
    }

    private async Task Load()
    {
        // A transient 5xx on the instances feed must not tear down the host page (Run/Backtest) via the
        // ErrorBoundary — degrade to an empty table and let the next poll/refresh recover.
        try
        {
            var all = await Http.GetDynamicArrayAsync("/api/instances/");
            _items = all.Where(i => (string)i.kind == Type).ToArray();
        }
        catch
        {
            _items = [];
        }
    }

    // An instance is only stoppable while it is still executing; once terminal (Stopped/Completed/Failed)
    // the Stop control is disabled and Delete is enabled instead.
    private static bool IsActive(string status) => status is "Running" or "Starting" or "Stopping";

    // Terminal instances can be re-launched with their original config via the Start (▶) control.
    private static bool IsTerminal(string status) => status is "Stopped" or "Completed" or "Failed";

    private static Color StatusColor(string status) => status switch
    {
        "Running" => Color.Success,
        "Completed" or "Stopped" => Color.Default,
        "Failed" => Color.Error,
        _ => Color.Info
    };

    // Carry the lineage id so the detail page can still resolve the instance if its id changed on a background
    // TPH transition (e.g. a backtest that just finished) between the list loading and the click.
    private void Open(Guid id, Guid lineageId) => Nav.NavigateTo($"/instance/{id}?lineage={lineageId}");

    // Runs the Backtest Integrity Lab on this completed backtest's stored report and shows the verdict in a
    // dialog. The icon is disabled unless a JSON report exists, so this only ever opens for an analysable backtest.
    private Task Integrity(Guid id)
    {
        var parameters = new DialogParameters<IntegrityResultDialog> { { x => x.InstanceId, id } };
        return Dialogs.ShowAsync<IntegrityResultDialog>("Backtest integrity", parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
    }

    private async Task DownloadLogs(Guid id)
    {
        try
        {
            var text = await Http.GetStringAsync($"/api/instances/{id}/logs");
            await JS.InvokeVoidAsync("appDownloadText", $"instance-{id:N}.log", text);
        }
        catch
        {
            Snack.Add("No logs available for this instance", Severity.Warning);
        }
    }
    // Downloads the persisted backtest report (json/html). Disabled in the UI unless the backtest completed
    // with a report, so this only ever hits an available file.
    private async Task DownloadReport(Guid id, string ext)
    {
        try
        {
            var text = await Http.GetStringAsync($"/api/instances/{id}/report.{ext}");
            await JS.InvokeVoidAsync("appDownloadText", $"backtest-{id:N}.{ext}", text);
        }
        catch
        {
            Snack.Add("No report available for this instance", Severity.Warning);
        }
    }

    private async Task Stop(Guid id)
    {
        // Immediately notify + disable the Stop icon for this row until the request resolves.
        _stopping.Add(id);
        Snack.Add("Stopping instance…", Severity.Info);
        StateHasChanged();
        try
        {
            var r = await Http.PostAsync($"/api/instances/{id}/stop", null);
            Snack.Add(r.IsSuccessStatusCode ? "Instance stopped" : "Stop failed",
                r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        }
        finally
        {
            _stopping.Remove(id);
            await Load();
        }
    }

    private async Task Start(Guid id)
    {
        // Re-run a stopped/failed instance with its original config; disable the Start icon until it resolves.
        _starting.Add(id);
        Snack.Add("Starting instance…", Severity.Info);
        StateHasChanged();
        try
        {
            var r = await Http.PostAsync($"/api/instances/{id}/start", null);
            Snack.Add(r.IsSuccessStatusCode ? "Instance started" : "Start failed",
                r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        }
        finally
        {
            _starting.Remove(id);
            await Load();
        }
    }

    // Edit a stopped instance's config (account / symbol / timeframe / parameter set / image / backtest
    // window + settings) and re-launch it. Only reachable from a terminal row (the icon is disabled otherwise).
    private async Task Edit(Guid id)
    {
        var parameters = new DialogParameters<EditInstanceDialog> { { x => x.InstanceId, id } };
        var dlg = await Dialogs.ShowAsync<EditInstanceDialog>("Edit instance", parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;
        await Load();
        StateHasChanged();
    }

    private async Task Delete(Guid id)
    {
        if (!await Dialogs.ConfirmAsync(
            "Delete instance?",
            "This permanently removes the instance, its logs and equity history. This cannot be undone.",
            "Delete", "Cancel")) return;
        var r = await Http.DeleteAsync($"/api/instances/{id}");
        Snack.Add(r.IsSuccessStatusCode ? "Instance deleted" : "Delete failed",
            r.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        await Load();
    }
}
