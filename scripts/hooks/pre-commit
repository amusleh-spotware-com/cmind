#!/usr/bin/env bash
# Pre-commit gate: verify staged C# is formatted (whitespace + style + analyzers).
# Fast — scoped to staged .cs files only. Skip with: SKIP_FORMAT_HOOK=1 git commit ...
set -euo pipefail

[ "${SKIP_FORMAT_HOOK:-0}" = "1" ] && exit 0
command -v dotnet >/dev/null 2>&1 || { echo "dotnet not found — skipping format hook"; exit 0; }

mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACM -- '*.cs')
[ ${#staged[@]} -eq 0 ] && exit 0

echo "pre-commit: verifying format on ${#staged[@]} staged C# file(s)..."
include_args=()
for f in "${staged[@]}"; do include_args+=(--include "$f"); done

if ! dotnet format cmind.slnx --verify-no-changes "${include_args[@]}"; then
  echo ""
  echo "!! Formatting/analyzer issues in staged files. Fix with:" >&2
  echo "   dotnet format cmind.slnx ${include_args[*]}" >&2
  echo "   (bypass once with SKIP_FORMAT_HOOK=1)" >&2
  exit 1
fi
