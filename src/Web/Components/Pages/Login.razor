@page "/login"
@layout EmptyLayout
@inject Web.Branding.IBrandingThemeProvider Branding

<PageTitle>Log in — @Branding.Branding.ProductName</PageTitle>

<div class="app-auth">
    <aside class="app-auth-hero">
        <div class="app-auth-hero-glow"></div>
        <div class="app-auth-hero-content">
            <div class="app-auth-hero-brand">
                @if (!string.IsNullOrWhiteSpace(Branding.Branding.LogoUrl))
                {
                    <img src="@Branding.Branding.LogoUrl" alt="@Branding.Branding.ProductName" height="40" />
                }
                else
                {
                    <BrandMark Size="40" />
                }
                <span class="app-login-brand">@Branding.Branding.ProductName</span>
            </div>
            <h1 class="app-auth-hero-title">Automate your cTrader edge.</h1>
            <p class="app-auth-hero-tagline">@Branding.Branding.Description</p>
            <ul class="app-auth-hero-points">
                <li>Build, run &amp; backtest cBots across your nodes</li>
                <li>Mirror trades and guard prop-firm rules automatically</li>
                <li>AI copilots for strategy, review &amp; risk</li>
            </ul>
        </div>
    </aside>

    <main class="app-auth-panel">
        <div class="app-login-card">
            <div class="app-login-logo app-auth-panel-brand">
                <BrandMark Size="40" />
                <span class="app-login-brand">@Branding.Branding.ProductName</span>
            </div>

            <div class="app-login-tabs">
                <div class="app-login-tab app-login-tab-active">LOG IN</div>
            </div>

            <form method="post" action="/api/auth/login" class="app-login-form" id="app-login-form">
                <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />

                <div class="app-login-field">
                    <svg class="app-login-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9BA3AF" stroke-width="2">
                        <rect x="3" y="5" width="18" height="14" rx="2"/>
                        <polyline points="3,7 12,13 21,7"/>
                    </svg>
                    <input type="email" name="Email" placeholder="Enter email" required autofocus autocomplete="username" inputmode="email" />
                </div>

                <div class="app-login-field">
                    <svg class="app-login-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9BA3AF" stroke-width="2">
                        <rect x="5" y="11" width="14" height="10" rx="2"/>
                        <path d="M8 11V7a4 4 0 0 1 8 0v4"/>
                    </svg>
                    <input type="password" name="Password" id="app-login-password" placeholder="Enter password" required autocomplete="current-password" />
                    <button type="button" class="app-login-reveal" id="app-login-reveal" aria-label="Show password">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>

                <label class="app-login-remember">
                    <input type="checkbox" name="RememberMe" value="true" role="switch" checked />
                    <span>Remember me</span>
                </label>

                @if (HasError)
                {
                    <div class="app-login-error" role="alert" data-testid="login-error">Invalid credentials. Check your email and password.</div>
                }

                <button class="app-login-button" type="submit" id="app-login-submit">
                    <span class="app-login-button-label">LOG IN</span>
                    <span class="app-login-spinner" aria-hidden="true"></span>
                </button>
            </form>

            @if (!string.IsNullOrWhiteSpace(Branding.Branding.SupportUrl))
            {
                <a class="app-login-support" href="@Branding.Branding.SupportUrl" target="_blank" rel="noopener">Need help signing in?</a>
            }
            <div class="app-login-copyright">
                &copy; @DateTime.UtcNow.Year @(string.IsNullOrWhiteSpace(Branding.Branding.CompanyName) ? Branding.Branding.ProductName : Branding.Branding.CompanyName)
            </div>
        </div>
    </main>
</div>

<script>
    (function () {
        var reveal = document.getElementById('app-login-reveal');
        var pwd = document.getElementById('app-login-password');
        if (reveal && pwd) {
            reveal.addEventListener('click', function () {
                var show = pwd.type === 'password';
                pwd.type = show ? 'text' : 'password';
                reveal.classList.toggle('app-login-reveal-on', show);
                reveal.setAttribute('aria-label', show ? 'Hide password' : 'Show password');
            });
        }
        var form = document.getElementById('app-login-form');
        var submit = document.getElementById('app-login-submit');
        if (form && submit) {
            form.addEventListener('submit', function () {
                submit.classList.add('app-login-button-loading');
                submit.disabled = true;
            });
        }
    })();
</script>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery(Name = "error")] public string? Error { get; set; }
    private bool HasError => !string.IsNullOrEmpty(Error);
}
