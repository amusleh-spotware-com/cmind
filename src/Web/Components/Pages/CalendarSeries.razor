@page "/economic-calendar/series/{Code}"
@using Core.Calendar
@using Core.Features
@using Core.Options
@using Microsoft.Extensions.Options
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UserOrAbove")]
@inject IStringLocalizer<Ui> L
@inject IEconomicCalendar Calendar
@inject IFeatureGate Gate
@inject IOptionsMonitor<AppOptions> Options
@inject TimeProvider Time

<PageTitle>@Code</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/economic-calendar"
                   aria-label="@L["common.close"]" />
    <MudText Typo="Typo.h5">@Code</MudText>
    <HelpTip Text='@L["calendar.series.help"]' />
</MudStack>
<MudText Typo="Typo.subtitle2" Class="mb-3 mud-text-secondary">@L["calendar.series.title"]</MudText>

@if (!_enabled)
{
    <MudAlert Severity="Severity.Info">@L["calendar.empty"]</MudAlert>
}
else if (!_hasSource)
{
    <MudAlert Severity="Severity.Warning" data-testid="calendar-source-required">@L["calendar.sourceRequired"]</MudAlert>
}
else if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" data-testid="series-loading" />
    <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary" data-testid="series-loading-text">@L["calendar.series.loading"]</MudText>
}
else if (_events.Count == 0)
{
    <MudAlert Severity="Severity.Normal" data-testid="series-empty">@L["calendar.series.empty"]</MudAlert>
}
else
{
    <MudStack Spacing="2">
        @foreach (var e in _events)
        {
            <MudCard Elevation="1">
                <MudCardContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body2"><UserTime Value="e.EffectiveAt" Format="g" /></MudText>
                        <MudChip T="string" Size="Size.Small" Color="@ImpactColor(e.Impact)">@ImpactLabel(e.Impact)</MudChip>
                        <MudSpacer />
                        @if (e.Released)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@L["calendar.released"]</MudChip>
                        }
                    </MudStack>
                    <MudStack Row="true" Spacing="4" Class="mt-1">
                        <div>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@L["calendar.actual"]</MudText>
                            <MudText Typo="Typo.body2">@Format(e.Actual)</MudText>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@L["calendar.forecast"]</MudText>
                            <MudText Typo="Typo.body2">@Format(e.Forecast)</MudText>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@L["calendar.previous"]</MudText>
                            <MudText Typo="Typo.body2">@Format(e.Previous)</MudText>
                        </div>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        }
    </MudStack>
}

@code {
    [Parameter] public string Code { get; set; } = string.Empty;

    private IReadOnlyList<CalendarEventView> _events = [];
    private bool _enabled;
    private bool _hasSource;
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _enabled = CalendarEnablement.IsEnabled(Options.CurrentValue.Branding, Gate);
        _hasSource = CalendarEnablement.HasConfiguredSource(Options.CurrentValue.Calendar);
        if (!_enabled || !_hasSource)
        {
            _loading = false;
            return;
        }

        _loading = true;
        var now = Time.GetUtcNow();
        _events = await Calendar.GetEventsAsync(new CalendarQuery
        {
            Series = [Code],
            From = now.AddYears(-10),
            To = now.AddDays(30),
            Limit = 200
        }, CancellationToken.None);
        _loading = false;
    }

    private static string Format(decimal? value) => value?.ToString("0.##") ?? "—";

    private static Color ImpactColor(ImpactLevel level) => level switch
    {
        ImpactLevel.Critical => Color.Error,
        ImpactLevel.High => Color.Warning,
        ImpactLevel.Medium => Color.Info,
        _ => Color.Default
    };

    private string ImpactLabel(ImpactLevel level) => L[level switch
    {
        ImpactLevel.Critical => "calendar.impact.critical",
        ImpactLevel.High => "calendar.impact.high",
        ImpactLevel.Medium => "calendar.impact.medium",
        _ => "calendar.impact.low"
    }];
}
